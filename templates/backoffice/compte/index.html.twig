{% extends 'backoffice.html.twig' %}
{% block title %}Comptes - Liste{% endblock %}
{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'items': ['Accueil','Comptes','Liste']} %}
  {% include 'partials/_flash.html.twig' %}

  <div class="MfCard">
    <div class="MfDataTable">
      {% if data is defined and data.data is iterable and data.data|length > 0 %}
        <table class="table">
          <thead>
            <tr>
              <th>Numéro</th>
              <th>Titulaire</th>
              <th>Solde</th>
              <th>Statut</th>
              <th>Agence</th>
              <th>Date ouverture</th>
            </tr>
          </thead>
          <tbody>
            {% for compte in data.data %}
              <tr>
                <td>{{ compte.num ?? compte.numero ?? '' }}</td>
                <td>{{ compte.titulaire ?? '' }}</td>
              <td><span class="MfMoneyInput">{{ compte.solde ?? 0 }}</span></td>
                <td><span class="MfStatusBadge" data-status="{{ compte.status ?? '' }}">{{ compte.status_label ?? (compte.status ?? '') }}</span></td>
                <td>{{ compte.agence ?? '' }}</td>
                <td>{{ compte.date_ouverture ?? '' }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
        {% include 'partials/_pagination.html.twig' with {'total': data.total ?? 0} %}
      {% else %}
        {% include 'partials/_empty_state.html.twig' with {'message': 'Aucun compte trouvé'} %}
      {% endif %}
    </div>
  </div>
{% endblock %}
