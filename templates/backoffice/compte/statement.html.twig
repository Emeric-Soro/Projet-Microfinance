{% extends 'backoffice.html.twig' %}
{% block title %}État du compte - {{ num }}{% endblock %}
{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'items': ['Accueil','Comptes','État'] } %}
  {% include 'partials/_flash.html.twig' %}

  <div class="MfCard">
    <div class="MfFormCard">
      <h3>Plage de dates</h3>
      <form>
        <div class="field">
          <label>Début</label>
          <input class="MfDatePicker" type="text" name="start" />
        </div>
        <div class="field">
          <label>Fin</label>
          <input class="MfDatePicker" type="text" name="end" />
        </div>
        <button class="MfButton" type="submit">Voir échantillon</button>
      </form>
    </div>
  </div>

  {% if data is iterable and data|length > 0 %}
  <div class="MfCard">
    <div class="MfDataTable">
      <table class="table">
        <thead><tr><th>Date</th><th>Description</th><th>Montant</th></tr></thead>
        <tbody>
          {% for s in data %}
            <tr>
              <td>{{ s.date ?? '' }}</td>
              <td>{{ s.description ?? '' }}</td>
              <td>{{ s.amount ?? '' }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <button class="MfButton">Exporter PDF</button>
    <button class="MfButton">Exporter Excel</button>
  </div>
  {% endif %}
{% endblock %}
