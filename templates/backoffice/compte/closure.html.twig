{% extends 'backoffice.html.twig' %}
{% block title %}Clôture de compte{% endblock %}
{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'items': ['Accueil','Comptes','Clôture'] } %}
  {% include 'partials/_flash.html.twig' %}
  <div class="MfCard">
    <div class="MfFormCard">
      <h3>Clôturer le compte</h3>
      <form method="post">
        <div class="field">
          <label>Raison</label>
          <textarea name="reason" class="mf-input"></textarea>
        </div>
        <button class="MfButton" type="submit">Clôturer</button>
      </form>
    </div>
  </div>
{% endblock %}
