{# Validation queue - lists with filters #}
{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'backoffice/partials/_breadcrumb.html.twig' with {'path': ['Accueil','Validations/Conformité','Validation queue']} %}
  {% include 'backoffice/partials/_table_toolbar.html.twig' with {'title': 'Filtrer les validations'} %}

  <div class="MfCard">
    <div class="MfDataTable">
      <table>
        <thead>
          <tr>
            <th>Priorité</th>
            <th>Type</th>
            <th>Créateur</th>
            <th>Date</th>
            <th>Montant</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for row in data.data %}
          <tr>
            <td>{{ row.priority ?? row.type_priority ?? '' }}</td>
            <td>{{ row.type ?? '' }}</td>
            <td>{{ row.maker ?? '' }}</td>
            <td>{{ row.date|date('d/m/Y') ?? '' }}</td>
            <td>{{ row.amount ? ('€ ' ~ row.amount) : '' }}</td>
            <td>
              <a class="MfButton" href="/validations/{{ row.id }}">Voir</a>
              <form method="post" action="/validations/{{ row.id }}/approve" style="display:inline;">
                <button class="MfButton MfButton--primary" type="submit">Approuver</button>
              </form>
              <form method="post" action="/validations/{{ row.id }}/reject" style="display:inline;">
                <button class="MfButton" type="submit">Rejeter</button>
              </form>
              <form method="post" action="/validations/{{ row.id }}/revision" style="display:inline;">
                <button class="MfButton" type="submit">Révision</button>
              </form>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
