{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'backoffice/partials/_breadcrumb.html.twig' with {'path': ['Accueil','Validations/Conformité','Mes actions']} %}
  <div class="MfCard">
    <h2>Mes actions sur les validations</h2>
    <div class="MfDataTable">
      <table>
        <thead><tr><th>Date</th><th>Action</th><th>Statut</th></tr></thead>
        <tbody>
          {% for r in data.data %}
          <tr><td>{{ r.date|date('d/m/Y') }}</td><td>{{ r.action ?? '' }}</td><td>{{ r.status ?? '' }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
