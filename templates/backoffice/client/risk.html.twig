{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'path': 'Accueil > Clients > Risque'} %}
  {% include 'partials/_flash.html.twig' %}

  <MfCard>
    <h3>Évaluation de risque</h3>
    <MfFormCard>
      <form method="post" action="/clients/{{ id ?? 0 }}/risk">
        <div class="grid">
          <MfInput name="risque_financier" label="Risque financier" />
          <MfInput name="risque_reputation" label="Risque réputationnel" />
          <MfInput name="risque_operationnel" label="Risque opérationnel" />
        </div>
        <MfButton label="Enregistrer" type="primary" />
      </form>
    </MfFormCard>
  </MfCard>
{% endblock %}
