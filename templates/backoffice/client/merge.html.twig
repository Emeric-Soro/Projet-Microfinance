{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'path': 'Accueil > Clients > Fusion'} %}
  {% include 'partials/_flash.html.twig' %}

  <MfCard>
    <MfFormCard>
      <h3>Fusionner deux clients</h3>
      <form method="post" action="/clients/merge">
        <MfSelect name="source" label="Client source" />
        <MfSelect name="target" label="Client cible" />
        <MfButton label="Fusionner" type="primary" />
      </form>
    </MfFormCard>
  </MfCard>
{% endblock %}
