{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'path': 'Accueil > Clients > Recherche'} %}
  {% include 'partials/_flash.html.twig' %}

  <MfCard>
    <MfFormCard>
      <h3>Recherche avancée</h3>
      <form method="post" action="/clients/search">
        <div class="grid">
          <MfInput name="name" label="Nom" />
          <MfInput name="id" label="Identifiant" />
          <MfInput name="phone" label="Téléphone" />
          <MfInput name="email" label="Email" />
          <MfDatePicker name="date_range" label="Période" />
        </div>
        <MfButton label="Rechercher" type="primary" submitKey="Enter" />
      </form>
    </MfFormCard>
  </MfCard>

  <MfCard>
    <MfTableToolbar />
    <MfDataTable headers="Nom,Identifiant,Téléphone,Email" rows="{{ results|length ? results|json_encode : '[]' }}" />
  </MfCard>
{% endblock %}
