{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'path': 'Accueil > Clients > Détails'} %}
  {% include 'partials/_flash.html.twig' %}

  <MfCard>
    <MfTabs active="infos" id="client-tabs">
      <MfTab label="Infos" href="#infos">
        <div id="infos">
          <p>Nom: {{ client.nom|default('—') }}</p>
          <p>Identifiant: {{ client.id|default('—') }}</p>
        </div>
      </MfTab>
      <MfTab label="KYC" href="#kyc"><div id="kyc">Détail KYC</div></MfTab>
      <MfTab label="Comptes" href="#accounts"><div id="accounts">Comptes</div></MfTab>
      <MfTab label="Crédits" href="#credits"><div id="credits">Crédits</div></MfTab>
      <MfTab label="Épargne" href="#savings"><div id="savings">Épargne</div></MfTab>
      <MfTab label="Opérations" href="#operations"><div id="operations">Opérations</div></MfTab>
      <MfTab label="Documents" href="#documents"><div id="documents">Documents</div></MfTab>
    </MfTabs>
  </MfCard>
{% endblock %}
