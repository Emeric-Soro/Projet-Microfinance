{# List view for clients with toolbar, search, filters, export and pagination #}
{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'path': 'Accueil > Clients'} %}
  {% include 'partials/_flash.html.twig' %}

  <MfCard>
    <div class="toolbar">
      <MfButton label="Nouveau" type="primary" link="/clients/create" />
      <MfSelect name="type" label="Type" options="Physical,Firm" />
      <MfSelect name="status" label="Statut" options="Actif,Suspendu,Archivé" />
      <MfInput name="search" placeholder="Rechercher..." />
      <MfButton label="Rechercher" type="secondary" />
      <MfButton label="Exporter" type="default" />
    </div>
  </MfCard>

  <MfDataTable headers="Nom,Type,Statut,Actions" rows="{{ clients|length ? clients|json_encode : '[]' }}" selectable="true" empty_title="Aucun client" empty_message="Aucun client trouvé">
  </MfDataTable>

  {% include 'partials/_pagination.html.twig' with {'page': page, 'pages': pages} %}
{% endblock %}
