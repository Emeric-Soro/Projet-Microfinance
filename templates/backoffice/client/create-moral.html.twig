{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'partials/_breadcrumb.html.twig' with {'path': 'Accueil > Clients > Créer (Moral)'} %}
  {% include 'partials/_flash.html.twig' %}

  <MfCard>
    <MfFormCard>
      <h3>Créer une société (client moral)</h3>
      <form method="post" action="/clients/create/moral">
        <div class="grid">
          <MfInput name="raisonSociale" label="Raison sociale" />
          <MfInput name="sigle" label="Sigle" />
          <MfInput name="formeJuridique" label="Forme juridique" />
          <MfInput name="capitalSocial" label="Capital social" />
          <MfInput name="numeroContribuable" label="Numéro de contribuable" />
          <MfInput name="registreCommerce" label="Registre du commerce" />
          <MfDatePicker name="dateCreation" label="Date de création" />
          <MfInput name="siegeSocial" label="Siège social" />
          <MfInput name="telephone" label="Téléphone" />
          <MfInput name="email" label="Email" />
          <MfInput name="secteurActivite" label="Secteur d'activité" />
          <MfInput name="representantLégal" label="Représentant légal" />
        </div>
        <MfButton label="Enregistrer" type="primary" />
      </form>
    </MfFormCard>
  </MfCard>
{% endblock %}
