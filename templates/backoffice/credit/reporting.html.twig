{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Reporting'] } %}
{% include 'partials/_flash.html.twig' %}

<h1>Reporting Crédit</h1>

<section class="MfCard">
    <header>Rapports</header>
    {% if reports is defined and reports|length > 0 %}
        <ul>
        {% for r in reports %}
            <li>{{ r.title ?? 'Rapport' }} - {{ r.date ?? '' }}</li>
        {% endfor %}
        </ul>
    {% else %}
        <p>Aucun rapport.</p>
    {% endif %}
    </section>
