{# Liste des demandes de crédit #}
{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Demandes']} %}
{% include 'partials/_flash.html.twig' %}

<h1>Demandes de Crédit</h1>

<section class="MfDataTable">
    {% if data is defined and data|length > 0 %}
        <table class="MfDataTable__Table">
            <thead><tr><th>ID</th><th>Client</th><th>Produit</th><th>Montant</th><th>État</th><th>Date</th></tr></thead>
            <tbody>
            {% for r in data %}
                <tr>
                    <td>{{ r.id }}</td>
                    <td>{{ r.client ?? '' }}</td>
                    <td>{{ r.product ?? '' }}</td>
                    <td>{{ r.amount ?? 0 }}</td>
                    <td>{% include 'partials/_status_badge.html.twig' with {'status': r.status ?? 'en_attente'} %}</td>
                    <td>{{ r.date ?? '' }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucune demande trouvée.</p>
    {% endif %}
    </section>
