{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Alertes'] } %}
{% include 'partials/_flash.html.twig' %}

<h1>Alertes Crédit</h1>

<section class="MfTable">
    <h2>Liste des alertes</h2>
    {% if alerts is defined and alerts|length > 0 %}
        <ul>
        {% for a in alerts %}
            <li>{{ a.message ?? '' }} - {{ a.date ?? '' }}</li>
        {% endfor %}
        </ul>
    {% else %}
        <p>Aucune alerte.</p>
    {% endif %}
    </section>
