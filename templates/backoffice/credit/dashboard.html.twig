{# Dashboard Crédit - Vue principale #}
{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Tableau de bord']} %}
{% include 'partials/_flash.html.twig' %}

<h1>Tableau de bord Crédit</h1>

<section class="MfStatsGrid">
    {% if kpis is defined and kpis|length > 0 %}
        {% for label, value in kpis %}
            <div class="MfStatsGrid__Item">
                <div class="MfStatsGrid__Label">{{ label }}</div>
                <div class="MfStatsGrid__Value">{{ value }}</div>
            </div>
        {% endfor %}
    {% else %}
        <div class="MfStatsGrid__Item"><div class="MfStatsGrid__Label">Portefeuille</div><div class="MfStatsGrid__Value">0</div></div>
        <div class="MfStatsGrid__Item"><div class="MfStatsGrid__Label">Décaissements</div><div class="MfStatsGrid__Value">0</div></div>
        <div class="MfStatsGrid__Item"><div class="MfStatsGrid__Label">PAR</div><div class="MfStatsGrid__Value">0</div></div>
        <div class="MfStatsGrid__Item"><div class="MfStatsGrid__Label">Créances en retard</div><div class="MfStatsGrid__Value">0</div></div>
        <div class="MfStatsGrid__Item"><div class="MfStatsGrid__Label">Provision</div><div class="MfStatsGrid__Value">0</div></div>
        <div class="MfStatsGrid__Item"><div class="MfStatsGrid__Label">Solde</div><div class="MfStatsGrid__Value">0</div></div>
    {% endif %}
</section>

<section class="MfSummaryCard">
    <h2>Résumé des produits</h2>
    {% if products is defined and products|length > 0 %}
        <ul>
            {% for p in products %}
                <li>{{ p.name ?? 'Produit' }} - {{ p.count ?? 0 }} crédits</li>
            {% endfor %}
        </ul>
    {% else %}
        <p>Aucun produit pour le moment.</p>
    {% endif %}
    </section>

<section class="MfTable">
    <h2>Récents</h2>
    {% if requests is defined and requests|length > 0 %}
        <table class="MfDataTable__Table">
            <thead><tr><th>ID</th><th>Client</th><th>Montant</th><th>Statut</th><th>Date</th></tr></thead>
            <tbody>
            {% for r in requests %}
                <tr>
                    <td>{{ r.id }}</td>
                    <td>{{ r.client ?? '' }}</td>
                    <td>{{ r.amount ?? 0 }}</td>
                    <td>{% include 'partials/_status_badge.html.twig' with {'status': r.status ?? 'en_attente'} %}</td>
                    <td>{{ r.date ?? '' }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucune demande récemment créée.</p>
    {% endif %}
    </section>

<section class="MfAlerts">
    {% if app.flashes['error'] is defined and app.flashes['error']|length > 0 %}
        {% for msg in app.flashes['error'] %}
            <div class="MfAlertBanner error">{{ msg }}</div>
        {% endfor %}
    {% endif %}
    {% if app.flashes['success'] is defined and app.flashes['success']|length > 0 %}
        {% for msg in app.flashes['success'] %}
            <div class="MfAlertBanner success">{{ msg }}</div>
        {% endfor %}
    {% endif %}
    </section>
