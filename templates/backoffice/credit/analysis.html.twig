{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Analyse'] } %}
{% include 'partials/_flash.html.twig' %}

<h1>Analyse financière</h1>

<section class="MfFormCard">
    <header>Finances et flux de trésorerie</header>
    <form method="post" action="">
        <div class="MfFormRow">
            <label>Flux de trésorerie</label>
            <input class="MfInput" name="_cashflow" type="text" placeholder="Flux" />
        </div>
        <div class="MfFormRow">
            <label>Cash-in / Cash-out</label>
            <input class="MfInput" name="cashinout" type="text" placeholder="Cash in/out" />
        </div>
        <button class="MfButton" type="submit">Actualiser</button>
    </form>
    </section>

<section class="MfTable">
    <h2>Indicateurs financiers</h2>
    {% if data is defined %}
        <table class="MfDataTable__Table">
            <thead><tr><th>Indicateur</th><th>Valeur</th></tr></thead>
            <tbody>
            {% for key, value in data %}
                <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
    </section>
