{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Provisions'] } %}
{% include 'partials/_flash.html.twig' %}

<h1>Provisions</h1>

<section class="MfTable">
    <h2>Calculs de provisions</h2>
    <table class="MfDataTable__Table">
        <thead><tr><th>Crédit</th><th>Montant</th><th>Provision</th></tr></thead>
        <tbody>
        {% if provisions is defined %}
            {% for p in provisions %}
                <tr><td>{{ p.credit_id }}</td><td>{{ p.amount }}</td><td>{{ p.provision }}</td></tr>
            {% endfor %}
        {% else %}
            <tr><td colspan="3">Aucune provision</td></tr>
        {% endif %}
        </tbody>
    </table>
    </section>
