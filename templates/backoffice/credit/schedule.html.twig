{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Calendrier'] } %}
{% include 'partials/_flash.html.twig' %}

<h1>Calendrier amortissement</h1>

<section class="MfTable">
    <h2>Échéancier</h2>
    {% if data is defined and data|length > 0 %}
        <table class="MfDataTable__Table">
            <thead><tr><th>Période</th><th>Intérêt</th><th>Principal</th><th>Solde</th></tr></thead>
            <tbody>
            {% for row in data %}
                <tr>
                    <td>{{ row.period }}</td>
                    <td>{{ row.interest }}</td>
                    <td>{{ row.principal }}</td>
                    <td>{{ row.balance }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucun échéancier.</p>
    {% endif %}
    </section>
