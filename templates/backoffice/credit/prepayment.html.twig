{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Prépaiement'] } %}
{% include 'partials/_flash.html.twig' %}

<h1>Prépaiement</h1>

<section class="MfCard">
    <header>Calculateur de prépaiement</header>
    <form method="post" action="">
        <div class="MfFormRow">
            <label>Montant restant</label>
            <input class="MfMoneyInput" name="amount" type="text" />
        </div>
        <button class="MfButton" type="submit">Calculer</button>
    </form>
    </section>

<section class="MfTable">
    <h2>Résultat</h2>
    {% if data is defined %}
        <p>Économies potentielles: {{ data_savings ?? 0 }}</p>
    {% else %}
        <p>Entrez un montant pour calculer les économies potentielles.</p>
    {% endif %}
    </section>
