{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Documents de la demande']} %}
{% include 'partials/_flash.html.twig' %}

<h1>Documents - Demande</h1>

<section class="MfCard">
    <header>Téléversement</header>
    <form method="post" enctype="multipart/form-data" action="">
        <div class="MfFormRow">
            <label>Fichiers</label>
            <input type="file" name="documents" />
        </div>
        <button class="MfButton" type="submit">Téléverser</button>
    </form>
    </section>

<section class="MfTable">
    <h2>Documents existants</h2>
    {% if documents is defined and documents|length > 0 %}
        <ul>
        {% for d in documents %}
            <li>{{ d.name ?? 'Document' }} - {{ d.size ?? '' }}</li>
        {% endfor %}
        </ul>
    {% else %}
        <p>Aucun document.</p>
    {% endif %}
    </section>
