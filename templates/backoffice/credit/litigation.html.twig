{% include 'partials/_breadcrumb.html.twig' with {'path': ['Accueil','Crédit','Litige'] } %}
{% include 'partials/_flash.html.twig' %}

<h1>Litige Crédit</h1>

<section class="MfCard">
    <header>Dossier litige</header>
    <form method="post" action="">
        <div class="MfFormRow">
            <label>Statut</label>
            <select class="MfSelect" name="status">
                <option>En cours</option>
                <option>Résolu</option>
            </select>
        </div>
        <button class="MfButton" type="submit">Mettre à jour</button>
    </form>
    </section>

<section class="MfTable">
    <h2>Cas en litige</h2>
    {% if data is defined %}
        <ul>
        {% for c in data %}
            <li>{{ c.id ?? '' }} - {{ c.description ?? '' }}</li>
        {% endfor %}
        </ul>
    {% else %}
        <p>Aucun litige.</p>
    {% endif %}
    </section>
