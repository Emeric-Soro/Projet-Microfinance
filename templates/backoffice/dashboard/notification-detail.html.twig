{% extends 'backoffice.html.twig' %}

{% block title %}Détail Notification{% endblock %}

{% block content %}
    {% include '_breadcrumb.html.twig' with {'breadcrumbs': breadcrumbs} %}
    <div class="page-header mb-4 d-flex justify-content-between align-items-center">
        <h1 class="h3 mb-0">Détail Notification</h1>
        <div class="actions"></div>
    </div>

    <div class="MfCard bg-white rounded-lg shadow-card border-teal-100 p-4">
        {% if notification is defined and notification is not empty %}
            <h3 class="mb-2">Notification</h3>
            <p>{{ notification.message ?? 'Aucun contenu' }}</p>
            <div class="text-sm text-gray-500">Date: {{ notification.date ?? '' }}</div>
        {% else %}
            <div class="text-sm text-gray-600">Aucune notification sélectionnée</div>
        {% endif %}
    </div>
{% endblock %}
