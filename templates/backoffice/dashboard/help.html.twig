{% extends 'backoffice.html.twig' %}

{% block title %}Aide & FAQ{% endblock %}

{% block content %}
    {% include '_breadcrumb.html.twig' with {'breadcrumbs': breadcrumbs} %}
    <div class="page-header mb-4 d-flex justify-content-between align-items-center">
        <h1 class="h3 mb-0">Aide</h1>
        <div class="actions"></div>
    </div>

    <div class="card bg-white rounded-lg shadow-card border-teal-100 p-4">
        <h3 class="mb-2">FAQ</h3>
        <div class="accordion" id="faqAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header" id="faq1">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse1" aria-expanded="true" aria-controls="collapse1">Comment accéder aux dashboards ?</button>
                </h2>
                <div id="collapse1" class="accordion-collapse collapse show" aria-labelledby="faq1" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Utilisez le menu de navigation gauche pour accéder aux vues Générale, Agences, Caissier, Crédit, Conformité, Comptable et Direction.</div>
                </div>
            </div>
            <div class="accordion-item">
                <h2 class="accordion-header" id="faq2">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse2" aria-expanded="false" aria-controls="collapse2">Comment configurer mes préférences ?</button>
                </h2>
                <div id="collapse2" class="accordion-collapse collapse" aria-labelledby="faq2" data-bs-parent="#faqAccordion">
                    <div class="accordion-body">Rendez-vous dans Profil > Préférences et ajustez la langue, le thème et les notifications.</div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
