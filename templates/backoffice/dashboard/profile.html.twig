{% extends 'backoffice.html.twig' %}

{% block title %}Profil Utilisateur{% endblock %}

{% block content %}
    {% include '_breadcrumb.html.twig' with {'breadcrumbs': breadcrumbs} %}
    <div class="page-header mb-4 d-flex justify-content-between align-items-center">
        <h1 class="h3 mb-0">Profil</h1>
        <div class="actions"></div>
    </div>

    <form method="post" class="MfFormCard bg-white rounded-lg shadow-card border-teal-100 p-4">
        {% if profile is defined %}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label>Nom</label>
                    <input type="text" name="nom" value="{{ profile.nom ?? '' }}" class="form-control" />
                </div>
                <div>
                    <label>Prénom</label>
                    <input type="text" name="prenom" value="{{ profile.prenom ?? '' }}" class="form-control" />
                </div>
                <div>
                    <label>Email</label>
                    <input type="email" name="email" value="{{ profile.email ?? '' }}" class="form-control" />
                </div>
                <div>
                    <label>Téléphone</label>
                    <input type="text" name="telephone" value="{{ profile.telephone ?? '' }}" class="form-control" />
                </div>
                <div class="md:col-span-2">
                    <label>Photo</label>
                    <input type="text" name="photo" value="{{ profile.photo ?? '' }}" class="form-control" />
                </div>
            </div>
        {% else %}
            <div class="text-sm text-gray-600">Aucune donnée utilisateur disponible</div>
        {% endif %}
        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
        </div>
    </form>
{% endblock %}
