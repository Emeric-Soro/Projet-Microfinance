{% extends 'backoffice.html.twig' %}

{% block title %}Tableau - Comptable{% endblock %}

{% block content %}
    {% include '_breadcrumb.html.twig' with {'breadcrumbs': breadcrumbs} %}
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Comptable</h1>
        <div class="actions"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            {% include 'components/MfStatsGrid.html.twig' with {'cols': 2, 'stats': stats} %}
        </div>
        <div class="space-y-4">
            <div class="card bg-white rounded-lg shadow-card border-teal-100 p-4">
                <h3 class="mb-2">Ratios et Bilan</h3>
                {% if recent|length > 0 %}
                    {% include 'components/MfDataTable.html.twig' with {'headers': ['P&L','Ratio'], 'rows': recent} %}
                {% else %}
                    <div class="text-sm text-gray-600">Aucune donnée</div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
