{% extends 'backoffice.html.twig' %}

{% block title %}Tableau de bord - Général{% endblock %}

{% block content %}
    {% include '_breadcrumb.html.twig' with {'breadcrumbs': breadcrumbs} %}
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Général</h1>
        <div class="actions">
            {% include 'components/MfButton.html.twig' with {'label': 'Actualités', 'url': '#'} %}
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
            {% include 'components/MfStatsGrid.html.twig' with {'cols': 2, 'stats': stats} %}
        </div>
        <div class="space-y-4">
            <div class="card bg-white rounded-lg shadow-card border-teal-100 p-4">
                <h3 class="mb-2">Activité récente</h3>
                <ul class="list-disc pl-5 text-sm text-gray-700">
                    {% for r in recent %}
                        <li>{{ r.label ?? r.message ?? '' }}{% if r.date %} — {{ r.date }}{% endif %}</li>
                    {% else %}
                        <li>Aucune activité récente</li>
                    {% endfor %}
                </ul>
            </div>
            {% for alert in alerts %}
                {% include 'partials/_status_badge.html.twig' with {'status': alert.status ?? ''} %}
                {% include 'components/MfAlertBanner.html.twig' with {'alert': alert} %}
            {% else %}
                <div class="text-sm text-gray-500">Aucune alerte</div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
