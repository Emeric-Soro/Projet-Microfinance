{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'backoffice/partials/_breadcrumb.html.twig' with {'path': ['Accueil','Conformité','PEP']} %}
  <div class="MfCard">
    <h2>PEP conformite</h2>
    <div class="MfDataTable">
      <table>
        <thead><tr><th>PEP</th><th>Description</th></tr></thead>
        <tbody>
          {% for r in data.data %}
          <tr><td>{{ r.pep ?? '' }}</td><td>{{ r.description ?? '' }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
