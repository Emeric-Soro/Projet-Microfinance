{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'backoffice/partials/_breadcrumb.html.twig' with {'path': ['Accueil','Conformité','Profil de risque']} %}
  <div class="MfCard">
    <h2>Profil de risque</h2>
    <div class="MfDataTable">
      <table>
        <thead><tr><th>Catégorie</th><th>Indicateur</th><th>Valeur</th></tr></thead>
        <tbody>
          {% for r in data.data %}
          <tr><td>{{ r.category ?? '' }}</td><td>{{ r.metric ?? '' }}</td><td>{{ r.value ?? '' }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
