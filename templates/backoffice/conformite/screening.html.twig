{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'backoffice/partials/_breadcrumb.html.twig' with {'path': ['Accueil','Conformité','Screening']} %}
  <div class="MfCard">
    <h2>Screening conformité</h2>
    <div class="MfDataTable">
      <table>
        <thead><tr><th>Résultat</th><th>Détails</th></tr></thead>
        <tbody>
          {% for r in data.data %}
          <tr><td>{{ r.result ?? '' }}</td><td>{{ r.details ?? '' }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
