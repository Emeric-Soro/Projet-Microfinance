{% extends 'backoffice.html.twig' %}

{% block content %}
  {% include 'backoffice/partials/_breadcrumb.html.twig' with {'path': ['Accueil','Conformité','Correspondents bancaires']} %}
  <div class="MfCard">
    <h2>Correspondents bancaires</h2>
    <div class="MfDataTable">
      <table>
        <thead><tr><th>Nom</th><th>Code Banque</th></tr></thead>
        <tbody>
          {% for r in data.data %}
          <tr><td>{{ r.name ?? '' }}</td><td>{{ r.bankCode ?? '' }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
