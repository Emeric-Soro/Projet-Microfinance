{% extends 'auth/auth.html.twig' %}

{% block title %}Mot de passe expiré - MicroFin{% endblock %}

{% block auth_content %}
<div class="MfFormCard" style="max-width:520px;margin:0 auto;padding:20px;border-radius:8px;box-shadow:0 2px 12px rgba(0,0,0,0.05);background:#fff;">
  <h2 style="font-family: 'Manrope', sans-serif;margin-bottom:8px;">Mot de passe expiré</h2>
  <p style="color:#555;">Votre mot de passe a expiré. Veuillez définir un nouveau mot de passe.</p>
  <form method="post" action="{{ path('change_expired_password') }}">
    <div class="MfInput" style="margin-bottom:12px;">
      <label for="current_password">Mot de passe actuel</label>
      <input id="current_password" name="current_password" type="password" required class="form-control" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;" />
    </div>
    <div class="MfInput" style="margin-bottom:12px;">
      <label for="new_password">Nouveau mot de passe</label>
      <input id="new_password" name="new_password" type="password" required class="form-control" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;" />
    </div>
    <div class="MfInput" style="margin-bottom:12px;">
      <label for="confirm_password">Confirmer le mot de passe</label>
      <input id="confirm_password" name="confirm_password" type="password" required class="form-control" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;" />
    </div>
    <p class="hint" style="font-size:12px;color:#555;">Min. 8 caractères. Utilisez une combinaison de lettres et chiffres.</p>
    <button type="submit" class="MfButton" style="width:100%;padding:12px;background:#004D61;color:white;border:none;border-radius:4px;">Changer le mot de passe</button>
  </form>
</div>
{% endblock %}
