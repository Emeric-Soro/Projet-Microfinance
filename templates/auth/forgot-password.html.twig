{% extends 'auth/auth.html.twig' %}

{% block title %}Mot de passe oublié - MicroFin{% endblock %}

{% block auth_content %}
<div class="MfFormCard" style="max-width:420px;margin:0 auto;padding:20px;border-radius:8px;box-shadow:0 2px 12px rgba(0,0,0,0.05);background:#fff;">
  <h2 style="font-family: 'Manrope', sans-serif;margin-bottom:8px;">Réinitialisation du mot de passe</h2>
  <form method="post" action="{{ path('forgot_password') }}">
    <div class="MfInput" style="margin-bottom:12px;">
      <label for="email">Adresse e-mail</label>
      <input id="email" name="email" type="email" required class="form-control" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;" />
    </div>
    <button type="submit" class="MfButton" style="width:100%;padding:12px;background:#004D61;color:white;border:none;border-radius:4px;">Envoyer le lien</button>
  </form>
  <div class="auth-links" style="margin-top:12px;">
    <a href="{{ path('login') }}">Retour à la connexion</a>
  </div>
</div>
{% endblock %}
