{% extends 'auth/auth.html.twig' %}

{% block title %}Nouveau mot de passe - MicroFin{% endblock %}

{% block auth_content %}
<div class="MfFormCard" style="max-width:420px;margin:0 auto;padding:20px;border-radius:8px;box-shadow:0 2px 12px rgba(0,0,0,0.05);background:#fff;">
  <h2 style="font-family: 'Manrope', sans-serif;margin-bottom:8px;">Définir un nouveau mot de passe</h2>
  <form method="post" action="{{ path('reset_password', {'token': token|default('')}) }}">
    <input type="hidden" name="token" value="{{ token|default('') }}" />
    <div class="MfInput" style="margin-bottom:12px;">
      <label for="password">Nouveau mot de passe</label>
      <input id="password" name="password" type="password" required class="form-control" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;" />
    </div>
    <div class="MfInput" style="margin-bottom:12px;">
      <label for="confirmPassword">Confirmer le mot de passe</label>
      <input id="confirmPassword" name="confirmPassword" type="password" required class="form-control" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;" />
    </div>
    <p class="hint" style="font-size:12px;color:#555;">Minimum 8 caractères recommandés. Utilisez une combinaison de lettres et chiffres.</p>
    <button type="submit" class="MfButton" style="width:100%;padding:12px;background:#004D61;color:white;border:none;border-radius:4px;">Réinitialiser</button>
  </form>
</div>
{% endblock %}
