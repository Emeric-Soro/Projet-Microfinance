{% extends 'auth/auth.html.twig' %}

{% block title %}Vérification OTP - MicroFin{% endblock %}

{% block auth_content %}
<div class="MfFormCard" style="max-width:420px;margin:0 auto;padding:20px;border-radius:8px;box-shadow:0 2px 12px rgba(0,0,0,0.05);background:#fff;">
  <h2 style="font-family: 'Manrope', sans-serif;margin-bottom:8px;">Vérification à deux facteurs</h2>
  <p style="color:#555;margin-top:0;margin-bottom:16px;font-family: 'Inter', sans-serif;">Saisissez le code OTP envoyé</p>
  <form method="post" action="{{ path('login_otp') }}">
    <input type="hidden" name="challenge" value="{{ app.session.get('otp_challenge') }}" />
    <div class="MfInput" style="margin-bottom:12px;">
      <label for="otp">OTP</label>
      <input id="otp" name="otp" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="6" required class="form-control" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:4px;" />
    </div>
    <button type="submit" class="MfButton" style="width:100%;padding:12px;background:#004D61;color:white;border:none;border-radius:4px;">Vérifier</button>
  </form>
  <div class="auth-links" style="margin-top:12px;text-align:right;">
    <a href="#" onclick="location.reload(); return false;">Renvoyer le code</a>
  </div>
</div>
{% endblock %}
