{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('auth') }}
{% endblock %}

{% block javascripts %}
{% endblock %}

{% block body %}
<div class="min-h-screen bg-surface flex flex-col justify-center items-center px-4 py-12">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="flex justify-center mb-4">
                <div class="w-16 h-16 bg-primary rounded-xl flex items-center justify-center">
                    <span class="text-white font-heading font-bold text-2xl">MF</span>
                </div>
            </div>
            <h1 class="font-heading text-2xl font-bold text-primary">MicroFin</h1>
            <p class="text-sm text-on-surface-variant mt-1">Système Bancaire Intégré</p>
        </div>

        <div class="bg-surface-white rounded-lg shadow-card border border-teal-100 p-6">
            {% include 'partials/_flash.html.twig' %}
            {% block auth_content %}{% endblock %}
        </div>

        <p class="text-center text-xs text-on-surface-variant mt-6">
            &copy; {{ 'now'|date('Y') }} MicroFin. Tous droits réservés.
        </p>
    </div>
</div>
{% endblock %}
