<div class="bg-gray-50 rounded-lg border border-gray-200 p-4 {{ class|default('') }}">
    {% if title is defined %}
        <h4 class="text-sm font-semibold text-on-surface mb-3">{{ title }}</h4>
    {% endif %}
    <dl class="divide-y divide-gray-200">
        {% for item in items %}
            <div class="flex justify-between py-2">
                <dt class="text-sm text-on-surface-variant">{{ item.label }}</dt>
                <dd class="text-sm font-medium text-on-surface">{{ item.value }}</dd>
            </div>
        {% endfor %}
    </dl>
</div>
