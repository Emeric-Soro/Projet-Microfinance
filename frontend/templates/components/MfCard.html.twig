<div class="bg-white rounded-lg shadow-card border border-teal-100 p-6 {{ class|default('') }}" {{ attributes|default('')|raw }}>
    {% if title is defined %}
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-heading font-semibold text-on-surface">{{ title }}</h3>
            {% if action is defined %}
                <a href="{{ action.url }}" class="text-sm font-medium text-primary hover:text-primary-600">{{ action.label }}</a>
            {% endif %}
        </div>
    {% endif %}
    {% block card_content %}{% endblock %}
</div>
