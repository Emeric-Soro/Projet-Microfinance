<div class="overflow-x-auto">
    <table class="mf-table">
        {% if headers is defined %}
        <thead>
            <tr>
                {% if selectable is defined and selectable %}
                    <th class="w-10"><input type="checkbox" class="rounded border-gray-300"></th>
                {% endif %}
                {% for header in headers %}
                    <th class="{% if header.sortable is defined and header.sortable %}cursor-pointer hover:text-primary{% endif %}" 
                        {% if header.sortable is defined and header.sortable %}data-action="click->table-sort#sort" data-column="{{ header.key }}"{% endif %}>
                        <div class="flex items-center gap-1">
                            {{ header.label }}
                            {% if header.sortable is defined and header.sortable %}
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
                            {% endif %}
                        </div>
                    </th>
                {% endfor %}
                {% if actions is defined and actions %}
                    <th class="w-24 text-right">Actions</th>
                {% endif %}
            </tr>
        </thead>
        {% endif %}
        <tbody>
            {% if rows is defined and rows is not empty %}
                {% for row in rows %}
                {% set current_row_class = row.row_class|default(row_class|default('')) %}
                <tr{% if current_row_class is not empty %} class="{{ current_row_class }}"{% endif %}>
                    {% if selectable is defined and selectable %}
                        <td><input type="checkbox" class="rounded border-gray-300"></td>
                    {% endif %}
                    {% for header in headers %}
                        <td>{{ row[header.key]|default('-') }}</td>
                    {% endfor %}
                    {% if actions is defined and actions %}
                        <td class="text-right">
                            <div class="flex items-center justify-end gap-2">
                                {% for action in actions %}
                                    {% if action.url is defined %}
                                        <a href="{{ action.url }}" class="text-sm text-primary hover:text-primary-600" title="{{ action.label|default('Action') }}">
                                            {% if action.icon is defined and action.icon %}
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ action.icon }}"/></svg>
                                            {% else %}
                                                {{ action.label|default('Action') }}
                                            {% endif %}
                                        </a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </td>
                    {% endif %}
                </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="{{ (headers|length) + ((selectable is defined and selectable) ? 1 : 0) + ((actions is defined and actions) ? 1 : 0) }}" class="text-center py-8">
                        {% include 'partials/_empty_state.html.twig' with {title: empty_title|default('Aucune donnée'), message: empty_message|default('Aucun enregistrement trouvé')} %}
                    </td>
                </tr>
            {% endif %}
        </tbody>
    </table>
</div>
