<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-{{ cols|default(4) }} gap-4 {{ class|default('') }}">
    {% for stat in stats %}
    <div class="bg-white rounded-lg shadow-card border border-teal-100 p-5">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm font-medium text-on-surface-variant">{{ stat.label }}</p>
                <p class="text-2xl font-heading font-bold text-on-surface mt-1">{{ stat.value }}</p>
            </div>
            {% if stat.icon is defined %}
                <div class="w-10 h-10 rounded-lg {{ stat.icon_bg|default('bg-primary-50') }} flex items-center justify-center">
                    <svg class="w-5 h-5 {{ stat.icon_color|default('text-primary') }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ stat.icon }}"/>
                    </svg>
                </div>
            {% endif %}
        </div>
        {% if stat.variation is defined %}
        <div class="mt-2 flex items-center gap-1 text-xs {{ stat.variation > 0 ? 'text-green-600' : 'text-red-600' }}">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ stat.variation > 0 ? 'M5 10l7-7m0 0l7 7m-7-7v18' : 'M19 14l-7 7m0 0l-7-7m7 7V3' }}"/>
            </svg>
            <span>{{ stat.variation|abs }}% vs période précédente</span>
        </div>
        {% endif %}
        {% if stat.subtext is defined %}
            <p class="mt-1 text-xs text-on-surface-variant">{{ stat.subtext }}</p>
        {% endif %}
    </div>
    {% endfor %}
</div>
