<div class="bg-white rounded-lg shadow-card border border-teal-100 p-6 {{ class|default('') }}">
    {% if title is defined %}
        <div class="mb-6">
            <h3 class="text-lg font-heading font-semibold text-on-surface">{{ title }}</h3>
            {% if description is defined %}
                <p class="text-sm text-on-surface-variant mt-1">{{ description }}</p>
            {% endif %}
        </div>
    {% endif %}
    {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}
        {% if form_errors(form) %}
            <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-800">
                {{ form_errors(form) }}
            </div>
        {% endif %}
        {% block form_fields %}{% endblock %}
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-gray-100">
            {% if cancel_url is defined %}
                <a href="{{ cancel_url }}" class="mf-btn-secondary">{{ cancel_label|default('Annuler') }}</a>
            {% endif %}
            <button type="submit" class="mf-btn-primary">{{ submit_label|default('Enregistrer') }}</button>
        </div>
    {{ form_end(form) }}
</div>
