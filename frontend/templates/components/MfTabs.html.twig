<div data-controller="tabs" data-tabs-active-tab="{{ active_tab|default('') }}">
    <div class="border-b border-gray-200 mb-6">
        <nav class="flex space-x-6" role="tablist">
            {% for tab in tabs %}
                <button class="pb-3 text-sm font-medium border-b-2 transition-colors {{ loop.first ? 'border-primary text-primary' : 'border-transparent text-on-surface-variant hover:text-on-surface' }}"
                        data-action="click->tabs#select"
                        data-tabs-target="{{ tab.key }}">
                    {{ tab.label }}
                    {% if tab.count is defined and tab.count > 0 %}
                        <span class="ml-1.5 px-2 py-0.5 text-xs rounded-full {{ loop.first ? 'bg-primary-50 text-primary' : 'bg-gray-100 text-on-surface-variant' }}">{{ tab.count }}</span>
                    {% endif %}
                </button>
            {% endfor %}
        </nav>
    </div>
    {% block tabs_content %}{% endblock %}
</div>
