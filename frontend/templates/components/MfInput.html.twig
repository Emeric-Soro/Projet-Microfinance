<div class="{{ class|default('') }}">
    {% if label is defined %}
        <label for="{{ id|default(name) }}" class="block text-sm font-medium text-on-surface mb-1">
            {{ label }}
            {% if required is defined and required %}<span class="text-red-500">*</span>{% endif %}
        </label>
    {% endif %}
    <input type="{{ type|default('text') }}" 
           id="{{ id|default(name) }}" 
           name="{{ name|default('') }}"
           value="{{ value|default('') }}"
           placeholder="{{ placeholder|default('') }}"
           class="mf-input {{ error|default(false) ? 'border-red-400 focus:border-red-400 focus:ring-red-200' : '' }}"
           {% if required is defined and required %}required{% endif %}
           {% if disabled is defined and disabled %}disabled{% endif %}>
    {% if error is defined %}
        <p class="mt-1 text-xs text-red-600">{{ error }}</p>
    {% endif %}
    {% if help is defined %}
        <p class="mt-1 text-xs text-on-surface-variant">{{ help }}</p>
    {% endif %}
</div>
