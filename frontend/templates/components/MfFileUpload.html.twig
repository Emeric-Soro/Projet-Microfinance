<div class="{{ class|default('') }}" data-controller="document-upload">
    {% if label is defined %}
        <label class="block text-sm font-medium text-on-surface mb-1">
            {{ label }}
            {% if required is defined and required %}<span class="text-red-500">*</span>{% endif %}
        </label>
    {% endif %}
    <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-primary transition-colors cursor-pointer"
         data-action="click->document-upload#openFileDialog dragover->document-upload#dragOver dragleave->document-upload#dragLeave drop->document-upload#drop">
        <div class="text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48"><path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <p class="mt-2 text-sm text-on-surface-variant">
                <span class="font-medium text-primary hover:text-primary-600">Cliquez pour uploader</span> ou glissez-déposez
            </p>
            <p class="text-xs text-on-surface-variant mt-1">PNG, JPG, PDF jusqu'à 10MB</p>
        </div>
    </div>
    <input type="file" name="{{ name|default('file') }}" class="hidden" data-document-upload-target="input" accept="{{ accept|default('.jpg,.jpeg,.png,.pdf')}}">
    {% if error is defined %}
        <p class="mt-1 text-xs text-red-600">{{ error }}</p>
    {% endif %}
</div>
