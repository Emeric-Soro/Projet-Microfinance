{% extends 'backoffice.html.twig' %}

{% block title %}Enquête alerte #{{ alerte.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Alerte #' ~ alerte.id } %}
        {% block card_content %}
            {% embed 'components/MfDetailRow.html.twig' with { items: [
                { label: 'Type', value: alerte.type|default('—') },
                { label: 'Client', value: alerte.client|default('—') },
                { label: 'Date', value: alerte.date|default('—') },
                { label: 'Niveau de risque', value: alerte.niveau_risque|default('—') },
                { label: 'Statut', value: alerte.statut|default('—') },
            ] } %}{% endembed %}
        {% endblock %}
    {% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Enquête' } %}
        {% block card_content %}
            <form method="post" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Résultat de l'enquête</label>
                    <textarea name="investigation[resultat]" rows="4" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>{{ investigation.resultat|default('') }}</textarea>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Conclusion</label>
                        <select name="investigation[conclusion]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                            <option value="justifie" {{ investigation.conclusion == 'justifie' ? 'selected' : '' }}>Justifié</option>
                            <option value="non_justifie" {{ investigation.conclusion == 'non_justifie' ? 'selected' : '' }}>Non justifié</option>
                            <option value="a_suivre" {{ investigation.conclusion == 'a_suivre' ? 'selected' : '' }}>À suivre</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Date de clôture</label>
                        <input type="date" name="investigation[date_cloture]" value="{{ investigation.date_cloture|default('now'|date('Y-m-d')) }}" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                    </div>
                </div>
                <div class="flex justify-end gap-3">
                    <a href="{{ path('conformite_alerts') }}" class="mf-btn-secondary">Retour</a>
                    <button type="submit" class="mf-btn-primary">Enregistrer l'enquête</button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
