{% extends 'backoffice.html.twig' %}

{% block title %}Alertes conformité - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Alertes de conformité' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'id', label: 'N°' },
                    { key: 'date', label: 'Date' },
                    { key: 'type', label: 'Type' },
                    { key: 'client', label: 'Client' },
                    { key: 'niveau_risque', label: 'Niveau de risque' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: alertes.liste|default([]),
                actions: [
                    { label: 'Enquêter', url: row => path('conformite_investigation', { id: row.id }), icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
                    { label: 'Détails', url: row => '#', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' },
                ],
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
