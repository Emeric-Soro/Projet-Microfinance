{% extends 'backoffice.html.twig' %}

{% block title %}Contrôle interne - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Nouveau contrôle interne' } %}
        {% block card_content %}
            <form method="post" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Domaine de contrôle</label>
                        <select name="controle[domaine]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                            <option value="lcb_ft">LCB-FT</option>
                            <option value="kyc">KYC</option>
                            <option value="conformite_operationnelle">Conformité opérationnelle</option>
                            <option value="protection_client">Protection du client</option>
                            <option value="gouvernance">Gouvernance</option>
                            <option value="ethique">Éthique et déontologie</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Période</label>
                        <input type="month" name="controle[periode]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Objet du contrôle</label>
                    <textarea name="controle[objet]" rows="3" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Résultats / Observations</label>
                    <textarea name="controle[resultats]" rows="4" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary"></textarea>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Note de conformité</label>
                        <select name="controle[note]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                            <option value="A">A - Conforme</option>
                            <option value="B">B - Partiellement conforme</option>
                            <option value="C">C - Non conforme</option>
                            <option value="D">D - Critique</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Contrôleur</label>
                        <input type="text" name="controle[controleur]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                    </div>
                </div>
                <div class="flex justify-end">
                    <button type="submit" class="mf-btn-primary">Enregistrer le contrôle</button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Historique des contrôles' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'date', label: 'Date' },
                    { key: 'domaine', label: 'Domaine' },
                    { key: 'objet', label: 'Objet' },
                    { key: 'note', label: 'Note' },
                    { key: 'controleur', label: 'Contrôleur' },
                ],
                rows: controles.liste|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
