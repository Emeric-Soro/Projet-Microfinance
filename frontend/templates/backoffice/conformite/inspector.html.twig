{% extends 'backoffice.html.twig' %}

{% block title %}Inspection conformité - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Rapport d\'inspection' } %}
        {% block card_content %}
            <form method="post" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Type d'inspection</label>
                        <select name="inspection[type]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                            <option value="interne">Inspection interne</option>
                            <option value="externe">Inspection externe</option>
                            <option value="regulateur">Inspection régulateur</option>
                            <option value="audit">Audit</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Date d'inspection</label>
                        <input type="date" name="inspection[date]" value="{{ 'now'|date('Y-m-d') }}" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Inspecteur / Organisme</label>
                    <input type="text" name="inspection[inspecteur]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required placeholder="Nom de l'inspecteur ou de l'organisme">
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Objet de l'inspection</label>
                    <textarea name="inspection[objet]" rows="3" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Conclusions / Observations</label>
                    <textarea name="inspection[conclusions]" rows="4" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary"></textarea>
                </div>
                <div class="flex justify-end">
                    <button type="submit" class="mf-btn-primary">Enregistrer le rapport</button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Historique des inspections' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'date', label: 'Date' },
                    { key: 'type', label: 'Type' },
                    { key: 'inspecteur', label: 'Inspecteur' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: inspections.liste|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
