{% extends 'backoffice.html.twig' %}

{% block title %}Correspondants bancaires - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Enregistrer un correspondant' } %}
        {% block card_content %}
            <form method="post" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Nom de la banque</label>
                        <input type="text" name="correspondant[banque]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Pays</label>
                        <input type="text" name="correspondant[pays]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Code SWIFT/BIC</label>
                        <input type="text" name="correspondant[swift]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Niveau de risque</label>
                        <select name="correspondant[niveau_risque]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                            <option value="faible">Faible</option>
                            <option value="moyen" selected>Moyen</option>
                            <option value="eleve">Élevé</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Notes / Évaluation</label>
                    <textarea name="correspondant[notes]" rows="3" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary"></textarea>
                </div>
                <div class="flex justify-end">
                    <button type="submit" class="mf-btn-primary">Enregistrer</button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Liste des correspondants' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'banque', label: 'Banque' },
                    { key: 'pays', label: 'Pays' },
                    { key: 'swift', label: 'SWIFT/BIC' },
                    { key: 'niveau_risque', label: 'Niveau de risque' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: correspondants.liste|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
