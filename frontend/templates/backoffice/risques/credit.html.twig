{% extends 'backoffice.html.twig' %}

{% block title %}Risque de Crédit - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfStatsGrid.html.twig' with { stats: [
        { label: 'Encours Total', value: data.encours|default('—'), icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', icon_bg: 'bg-primary-50', icon_color: 'text-primary' },
        { label: 'IMP (< 30j)', value: data.imp_30|default('—'), icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-yellow-50', icon_color: 'text-yellow-600' },
        { label: 'Créances Douteuses', value: data.douteux|default('—'), icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
        { label: 'Provision', value: data.provision|default('—'), icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-blue-50', icon_color: 'text-blue-600' },
    ] } %}{% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Portefeuille Crédit par Catégorie' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'categorie', label: 'Catégorie' },
                    { key: 'encours', label: 'Encours' },
                    { key: 'nombre', label: 'Nombre' },
                    { key: 'taux_impaye', label: 'Taux Impayé' },
                    { key: 'provision', label: 'Provision' },
                ],
                rows: data.portefeuille|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Indicateurs de Risque Crédit' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'indicateur', label: 'Indicateur' },
                    { key: 'valeur', label: 'Valeur' },
                    { key: 'cible', label: 'Cible' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: data.indicateurs|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
