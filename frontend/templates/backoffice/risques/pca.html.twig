{% extends 'backoffice.html.twig' %}

{% block title %}Plan de Continuité d'Activité - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfStatsGrid.html.twig' with { cols: 3, stats: [
        { label: 'Processus Critiques', value: data.processus_critiques|default('—'), icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-primary-50', icon_color: 'text-primary' },
        { label: 'Tests Effectués', value: data.tests|default('—'), icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
        { label: 'Dernier Test', value: data.dernier_test|default('—'), icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-blue-50', icon_color: 'text-blue-600' },
    ] } %}{% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Processus Critiques' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'processus', label: 'Processus' },
                    { key: 'rto', label: 'RTO' },
                    { key: 'rpo', label: 'RPO' },
                    { key: 'priorite', label: 'Priorité' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: data.processus|default([]),
                actions: [{ label: 'Détails', url: row => '#', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' }],
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
