{% extends 'backoffice.html.twig' %}

{% block title %}Cartographie des Risques - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfStatsGrid.html.twig' with { stats: [
        { label: 'Risques Identifiés', value: data.total|default('—'), icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-primary-50', icon_color: 'text-primary' },
        { label: 'Risques Critiques', value: data.critiques|default('—'), icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
        { label: 'Risques Élevés', value:data.eleves|default('—'), icon: 'M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-orange-50', icon_color: 'text-orange-600' },
        { label: 'Risques Maîtrisés', value: data.maitrises|default('—'), icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
    ] } %}{% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Matrice des Risques' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'risque', label: 'Risque' },
                    { key: 'categorie', label: 'Catégorie' },
                    { key: 'probabilite', label: 'Probabilité' },
                    { key: 'impact', label: 'Impact' },
                    { key: 'niveau', label: 'Niveau' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: data.matrice|default([]),
                actions: [{ label: 'Voir', url: row => '#', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' }],
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
