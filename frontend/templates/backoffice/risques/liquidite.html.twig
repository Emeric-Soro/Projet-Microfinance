{% extends 'backoffice.html.twig' %}

{% block title %}Risque de Liquidité - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfStatsGrid.html.twig' with { stats: [
        { label: 'Ratio de Liquidité', value: data.ratio_liquidite|default('—'), icon: 'M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z', icon_bg: 'bg-primary-50', icon_color: 'text-primary' },
        { label: 'Disponibilités', value: data.disponibilites|default('—'), icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
        { label: 'Besoin de Liquidité', value: data.besoin|default('—'), icon: 'M13 17h8m0 0V9m0 8l-8-8-4 4-6-6', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
        { label: 'Gap de Liquidité', value: data.gap|default('—'), icon: 'M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z', icon_bg: 'bg-blue-50', icon_color: 'text-blue-600' },
    ] } %}{% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Échéances de Liquidité' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'periode', label: 'Période' },
                    { key: 'entrees', label: 'Entrées' },
                    { key: 'sorties', label: 'Sorties' },
                    { key: 'gap', label: 'Gap' },
                    { key: 'cumul', label: 'Cumul' },
                ],
                rows: data.echeances|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
