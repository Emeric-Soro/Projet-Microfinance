{% extends 'backoffice.html.twig' %}

{% block title %}Rejeter validation #{{ validation.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Rejeter la validation #' ~ validation.id } %}
        {% block card_content %}
            <form method="post" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Motif du rejet <span class="text-red-500">*</span></label>
                    <textarea name="motif" rows="4" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required placeholder="Indiquez le motif du rejet..."></textarea>
                </div>
                <div class="flex justify-end gap-3">
                    <a href="{{ path('validation_detail', { id: validation.id }) }}" class="mf-btn-secondary">Annuler</a>
                    <button type="submit" class="mf-btn-danger">Confirmer le rejet</button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
