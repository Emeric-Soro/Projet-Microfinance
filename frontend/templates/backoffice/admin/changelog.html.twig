{% extends 'backoffice.html.twig' %}

{% block title %}Changelog - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Administration', url: path('admin_changelog') }, { label: 'Changelog' }] %}

<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Changelog</h1>
</div>

<div class="space-y-6">
    {% for entry in items %}
    {% embed 'components/MfCard.html.twig' with { title: 'v' ~ entry.version ~ ' - ' ~ entry.date } %}
        {% block card_content %}
            {% if entry.type is defined and entry.type %}
            <div class="mb-2">{% include 'components/MfStatusBadge.html.twig' with { status: entry.type } %}</div>
            {% endif %}
            <div class="text-sm">{{ entry.description ?? '' }}</div>
            {% if entry.modifications is defined and entry.modifications is not empty %}
            <ul class="mt-3 space-y-1">
                {% for mod in entry.modifications %}
                <li class="text-sm text-on-surface-variant">- {{ mod }}</li>
                {% endfor %}
            </ul>
            {% endif %}
        {% endblock %}
    {% endembed %}
    {% else %}
    <p class="text-on-surface-variant">Aucun changelog disponible.</p>
    {% endfor %}
</div>
{% endblock %}
