{% extends 'backoffice.html.twig' %}

{% block title %}Sauvegardes - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Administration', url: path('admin_sauvegardes') }, { label: 'Sauvegardes' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Sauvegardes</h1>
    <a href="{{ path('admin_sauvegardes_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Lancer une sauvegarde</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des sauvegardes' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'date', label: 'Date' },
                { key: 'type', label: 'Type' },
                { key: 'taille', label: 'Taille' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'admin_sauvegardes', query: {} } %}

{% elseif mode == 'restore' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Restaurer sauvegarde</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Confirmation' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('admin_sauvegardes_restore', { id: item.id ?? 0 }) }}">
        <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg mb-4">
            <p class="text-yellow-800 font-medium">Attention : La restauration remplacera toutes les données actuelles.</p>
        </div>
        <p>Sauvegarde du {{ item.date ?? '—' }} ({{ item.type ?? '—' }})</p>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">Confirmer la restauration</button>
            <a href="{{ path('admin_sauvegardes') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
