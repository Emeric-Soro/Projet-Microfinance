{% extends 'backoffice.html.twig' %}

{% block title %}Modules - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Administration', url: path('admin_modules') }, { label: 'Modules' }] %}

{% if mode == 'list' %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Modules</h1>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des modules' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'nom', label: 'Nom' },
                { key: 'description', label: 'Description' },
                { key: 'version', label: 'Version' },
                { key: 'actif', label: 'Actif' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}

{% elseif mode == 'configure' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Configurer - {{ item.nom ?? '' }}</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Configuration' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('admin_modules_configure', { id: item.id ?? 0 }) }}">
        <div class="grid grid-cols-1 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'config', label: 'Configuration (JSON)', value: item.config is defined ? item.config|json_encode : '' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('admin_modules') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
