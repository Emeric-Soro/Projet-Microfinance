{% extends 'backoffice.html.twig' %}

{% block title %}Utilisateurs - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Administration', url: path('admin_utilisateurs') }, { label: 'Utilisateurs' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Utilisateurs</h1>
    <a href="{{ path('admin_utilisateurs_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouvel utilisateur</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des utilisateurs' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'username', label: 'Identifiant' },
                { key: 'nom', label: 'Nom' },
                { key: 'email', label: 'Email' },
                { key: 'role', label: 'Rôle' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'admin_utilisateurs', query: {} } %}

{% elseif mode == 'create' or mode == 'edit' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">{{ mode == 'create' ? 'Nouvel utilisateur' : 'Modifier utilisateur' }}</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: mode == 'create' ? 'Création' : 'Édition' } %}
    {% block form_fields %}
    <form method="post" action="{{ path(mode == 'create' ? 'admin_utilisateurs_create' : 'admin_utilisateurs_edit', { id: item.id ?? 0 }) }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'username', label: 'Identifiant', value: item.username ?? '', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'nom', label: 'Nom', value: item.nom ?? '', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'email', label: 'Email', value: item.email ?? '', type: 'email' } %}
            {% include 'components/MfSelect.html.twig' with { name: 'role', label: 'Rôle', value: item.role ?? '', options: [
                { value: 'ADMIN', label: 'Administrateur' }, { value: 'SUPERVISEUR', label: 'Superviseur' },
                { value: 'AGENT', label: 'Agent' }, { value: 'CAISSIER', label: 'Caissier' }
            ]} %}
            {% if mode == 'create' %}
            {% include 'components/MfInput.html.twig' with { name: 'password', label: 'Mot de passe', type: 'password', required: true } %}
            {% endif %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('admin_utilisateurs') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}

{% elseif mode == 'show' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">{{ item.nom ?? 'Utilisateur' }}</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Détails' } %}
    {% block card_content %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><strong>Identifiant:</strong> {{ item.username ?? '—' }}</div>
        <div><strong>Nom:</strong> {{ item.nom ?? '—' }}</div>
        <div><strong>Email:</strong> {{ item.email ?? '—' }}</div>
        <div><strong>Rôle:</strong> {{ item.role ?? '—' }}</div>
        <div><strong>Statut:</strong> {% include 'components/MfStatusBadge.html.twig' with { status: item.statut ?? 'ACTIF' } %}</div>
        <div><strong>Dernière connexion:</strong> {{ item.derniereConnexion ?? '—' }}</div>
    </div>
    <div class="mt-6 flex gap-3">
        <a href="{{ path('admin_utilisateurs_edit', { id: item.id }) }}" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Modifier</a>
        <a href="{{ path('admin_utilisateurs_suspend', { id: item.id }) }}" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors" onclick="return confirm('Suspendre cet utilisateur ?')">Suspendre</a>
        <a href="{{ path('admin_utilisateurs') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a>
    </div>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
