{% extends 'backoffice.html.twig' %}

{% block title %}Tâches planifiées - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Administration', url: path('admin_taches_planifiees') }, { label: 'Tâches planifiées' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Tâches planifiées</h1>
    <a href="{{ path('admin_taches_planifiees_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouvelle tâche</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des tâches' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'nom', label: 'Nom' },
                { key: 'cron', label: 'Expression CRON' },
                { key: 'derniereExecution', label: 'Dernière exéc.' },
                { key: 'prochaineExecution', label: 'Prochaine exéc.' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'admin_taches_planifiees', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouvelle tâche planifiée</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Création' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('admin_taches_planifiees_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'nom', label: 'Nom', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'cron', label: 'Expression CRON', required: true, placeholder: 'ex: 0 2 * * *' } %}
            {% include 'components/MfInput.html.twig' with { name: 'commande', label: 'Commande', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'description', label: 'Description' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Créer</button>
            <a href="{{ path('admin_taches_planifiees') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
