{% extends 'backoffice.html.twig' %}

{% block title %}Taux épargne - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Taux d'épargne</h1>
    <p class="text-sm text-on-surface-variant mt-1">Gestion des taux des produits d'épargne</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
        {% embed component('MfFormCard') with { title: 'Nouveau taux', description: 'Définir un nouveau taux pour un produit' } %}
            {% block form_fields %}
                <div class="space-y-4">
                    {% include component('MfSelect') with { name: 'produit', label: 'Produit', required: true, options: products|map(p => { value: p.id, label: p.libelle }) } %}
                    {% include component('MfInput') with { name: 'taux', label: 'Taux annuel (%)', required: true, type: 'number', step: '0.01' } %}
                    {% include component('MfDatePicker') with { name: 'date_effet', label: 'Date d\'effet', required: true, value: 'now'|date('Y-m-d') } %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>

    <div class="lg:col-span-2">
        {% embed component('MfDataTable') with {
            headers: [
                { key: 'produit', label: 'Produit', sortable: true },
                { key: 'taux', label: 'Taux (%)', sortable: true },
                { key: 'dateEffet', label: 'Date d\'effet', sortable: true },
                { key: 'statut', label: 'Statut' },
            ],
            rows: rates,
            empty_title: 'Aucun taux',
            empty_message: 'Aucun taux défini pour le moment.',
        } %}
            {% block card_content %}
                {{ parent() }}
            {% endblock %}
        {% endembed %}
    </div>
</div>
{% endblock %}
