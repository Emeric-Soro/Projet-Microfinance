{% extends 'backoffice.html.twig' %}

{% block title %}Simulation épargne - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Simulation d'épargne</h1>
    <p class="text-sm text-on-surface-variant mt-1">Simulez la croissance de votre épargne</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
        {% embed component('MfFormCard') with { title: 'Paramètres', description: 'Saisissez les hypothèses' } %}
            {% block form_fields %}
                <div class="space-y-4">
                    {% include component('MfMoneyInput') with { name: 'montant_initial', label: 'Montant initial' } %}
                    {% include component('MfMoneyInput') with { name: 'versement_mensuel', label: 'Versement mensuel' } %}
                    {% include component('MfInput') with { name: 'duree_mois', label: 'Durée (mois)', type: 'number', required: true, value: '12' } %}
                    {% include component('MfInput') with { name: 'taux_annuel', label: 'Taux annuel (%)', type: 'number', step: '0.01', required: true, value: '5.0' } %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>

    <div class="lg:col-span-2">
        {% if result is defined and result is not empty %}
            {% embed component('MfCard') with { title: 'Résultat de la simulation' } %}
                {% block card_content %}
                    {% embed component('MfStatsGrid') with { cols: 3, stats: [
                        { label: 'Montant total épargné', value: result.totalVerse|default(0)|montant, icon: 'M12 4v16m8-8H4', icon_bg: 'bg-blue-50', icon_color: 'text-blue-600' },
                        { label: 'Intérêts générés', value: result.interets|default(0)|montant, icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
                        { label: 'Solde final', value: result.soldeFinal|default(0)|montant, icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-teal-50', icon_color: 'text-teal-600' },
                    ]} %}
                        {% block card_content %}
                            {{ parent() }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}
        {% else %}
            {% include 'partials/_empty_state.html.twig' with {
                title: 'Aucune simulation',
                message: 'Remplissez les paramètres et lancez la simulation.',
            } %}
        {% endif %}
    </div>
</div>
{% endblock %}
