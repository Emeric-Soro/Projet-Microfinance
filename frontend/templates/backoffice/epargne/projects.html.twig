{% extends 'backoffice.html.twig' %}

{% block title %}Projets épargne - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Projets d'épargne</h1>
    <p class="text-sm text-on-surface-variant mt-1">Gestion des projets d'épargne (épargne projet)</p>
</div>

{% include component('MfTabs') with { tabs: [
    { key: 'list', label: 'Projets', count: projects|length },
    { key: 'create', label: 'Nouveau projet' },
] } %}
{% block tabs_content %}
    <div data-tabs-target="list">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for project in projects %}
                <div class="bg-white rounded-lg shadow-card border border-teal-100 p-5">
                    <div class="flex items-start justify-between mb-3">
                        <h3 class="font-heading font-semibold text-on-surface">{{ project.nom }}</h3>
                        {% include component('MfStatusBadge') with { status: project.statut|default('ACTIF') } %}
                    </div>
                    {% include component('MfProgressBar') with { label: 'Progression', value: project.pourcentage|default(0) } %}
                    <div class="mt-3 space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant">Objectif</span>
                            <span class="font-medium">{{ project.montantObjectif|montant }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant">Épargné</span>
                            <span class="font-medium">{{ project.montantEpargne|default(0)|montant }}</span>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-span-full">
                    {% include 'partials/_empty_state.html.twig' with {
                        title: 'Aucun projet',
                        message: 'Aucun projet d\'épargne enregistré.',
                    } %}
                </div>
            {% endfor %}
        </div>
    </div>

    <div data-tabs-target="create" class="hidden mt-6">
        <div class="max-w-2xl">
            {% embed component('MfFormCard') with { title: 'Nouveau projet', description: 'Définissez les objectifs' } %}
                {% block form_fields %}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {% include component('MfInput') with { name: 'nom', label: 'Nom du projet', required: true } %}
                        {% include component('MfInput') with { name: 'client', label: 'Client', required: true } %}
                        {% include component('MfMoneyInput') with { name: 'montant_objectif', label: 'Montant objectif', required: true } %}
                        {% include component('MfDatePicker') with { name: 'date_fin_prevue', label: 'Date fin prévue' } %}
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    </div>
{% endblock %}
{% endblock %}
