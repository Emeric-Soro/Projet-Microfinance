{% extends 'backoffice.html.twig' %}

{% block title %}Inventaire - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% if create_mode is defined %}
        <div class="max-w-2xl">
            {% embed 'components/MfFormCard.html.twig' with { title: 'Nouvel inventaire', description: 'Saisissez les informations de l\'inventaire' } %}
                {% block form_fields %}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Agence</label>
                            <select name="agence_id" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                                <option value="">Sélectionner</option>
                                {% for a in agences %}
                                    <option value="{{ a.id }}">{{ a.libelle }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Date inventaire</label>
                            <input type="date" name="dateInventaire" value="{{ 'now'|date('Y-m-d') }}" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Type</label>
                            <select name="type" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                                <option value="CAISSE">Caisse</option>
                                <option value="STOCK">Stock</option>
                                <option value="IMMOBILISATION">Immobilisation</option>
                                <option value="COMPLET">Complet</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Agent recenseur</label>
                            <input type="text" name="agentRecenseur" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Observations</label>
                        <textarea name="observations" rows="3" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary"></textarea>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    {% endif %}

    {% embed 'components/MfCard.html.twig' with { title: 'Inventaires' } %}
        {% block card_content %}
            {% include 'partials/_table_toolbar.html.twig' with {
                search_placeholder: 'Rechercher un inventaire...',
                filters: [
                    { label: 'Agence', options: agences|map(a => { value: a.id, label: a.libelle }) },
                ],
                action_button: { url: path('organisation_inventaire_create'), label: 'Nouvel inventaire' }
            } %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'date', label: 'Date', sortable: true },
                    { key: 'agence', label: 'Agence' },
                    { key: 'type', label: 'Type' },
                    { key: 'agent', label: 'Agent' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: inventaires,
                actions: [
                    { label: 'Valider', url: (row) => path('organisation_inventaire_validate', { id: row.id }), icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
                ],
            } %}{% endembed %}
            {% include 'partials/_pagination.html.twig' with {
                route: 'organisation_inventaire',
                total_pages: total_pages,
                total_items: total_items,
                current_page: current_page,
                page_size: page_size
            } %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
