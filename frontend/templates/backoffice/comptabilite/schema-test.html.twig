{% extends 'backoffice.html.twig' %}

{% block title %}Test de schéma - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-heading font-bold text-on-surface">Test de schéma comptable</h1>
        <p class="text-sm text-on-surface-variant mt-1">Simuler l'exécution d'un schéma comptable</p>
    </div>
</div>

{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="mf-card p-6">
        <form method="post" action="{{ path('comptabilite_schema_test') }}" class="space-y-4">
            <div>
                <label class="mf-label">Schéma</label>
                <select name="schema_id" class="mf-input" required>
                    <option value="">Sélectionner</option>
                    {% for schema in schemas %}
                        <option value="{{ schema.id }}">{{ schema.code }} - {{ schema.libelle }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="mf-label">Montant</label>
                <input type="number" step="0.01" name="montant" class="mf-input" placeholder="Montant à tester" required>
            </div>
            <button type="submit" class="mf-btn-primary">Exécuter le test</button>
        </form>
    </div>

    <div class="mf-card p-6">
        <h3 class="font-heading font-semibold text-lg text-on-surface mb-4">Résultat</h3>
        {% if result is not null %}
            <div class="space-y-4">
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                    <p class="text-green-800 font-medium">Test exécuté avec succès</p>
                </div>
                <table class="mf-table">
                    <thead>
                        <tr>
                            <th>Compte</th>
                            <th>Libellé</th>
                            <th class="text-right">Débit</th>
                            <th class="text-right">Crédit</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ligne in result.lignes|default([]) %}
                        <tr>
                            <td class="font-mono">{{ ligne.numero_compte }}</td>
                            <td>{{ ligne.libelle }}</td>
                            <td class="text-right font-mono">{{ ligne.debit|default(0)|number_format(0, ',', ' ') }}</td>
                            <td class="text-right font-mono">{{ ligne.credit|default(0)|number_format(0, ',', ' ') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="flex justify-between font-bold text-sm">
                    <span>Total:</span>
                    <span class="font-mono">{{ result.total|default(0)|number_format(0, ',', ' ') }}</span>
                </div>
            </div>
        {% else %}
            <div class="text-center py-12 text-on-surface-variant">
                <p>Sélectionnez un schéma et un montant pour voir le résultat.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
