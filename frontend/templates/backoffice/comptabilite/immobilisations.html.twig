{% extends 'backoffice.html.twig' %}

{% block title %}Immobilisations - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-heading font-bold text-on-surface">Immobilisations</h1>
        <p class="text-sm text-on-surface-variant mt-1">Gestion des immobilisations et amortissements</p>
    </div>
    <a href="#" class="mf-btn-primary" data-controller="modal" data-action="click->modal#open" data-modal-target="immobilisation-modal">
        <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nouvelle immobilisation
    </a>
</div>

{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="mf-card p-6 mb-6">
    <form method="get" action="" class="flex flex-wrap gap-4 items-end">
        <div class="w-64">
            <label class="mf-label">Catégorie</label>
            <select name="categorie" class="mf-input">
                <option value="">Toutes</option>
                {% for cat in categories %}
                    <option value="{{ cat.code }}" {{ categorie == cat.code ? 'selected' }}>{{ cat.libelle }}</option>
                {% endfor %}
            </select>
        </div>
        <button type="submit" class="mf-btn-primary">Filtrer</button>
        <a href="{{ path('comptabilite_fixed_assets') }}" class="mf-btn-secondary">Réinitialiser</a>
    </form>
</div>

<div class="mf-card overflow-hidden">
    <div class="overflow-x-auto">
        <table class="mf-table">
            <thead>
                <tr>
                    <th>Désignation</th>
                    <th>Catégorie</th>
                    <th class="text-right">Valeur acquisition</th>
                    <th>Date acquisition</th>
                    <th class="text-right">Amortissement</th>
                    <th class="text-right">Valeur nette</th>
                    <th>Durée</th>
                    <th class="text-center">Statut</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for immo in immobilisations %}
                <tr>
                    <td>{{ immo.designation }}</td>
                    <td><span class="text-xs bg-gray-100 px-2 py-0.5 rounded">{{ immo.categorie }}</span></td>
                    <td class="text-right font-mono">{{ immo.valeur_acquisition|number_format(0, ',', ' ') }}</td>
                    <td>{{ immo.date_acquisition|date('d/m/Y') }}</td>
                    <td class="text-right font-mono">{{ immo.amortissement_cumule|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="text-right font-mono font-medium">{{ immo.valeur_nette|default(0)|number_format(0, ',', ' ') }}</td>
                    <td>{{ immo.duree_amortissement }} ans</td>
                    <td class="text-center">{% include 'partials/_status_badge.html.twig' with {status: immo.statut} %}</td>
                    <td class="text-center">
                        <a href="#" class="mf-btn-icon" title="Détails">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="text-center py-8 text-on-surface-variant">Aucune immobilisation trouvée</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% include 'partials/_pagination.html.twig' with {route: 'comptabilite_fixed_assets', query: {categorie: categorie}} %}
</div>

{% include 'partials/_modal.html.twig' with {
    id: 'immobilisation-modal',
    title: 'Nouvelle immobilisation',
    content: '
    <form method="post" action="' ~ path('comptabilite_fixed_assets') ~ '" class="space-y-4">
        <div>
            <label class="mf-label">Désignation</label>
            <input type="text" name="designation" class="mf-input" placeholder="Désignation du bien" required>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="mf-label">Catégorie</label>
                <select name="categorie" class="mf-input" required>
                    <option value="">Sélectionner</option>
                    {% for cat in categories %}
                        <option value="' ~ cat.code ~ '">' ~ cat.libelle ~ '</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="mf-label">Date acquisition</label>
                <input type="date" name="date_acquisition" class="mf-input" required>
            </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="mf-label">Valeur d\'acquisition</label>
                <input type="number" step="0.01" name="valeur_acquisition" class="mf-input" placeholder="0" required>
            </div>
            <div>
                <label class="mf-label">Durée d\'amortissement (ans)</label>
                <input type="number" name="duree_amortissement" class="mf-input" placeholder="5" required>
            </div>
        </div>
        <div>
            <label class="mf-label">Mode d\'amortissement</label>
            <select name="mode_amortissement" class="mf-input" required>
                <option value="lineaire">Linéaire</option>
                <option value="degressif">Dégressif</option>
            </select>
        </div>
        <div class="flex justify-end gap-3 pt-4">
            <button type="button" class="mf-btn-secondary" data-action="click->confirm-modal#close">Annuler</button>
            <button type="submit" class="mf-btn-primary">Enregistrer</button>
        </div>
    </form>
'} %}
{% endblock %}
