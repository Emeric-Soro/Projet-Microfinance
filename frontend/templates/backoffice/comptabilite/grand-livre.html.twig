{% extends 'backoffice.html.twig' %}

{% block title %}Grand livre - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-heading font-bold text-on-surface">Grand livre</h1>
        <p class="text-sm text-on-surface-variant mt-1">Consultation du grand livre par compte</p>
    </div>
</div>

{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="mf-card p-6 mb-6">
    <form method="get" action="" class="flex flex-wrap gap-4 items-end">
        <div class="flex-1 min-w-[200px]">
            <label class="mf-label">Compte</label>
            <select name="compte_id" class="mf-input" required>
                <option value="">Sélectionner un compte</option>
                {% for account in accounts %}
                    <option value="{{ account.id }}" {{ compte_id == account.id ? 'selected' }}>{{ account.numero }} - {{ account.libelle }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="mf-label">Date début</label>
            <input type="date" name="date_debut" value="{{ date_debut }}" class="mf-input">
        </div>
        <div>
            <label class="mf-label">Date fin</label>
            <input type="date" name="date_fin" value="{{ date_fin }}" class="mf-input">
        </div>
        <button type="submit" class="mf-btn-primary">Consulter</button>
    </form>
</div>

{% if entries is not empty %}
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="mf-card p-4">
        <p class="text-sm text-on-surface-variant">Total débit</p>
        <p class="text-xl font-heading font-bold text-on-surface">{{ total_debit|number_format(0, ',', ' ') }}</p>
    </div>
    <div class="mf-card p-4">
        <p class="text-sm text-on-surface-variant">Total crédit</p>
        <p class="text-xl font-heading font-bold text-on-surface">{{ total_credit|number_format(0, ',', ' ') }}</p>
    </div>
    <div class="mf-card p-4">
        <p class="text-sm text-on-surface-variant">Solde</p>
        <p class="text-xl font-heading font-bold {{ solde >= 0 ? 'text-green-600' : 'text-red-600' }}">{{ solde|number_format(0, ',', ' ') }}</p>
    </div>
</div>

<div class="mf-card overflow-hidden">
    <div class="overflow-x-auto">
        <table class="mf-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Journal</th>
                    <th>Libellé</th>
                    <th>Pièce</th>
                    <th class="text-right">Débit</th>
                    <th class="text-right">Crédit</th>
                    <th class="text-right">Solde cumulé</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries %}
                <tr>
                    <td>{{ entry.date_operation|date('d/m/Y') }}</td>
                    <td class="font-mono">{{ entry.journal_code }}</td>
                    <td>{{ entry.libelle }}</td>
                    <td class="font-mono">{{ entry.piece_reference|default('-') }}</td>
                    <td class="text-right font-mono">{{ entry.debit|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="text-right font-mono">{{ entry.credit|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="text-right font-mono">{{ entry.solde_cumule|default(0)|number_format(0, ',', ' ') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% include 'partials/_pagination.html.twig' with {route: 'comptabilite_general_ledger', query: {compte_id: compte_id, date_debut: date_debut, date_fin: date_fin}} %}
</div>
{% elseif compte_id %}
<div class="mf-card p-8 text-center text-on-surface-variant">Aucune écriture trouvée pour la période sélectionnée.</div>
{% endif %}
{% endblock %}
