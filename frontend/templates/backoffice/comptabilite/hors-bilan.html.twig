{% extends 'backoffice.html.twig' %}

{% block title %}Hors bilan - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-heading font-bold text-on-surface">Engagements hors bilan</h1>
        <p class="text-sm text-on-surface-variant mt-1">Suivi des engagements hors bilan de l'institution</p>
    </div>
</div>

{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="mf-card p-4 border-l-4 border-blue-500">
        <p class="text-sm text-on-surface-variant">Cautionnements</p>
        <p class="text-xl font-heading font-bold text-blue-600">
            {{ engagements|reduce((carry, item) => carry + (item.type == 'CAUTIONNEMENT' ? item.montant : 0), 0)|number_format(0, ',', ' ') }}
        </p>
    </div>
    <div class="mf-card p-4 border-l-4 border-green-500">
        <p class="text-sm text-on-surface-variant">Garanties reçues</p>
        <p class="text-xl font-heading font-bold text-green-600">
            {{ engagements|reduce((carry, item) => carry + (item.type == 'GARANTIE' ? item.montant : 0), 0)|number_format(0, ',', ' ') }}
        </p>
    </div>
    <div class="mf-card p-4 border-l-4 border-purple-500">
        <p class="text-sm text-on-surface-variant">Autres engagements</p>
        <p class="text-xl font-heading font-bold text-purple-600">
            {{ engagements|reduce((carry, item) => carry + (item.type not in ['CAUTIONNEMENT', 'GARANTIE'] ? item.montant : 0), 0)|number_format(0, ',', ' ') }}
        </p>
    </div>
</div>

<div class="mf-card overflow-hidden">
    <div class="overflow-x-auto">
        <table class="mf-table">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Bénéficiaire</th>
                    <th>Objet</th>
                    <th class="text-right">Montant</th>
                    <th>Date début</th>
                    <th>Date échéance</th>
                    <th class="text-center">Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for engagement in engagements %}
                <tr>
                    <td><span class="text-xs font-medium bg-gray-100 px-2 py-0.5 rounded">{{ engagement.type }}</span></td>
                    <td>{{ engagement.beneficiaire|default('-') }}</td>
                    <td>{{ engagement.objet }}</td>
                    <td class="text-right font-mono">{{ engagement.montant|number_format(0, ',', ' ') }}</td>
                    <td>{{ engagement.date_debut|date('d/m/Y') }}</td>
                    <td>{{ engagement.date_echeance|date('d/m/Y') }}</td>
                    <td class="text-center">{% include 'partials/_status_badge.html.twig' with {status: engagement.statut} %}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center py-8 text-on-surface-variant">Aucun engagement hors bilan trouvé</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% include 'partials/_pagination.html.twig' with {route: 'comptabilite_off_balance'} %}
</div>
{% endblock %}
