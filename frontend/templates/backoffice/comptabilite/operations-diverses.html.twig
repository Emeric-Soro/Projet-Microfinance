{% extends 'backoffice.html.twig' %}

{% block title %}Opérations diverses - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-heading font-bold text-on-surface">Opérations diverses</h1>
        <p class="text-sm text-on-surface-variant mt-1">Saisie d'écritures comptables diverses</p>
    </div>
</div>

{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="mf-card p-6">
    <form method="post" action="{{ path('comptabilite_diverse') }}" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="mf-label">Date d'opération</label>
                <input type="date" name="date_operation" value="{{ 'now'|date('Y-m-d') }}" class="mf-input" required>
            </div>
            <div>
                <label class="mf-label">Journal</label>
                <select name="journal_code" class="mf-input" required>
                    <option value="">Sélectionner</option>
                    {% for journal in journaux %}
                        <option value="{{ journal.code }}">{{ journal.code }} - {{ journal.libelle }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="mf-label">Libellé</label>
                <input type="text" name="libelle" class="mf-input" placeholder="Libellé de l'opération" required>
            </div>
        </div>

        <div>
            <div class="flex items-center justify-between mb-2">
                <label class="mf-label mb-0">Lignes d'écriture</label>
                <button type="button" class="mf-btn-secondary text-sm" data-controller="dynamic-rows" data-action="dynamic-rows#add">
                    + Ajouter une ligne
                </button>
            </div>
            <div class="overflow-x-auto" data-controller="dynamic-rows">
                <table class="mf-table" data-dynamic-rows-target="container">
                    <thead>
                        <tr>
                            <th>Compte</th>
                            <th>Libellé ligne</th>
                            <th class="text-right">Débit</th>
                            <th class="text-right">Crédit</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr data-dynamic-rows-target="row">
                            <td>
                                <select name="lignes[0][compte_id]" class="mf-input text-sm" required>
                                    <option value="">-- Compte --</option>
                                    {% for account in accounts %}
                                        <option value="{{ account.id }}">{{ account.numero }} - {{ account.libelle }}</option>
                                    {% endfor %}
                                </select>
                            </td>
                            <td><input type="text" name="lignes[0][libelle]" class="mf-input text-sm" placeholder="Libellé"></td>
                            <td><input type="number" step="0.01" name="lignes[0][debit]" class="mf-input text-sm text-right" placeholder="0"></td>
                            <td><input type="number" step="0.01" name="lignes[0][credit]" class="mf-input text-sm text-right" placeholder="0"></td>
                            <td class="text-center">
                                <button type="button" class="mf-btn-icon text-red-500" data-action="dynamic-rows#remove">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
            <a href="{{ path('comptabilite_draft') }}" class="mf-btn-secondary">Annuler</a>
            <button type="submit" class="mf-btn-primary">Enregistrer</button>
        </div>
    </form>
</div>
{% endblock %}
