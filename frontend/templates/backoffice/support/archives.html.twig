{% extends 'backoffice.html.twig' %}

{% block title %}Archives - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support', url: path('support_archives') }, { label: 'Archives' }] %}

{% if mode == 'list' %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Archives</h1>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Recherche dans les archives' } %}
    {% block card_content %}
    <form method="get" action="{{ path('support_archives_search') }}" class="mb-4">
        <div class="flex gap-3">
            {% include 'components/MfInput.html.twig' with { name: 'q', label: 'Rechercher', placeholder: 'Mot-clé...', value: query ?? '' } %}
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors self-end">Chercher</button>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% embed 'components/MfCard.html.twig' with { title: 'Documents archivés' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'titre', label: 'Titre' },
                { key: 'categorie', label: 'Catégorie' },
                { key: 'date', label: 'Date' },
                { key: 'reference', label: 'Référence' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_archives', query: {} } %}

{% elseif mode == 'search' %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Résultats de recherche</h1>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Recherche' } %}
    {% block card_content %}
    <form method="get" action="{{ path('support_archives_search') }}" class="mb-4">
        <div class="flex gap-3">
            {% include 'components/MfInput.html.twig' with { name: 'q', label: 'Rechercher', placeholder: 'Mot-clé...', value: query ?? '' } %}
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors self-end">Chercher</button>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% embed 'components/MfCard.html.twig' with { title: 'Résultats' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'titre', label: 'Titre' },
                { key: 'categorie', label: 'Catégorie' },
                { key: 'date', label: 'Date' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
<div class="mt-4"><a href="{{ path('support_archives') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour aux archives</a></div>

{% elseif mode == 'show' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">{{ item.titre ?? 'Archive' }}</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Détails' } %}
    {% block card_content %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><strong>Titre:</strong> {{ item.titre ?? '—' }}</div>
        <div><strong>Catégorie:</strong> {{ item.categorie ?? '—' }}</div>
        <div><strong>Référence:</strong> {{ item.reference ?? '—' }}</div>
        <div><strong>Date:</strong> {{ item.date ?? '—' }}</div>
        <div><strong>Description:</strong> {{ item.description ?? '—' }}</div>
    </div>
    <div class="mt-6"><a href="{{ path('support_archives') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a></div>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
