{% extends 'backoffice.html.twig' %}

{% block title %}Maintenance - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support', url: path('support_maintenance') }, { label: 'Maintenance' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Maintenance</h1>
    <a href="{{ path('support_maintenance_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouvelle intervention</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Interventions de maintenance' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'equipement', label: 'Équipement' },
                { key: 'type', label: 'Type' },
                { key: 'date', label: 'Date' },
                { key: 'technicien', label: 'Technicien' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_maintenance', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouvelle intervention</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Enregistrement' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_maintenance_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'equipement', label: 'Équipement', required: true } %}
            {% include 'components/MfSelect.html.twig' with { name: 'type', label: 'Type', options: [
                { value: 'PREVENTIVE', label: 'Préventive' }, { value: 'CORRECTIVE', label: 'Corrective' }, { value: 'URGENTE', label: 'Urgente' }
            ]} %}
            {% include 'components/MfDatePicker.html.twig' with { name: 'date', label: "Date d'intervention", required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'technicien', label: 'Technicien' } %}
            {% include 'components/MfInput.html.twig' with { name: 'description', label: 'Description' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_maintenance') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
