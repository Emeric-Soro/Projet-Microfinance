{% extends 'backoffice.html.twig' %}

{% block title %}Courrier - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support', url: path('support_courrier') }, { label: 'Courrier' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Courrier</h1>
    <a href="{{ path('support_courrier_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouveau courrier</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste du courrier' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'reference', label: 'Référence' },
                { key: 'objet', label: 'Objet' },
                { key: 'date', label: 'Date' },
                { key: 'type', label: 'Type' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_courrier', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouveau courrier</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Enregistrement' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_courrier_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'reference', label: 'Référence', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'objet', label: 'Objet', required: true } %}
            {% include 'components/MfSelect.html.twig' with { name: 'type', label: 'Type', options: [
                { value: 'ENTRANT', label: 'Entrant' }, { value: 'SORTANT', label: 'Sortant' }, { value: 'INTERNE', label: 'Interne' }
            ]} %}
            {% include 'components/MfDatePicker.html.twig' with { name: 'date', label: 'Date', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'expediteur', label: 'Expéditeur' } %}
            {% include 'components/MfInput.html.twig' with { name: 'destinataire', label: 'Destinataire' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_courrier') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}

{% elseif mode == 'show' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">{{ item.objet ?? 'Courrier' }}</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Détails' } %}
    {% block card_content %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><strong>Référence:</strong> {{ item.reference ?? '—' }}</div>
        <div><strong>Objet:</strong> {{ item.objet ?? '—' }}</div>
        <div><strong>Type:</strong> {{ item.type ?? '—' }}</div>
        <div><strong>Date:</strong> {{ item.date ?? '—' }}</div>
        <div><strong>Expéditeur:</strong> {{ item.expediteur ?? '—' }}</div>
        <div><strong>Destinataire:</strong> {{ item.destinataire ?? '—' }}</div>
        <div><strong>Statut:</strong> {% include 'components/MfStatusBadge.html.twig' with { status: item.statut ?? 'EN_COURS' } %}</div>
    </div>
    <div class="mt-6"><a href="{{ path('support_courrier') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a></div>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
