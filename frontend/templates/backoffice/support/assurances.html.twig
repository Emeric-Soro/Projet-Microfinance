{% extends 'backoffice.html.twig' %}

{% block title %}Assurances - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support', url: path('support_assurances') }, { label: 'Assurances' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Assurances</h1>
    <a href="{{ path('support_assurances_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouvelle assurance</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des assurances' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'objet', label: 'Objet' },
                { key: 'type', label: 'Type' },
                { key: 'compagnie', label: 'Compagnie' },
                { key: 'dateDebut', label: 'Début' },
                { key: 'dateFin', label: 'Fin' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_assurances', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouvelle assurance</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Création' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_assurances_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'objet', label: 'Objet assuré', required: true } %}
            {% include 'components/MfSelect.html.twig' with { name: 'type', label: 'Type', options: [
                { value: 'VEHICULE', label: 'Véhicule' }, { value: 'BIEN', label: 'Bien' },
                { value: 'RESPONSABILITE', label: 'Responsabilité civile' }, { value: 'VIE', label: 'Vie' }
            ]} %}
            {% include 'components/MfInput.html.twig' with { name: 'compagnie', label: 'Compagnie', required: true } %}
            {% include 'components/MfDatePicker.html.twig' with { name: 'dateDebut', label: 'Date début', required: true } %}
            {% include 'components/MfDatePicker.html.twig' with { name: 'dateFin', label: 'Date fin', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'prime', label: 'Prime', type: 'number' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_assurances') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}

{% elseif mode == 'show' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Détails assurance</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Informations' } %}
    {% block card_content %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><strong>Objet:</strong> {{ item.objet ?? '—' }}</div>
        <div><strong>Type:</strong> {{ item.type ?? '—' }}</div>
        <div><strong>Compagnie:</strong> {{ item.compagnie ?? '—' }}</div>
        <div><strong>Date début:</strong> {{ item.dateDebut ?? '—' }}</div>
        <div><strong>Date fin:</strong> {{ item.dateFin ?? '—' }}</div>
        <div><strong>Prime:</strong> {{ item.prime ?? '—' }}</div>
        <div><strong>Statut:</strong> {% include 'components/MfStatusBadge.html.twig' with { status: item.statut ?? 'ACTIF' } %}</div>
    </div>
    <div class="mt-6"><a href="{{ path('support_assurances') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a></div>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
