{% extends 'backoffice.html.twig' %}

{% block title %}Évaluations - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support RH', url: path('support_evaluations') }, { label: 'Évaluations' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Évaluations</h1>
    <a href="{{ path('support_evaluations_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouvelle évaluation</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des évaluations' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'employe', label: 'Employé' },
                { key: 'periode', label: 'Période' },
                { key: 'note', label: 'Note' },
                { key: 'appreciation', label: 'Appréciation' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_evaluations', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouvelle évaluation</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Création' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_evaluations_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'employe', label: 'Employé', required: true } %}
            {% include 'components/MfDatePicker.html.twig' with { name: 'periode', label: 'Période', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'note', label: 'Note /20', type: 'number' } %}
            {% include 'components/MfInput.html.twig' with { name: 'appreciation', label: 'Appréciation' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_evaluations') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}

{% elseif mode == 'show' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Détails évaluation</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Informations' } %}
    {% block card_content %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><strong>Employé:</strong> {{ item.employe ?? '—' }}</div>
        <div><strong>Période:</strong> {{ item.periode ?? '—' }}</div>
        <div><strong>Note:</strong> {{ item.note ?? '—' }}</div>
        <div><strong>Appréciation:</strong> {{ item.appreciation ?? '—' }}</div>
    </div>
    <div class="mt-6"><a href="{{ path('support_evaluations') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a></div>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
