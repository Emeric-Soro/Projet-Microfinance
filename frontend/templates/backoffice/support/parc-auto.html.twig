{% extends 'backoffice.html.twig' %}

{% block title %}Parc Auto - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support', url: path('support_parc_auto') }, { label: 'Parc Auto' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Parc Auto</h1>
    <a href="{{ path('support_parc_auto_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Ajouter un véhicule</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Véhicules' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'immatriculation', label: 'Immatriculation' },
                { key: 'marque', label: 'Marque' },
                { key: 'modele', label: 'Modèle' },
                { key: 'annee', label: 'Année' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_parc_auto', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Ajouter un véhicule</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Ajout' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_parc_auto_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'immatriculation', label: 'Immatriculation', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'marque', label: 'Marque', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'modele', label: 'Modèle', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'annee', label: 'Année', type: 'number' } %}
            {% include 'components/MfInput.html.twig' with { name: 'carburant', label: 'Type carburant' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_parc_auto') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
