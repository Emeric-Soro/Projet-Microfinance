{% extends 'backoffice.html.twig' %}

{% block title %}Recrutement - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support RH', url: path('support_recrutement') }, { label: 'Recrutement' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Recrutement</h1>
    <a href="{{ path('support_recrutement_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouveau recrutement</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des recrutements' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'poste', label: 'Poste' },
                { key: 'candidat', label: 'Candidat' },
                { key: 'date', label: 'Date' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_recrutement', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouveau recrutement</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Création' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_recrutement_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'poste', label: 'Poste', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'candidat', label: 'Nom du candidat', required: true } %}
            {% include 'components/MfDatePicker.html.twig' with { name: 'dateCandidature', label: 'Date candidature' } %}
            {% include 'components/MfSelect.html.twig' with { name: 'statut', label: 'Statut', options: [
                { value: 'NOUVEAU', label: 'Nouveau' }, { value: 'ENTRETIEN', label: 'Entretien' },
                { value: 'ACCEPTE', label: 'Accepté' }, { value: 'REFUSE', label: 'Refusé' }
            ]} %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_recrutement') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}

{% elseif mode == 'show' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Détails recrutement</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Informations' } %}
    {% block card_content %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><strong>Poste:</strong> {{ item.poste ?? '—' }}</div>
        <div><strong>Candidat:</strong> {{ item.candidat ?? '—' }}</div>
        <div><strong>Date:</strong> {{ item.dateCandidature ?? '—' }}</div>
        <div><strong>Statut:</strong> {% include 'components/MfStatusBadge.html.twig' with { status: item.statut ?? 'NOUVEAU' } %}</div>
    </div>
    <div class="mt-6"><a href="{{ path('support_recrutement') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a></div>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
