{% extends 'backoffice.html.twig' %}

{% block title %}Budget - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support', url: path('support_budget') }, { label: 'Budget' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Budget</h1>
    <a href="{{ path('support_budget_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouveau budget</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des budgets' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'exercice', label: 'Exercice' },
                { key: 'categorie', label: 'Catégorie' },
                { key: 'montantPrevu', label: 'Montant prévu' },
                { key: 'montantExecute', label: 'Montant exécuté' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_budget', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouveau budget</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Création' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_budget_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'exercice', label: 'Exercice', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'categorie', label: 'Catégorie', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'montantPrevu', label: 'Montant prévu', type: 'number', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'description', label: 'Description' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_budget') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}

{% elseif mode == 'show' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Détails budget</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Informations' } %}
    {% block card_content %}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div><strong>Exercice:</strong> {{ item.exercice ?? '—' }}</div>
        <div><strong>Catégorie:</strong> {{ item.categorie ?? '—' }}</div>
        <div><strong>Montant prévu:</strong> {{ item.montantPrevu ?? '—' }}</div>
        <div><strong>Montant exécuté:</strong> {{ item.montantExecute ?? '—' }}</div>
        <div><strong>Statut:</strong> {% include 'components/MfStatusBadge.html.twig' with { status: item.statut ?? 'ACTIF' } %}</div>
    </div>
    <div class="mt-6 flex gap-3">
        <a href="{{ path('support_budget_execution', { id: item.id }) }}" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Voir exécution</a>
        <a href="{{ path('support_budget') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a>
    </div>
    {% endblock %}
{% endembed %}

{% elseif mode == 'execution' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Exécution budget {{ item.exercice ?? '' }}</h1></div>
{% embed 'components/MfCard.html.twig' with { title: 'Suivi d\'exécution' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'mois', label: 'Mois' },
                { key: 'prevu', label: 'Prévu' },
                { key: 'execute', label: 'Exécuté' },
                { key: 'ecart', label: 'Écart' },
                { key: 'taux', label: 'Taux' },
            ],
            rows: execution.lignes ?? [],
            actions: false,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
<div class="mt-4"><a href="{{ path('support_budget') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Retour</a></div>
{% endif %}
{% endblock %}
