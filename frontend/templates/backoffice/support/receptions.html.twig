{% extends 'backoffice.html.twig' %}

{% block title %}Réceptions - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Support', url: path('support_receptions') }, { label: 'Réceptions' }] %}

{% if mode == 'list' %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Réceptions</h1>
    <a href="{{ path('support_receptions_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Nouvelle réception</a>
</div>
{% embed 'components/MfCard.html.twig' with { title: 'Liste des réceptions' } %}
    {% block card_content %}
        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                { key: 'reference', label: 'Référence' },
                { key: 'fournisseur', label: 'Fournisseur' },
                { key: 'date', label: 'Date' },
                { key: 'statut', label: 'Statut' },
                { key: 'actions', label: 'Actions' },
            ],
            rows: items,
            actions: true,
        } %}{% endembed %}
    {% endblock %}
{% endembed %}
{% include 'partials/_pagination.html.twig' with { current_page: page, total_pages: pages, total_items: total, route: 'support_receptions', query: {} } %}

{% elseif mode == 'create' %}
<div class="mb-6"><h1 class="text-2xl font-heading font-bold">Nouvelle réception</h1></div>
{% embed 'components/MfFormCard.html.twig' with { title: 'Enregistrement' } %}
    {% block form_fields %}
    <form method="post" action="{{ path('support_receptions_create') }}">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% include 'components/MfInput.html.twig' with { name: 'reference', label: 'Référence', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'fournisseur', label: 'Fournisseur', required: true } %}
            {% include 'components/MfDatePicker.html.twig' with { name: 'date', label: 'Date', required: true } %}
            {% include 'components/MfInput.html.twig' with { name: 'notes', label: 'Notes' } %}
        </div>
        <div class="mt-6 flex gap-3">
            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Enregistrer</button>
            <a href="{{ path('support_receptions') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
        </div>
    </form>
    {% endblock %}
{% endembed %}
{% endif %}
{% endblock %}
