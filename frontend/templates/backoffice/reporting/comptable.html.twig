{% extends 'backoffice.html.twig' %}

{% block title %}Reporting Comptable - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfStatsGrid.html.twig' with { stats: [
        { label: 'Total Actifs', value: data.total_actifs|default('—'), icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
        { label: 'Total Passifs', value: data.total_passifs|default('—'), icon: 'M13 17h8m0 0V9m0 8l-8-8-4 4-6-6', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
        { label: 'Produits', value: data.produits|default('—'), icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-primary-50', icon_color: 'text-primary' },
        { label: 'Charges', value: data.charges|default('—'), icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
    ] } %}{% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Comptes de Résultat' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'compte', label: 'Compte' },
                    { key: 'montant', label: 'Montant' },
                    { key: 'variation', label: 'Variation' },
                    { key: 'periode', label: 'Période' },
                ],
                rows: data.comptes|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
