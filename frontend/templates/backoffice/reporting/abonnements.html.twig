{% extends 'backoffice.html.twig' %}

{% block title %}Abonnements Reporting - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Nouvel Abonnement' } %}
        {% block card_content %}
            <form method="post" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Type de Rapport</label>
                        <select name="subscription[type]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                            <option value="comptable">Comptable</option>
                            <option value="credit">Crédit</option>
                            <option value="epargne">Épargne</option>
                            <option value="caisse">Caisse</option>
                            <option value="conformite">Conformité</option>
                            <option value="rh">RH</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Fréquence</label>
                        <select name="subscription[frequence]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                            <option value="quotidien">Quotidien</option>
                            <option value="hebdomadaire">Hebdomadaire</option>
                            <option value="mensuel">Mensuel</option>
                            <option value="trimestriel">Trimestriel</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Email</label>
                    <input type="email" name="subscription[email]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Format</label>
                    <select name="subscription[format]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                        <option value="pdf">PDF</option>
                        <option value="xlsx">Excel</option>
                    </select>
                </div>
                <div class="flex justify-end gap-3">
                    <button type="reset" class="mf-btn-secondary">Réinitialiser</button>
                    <button type="submit" class="mf-btn-primary">S'abonner</button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Mes Abonnements' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'type', label: 'Type' },
                    { key: 'frequence', label: 'Fréquence' },
                    { key: 'email', label: 'Email' },
                    { key: 'format', label: 'Format' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: subscriptions|default([]),
                actions: [
                    { label: 'Modifier', url: row => '#', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
                    { label: 'Désactiver', url: row => '#', icon: 'M6 18L18 6M6 6l12 12' },
                ],
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
