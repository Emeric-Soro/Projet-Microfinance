{% extends 'backoffice.html.twig' %}

{% block title %}Rapports Programmés - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfCard.html.twig' with { title: 'Programmer un Rapport' } %}
        {% block card_content %}
            <form method="post" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Rapport</label>
                        <select name="program[rapport]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary" required>
                            <option value="">Sélectionner un rapport...</option>
                            {% for report in programs|default([]) %}
                                <option value="{{ report.id }}">{{ report.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Fréquence</label>
                        <select name="program[frequence]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                            <option value="quotidien">Quotidien</option>
                            <option value="hebdomadaire">Hebdomadaire</option>
                            <option value="mensuel">Mensuel</option>
                            <option value="trimestriel">Trimestriel</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Date Début</label>
                        <input type="date" name="program[date_debut]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Date Fin</label>
                        <input type="date" name="program[date_fin]" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Destinataires (emails séparés par ;)</label>
                    <input type="text" name="program[destinataires]" placeholder="email1@example.com; email2@example.com" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-primary focus:border-primary">
                </div>
                <div class="flex justify-end gap-3">
                    <button type="reset" class="mf-btn-secondary">Réinitialiser</button>
                    <button type="submit" class="mf-btn-primary">Programmer</button>
                </div>
            </form>
        {% endblock %}
    {% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Rapports Programmés' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'rapport', label: 'Rapport' },
                    { key: 'frequence', label: 'Fréquence' },
                    { key: 'prochaine_execution', label: 'Prochaine Exécution' },
                    { key: 'derniere_execution', label: 'Dernière Exécution' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: programs|default([]),
                actions: [
                    { label: 'Exécuter', url: row => '#', icon: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z' },
                    { label: 'Modifier', url: row => '#', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
                ],
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
