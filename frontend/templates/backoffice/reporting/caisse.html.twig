{% extends 'backoffice.html.twig' %}

{% block title %}Reporting Caisse - MicroFin{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' %}

<div class="space-y-6">
    {% embed 'components/MfStatsGrid.html.twig' with { stats: [
        { label: 'Solde Caisse', value: data.solde|default('—'), icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-primary-50', icon_color: 'text-primary' },
        { label: 'Flux Entrée', value: data.flux_entree|default('—'), icon: 'M12 6v6m0 0v6m0-6h6m-6 0H6', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
        { label: 'Flux Sortie', value: data.flux_sortie|default('—'), icon: 'M20 12H4', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
        { label: 'Variance', value: data.variance|default('—'), icon: 'M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z', icon_bg: 'bg-yellow-50', icon_color: 'text-yellow-600' },
    ] } %}{% endembed %}

    {% embed 'components/MfCard.html.twig' with { title: 'Mouvements de Caisse' } %}
        {% block card_content %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    { key: 'date', label: 'Date' },
                    { key: 'type', label: 'Type' },
                    { key: 'montant', label: 'Montant' },
                    { key: 'guichet', label: 'Guichet' },
                    { key: 'statut', label: 'Statut' },
                ],
                rows: data.mouvements|default([]),
                actions: false,
            } %}{% endembed %}
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
