{% extends 'backoffice.html.twig' %}

{% block title %}Export clients - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Clients', url: path('client_list') }, { label: 'Export' }] %}

<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Export des clients</h1>
    <p class="text-sm text-on-surface-variant mt-1">Choisissez le format et les filtres pour l'exportation.</p>
</div>

<div class="max-w-2xl mx-auto">
    <form method="get" action="{{ path('client_export') }}">
        {% embed 'components/MfCard.html.twig' with { title: 'Options d\'export' } %}
            {% block card_content %}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {% include 'components/MfSelect.html.twig' with { name: 'format', label: 'Format d\'export', required: true, options: [
                    { value: 'csv', label: 'CSV' },
                    { value: 'xlsx', label: 'Excel (XLSX)' },
                    { value: 'pdf', label: 'PDF' },
                ]} %}
                {% include 'components/MfSelect.html.twig' with { name: 'type', label: 'Type de client', options: [
                    { value: '', label: 'Tous' },
                    { value: 'PHYSIQUE', label: 'Personnes physiques' },
                    { value: 'MORAL', label: 'Personnes morales' },
                ]} %}
                {% include 'components/MfSelect.html.twig' with { name: 'statut', label: 'Statut', options: [
                    { value: '', label: 'Tous' },
                    { value: 'ACTIF', label: 'Actif' },
                    { value: 'SUSPENDU', label: 'Suspendu' },
                    { value: 'INACTIF', label: 'Inactif' },
                ]} %}
                {% include 'components/MfDatePicker.html.twig' with { name: 'dateDebut', label: 'Date création (début)' } %}
                {% include 'components/MfDatePicker.html.twig' with { name: 'dateFin', label: 'Date création (fin)' } %}
            </div>
            <div class="mt-6 flex gap-3">
                <button type="submit" class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">Télécharger</button>
                <a href="{{ path('client_list') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
            </div>
            {% endblock %}
        {% endembed %}
    </form>

    {% embed 'components/MfCard.html.twig' with { title: 'Exports récents', class: 'mt-6' } %}
        {% block card_content %}
            <p class="text-sm text-on-surface-variant">Aucun export récent.</p>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
