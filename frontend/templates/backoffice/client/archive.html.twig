{% extends 'backoffice.html.twig' %}

{% block title %}Archiver {{ client.nom ?? client.raisonSociale ?? 'Client' }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [
    { label: 'Clients', url: path('client_list') },
    { label: client.nom ?? client.raisonSociale ?? 'Client', url: path('client_detail', { id: client.id }) },
    { label: 'Archiver' }
] %}

<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Archiver le client</h1>
</div>

<div class="max-w-2xl mx-auto">
    {% embed 'components/MfCard.html.twig' with { title: 'Confirmation d\'archivage' } %}
        {% block card_content %}
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                </svg>
                <div>
                    <p class="text-sm font-medium text-red-800">Attention</p>
                    <p class="text-sm text-red-700 mt-1">Vous êtes sur le point d'archiver le client <strong>{{ client.nom ?? client.raisonSociale ?? '' }} {{ client.prenom ?? '' }}</strong>. Cette action est irréversible. Le client ne pourra plus effectuer d'opérations.</p>
                </div>
            </div>
        </div>

        <form method="post" action="{{ path('client_archive', { id: client.id }) }}">
            {% include 'components/MfInput.html.twig' with { name: 'motif', label: 'Motif de l\'archivage', required: true } %}
            <div class="mt-6 flex gap-3">
                <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">Confirmer l'archivage</button>
                <a href="{{ path('client_detail', { id: client.id }) }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
            </div>
        </form>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
