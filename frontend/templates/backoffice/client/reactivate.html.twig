{% extends 'backoffice.html.twig' %}

{% block title %}Réactiver {{ client.nom ?? client.raisonSociale ?? 'Client' }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [
    { label: 'Clients', url: path('client_list') },
    { label: client.nom ?? client.raisonSociale ?? 'Client', url: path('client_detail', { id: client.id }) },
    { label: 'Réactiver' }
] %}

<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Réactiver le client</h1>
</div>

<div class="max-w-2xl mx-auto">
    {% embed 'components/MfCard.html.twig' with { title: 'Confirmation de réactivation' } %}
        {% block card_content %}
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                    <p class="text-sm font-medium text-green-800">Réactivation</p>
                    <p class="text-sm text-green-700 mt-1">Vous êtes sur le point de réactiver le client <strong>{{ client.nom ?? client.raisonSociale ?? '' }} {{ client.prenom ?? '' }}</strong>. Cette action rétablira l'accès à ses comptes et services.</p>
                </div>
            </div>
        </div>

        <form method="post" action="{{ path('client_reactivate', { id: client.id }) }}">
            {% include 'components/MfInput.html.twig' with { name: 'motif', label: 'Motif de la réactivation', required: true } %}
            <div class="mt-6 flex gap-3">
                <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors">Confirmer la réactivation</button>
                <a href="{{ path('client_detail', { id: client.id }) }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Annuler</a>
            </div>
        </form>
        {% endblock %}
    {% endembed %}
</div>
{% endblock %}
