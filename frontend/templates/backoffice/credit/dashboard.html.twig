{% extends 'backoffice.html.twig' %}

{% block title %}Tableau de bord Crédit - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit' }, { label: 'Tableau de bord' }] %}

<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Tableau de bord Crédit</h1>
    <p class="text-sm text-on-surface-variant mt-1">Suivi du portefeuille et des indicateurs clés</p>
</div>

{% if data is defined and data is not empty %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <p class="text-sm text-on-surface-variant">Crédits en cours</p>
            <p class="text-2xl font-bold text-on-surface mt-1">{{ data.creditsEnCours|default(0)|number_format(0, ',', ' ') }}</p>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <p class="text-sm text-on-surface-variant">Encours total</p>
            <p class="text-2xl font-bold text-teal-600 mt-1">{{ data.encoursTotal|default(0)|number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <p class="text-sm text-on-surface-variant">Impayés > 30 jours</p>
            <p class="text-2xl font-bold text-red-600 mt-1">{{ data.impayes30j|default(0)|number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-4">
            <p class="text-sm text-on-surface-variant">Taux PAR</p>
            <p class="text-2xl font-bold text-on-surface mt-1">{{ data.par|default(0) }}%</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Décaissements du mois</h3>
            </div>
            <div class="p-4">
                {% if data.decaissementsMois|default([]) is not empty %}
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-on-surface-variant border-b border-gray-100">
                                <th class="pb-2">Date</th>
                                <th class="pb-2">Client</th>
                                <th class="pb-2">Montant</th>
                                <th class="pb-2">Produit</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for dec in data.decaissementsMois %}
                                <tr class="border-b border-gray-50">
                                    <td class="py-2">{{ dec.date|default('') }}</td>
                                    <td class="py-2">{{ dec.client|default('') }}</td>
                                    <td class="py-2">{{ dec.montant|default(0)|number_format(0, ',', ' ') }}</td>
                                    <td class="py-2">{{ dec.produit|default('') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-sm text-on-surface-variant">Aucun décaissement ce mois.</p>
                {% endif %}
            </div>
        </div>

        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Répartition du portefeuille</h3>
            </div>
            <div class="p-4 space-y-3">
                <div class="flex justify-between items-center">
                    <span class="text-sm text-on-surface">Crédits sains</span>
                    <span class="text-sm font-medium text-green-600">{{ data.creditsSains|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-sm text-on-surface">Impayés 1-30 jours</span>
                    <span class="text-sm font-medium text-yellow-600">{{ data.impayes1a30|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-sm text-on-surface">Impayés 31-90 jours</span>
                    <span class="text-sm font-medium text-orange-600">{{ data.impayes31a90|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-sm text-on-surface">Impayés > 90 jours</span>
                    <span class="text-sm font-medium text-red-600">{{ data.impayesPlus90|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between items-center pt-2 border-t border-gray-100">
                    <span class="text-sm font-semibold text-on-surface">Provisions constituées</span>
                    <span class="text-sm font-semibold text-red-700">{{ data.provisions|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
            </div>
        </div>
    </div>

    {% if data.alertes|default([]) is not empty %}
        <div class="mt-6 space-y-2">
            <h3 class="font-semibold text-on-surface mb-3">Alertes</h3>
            {% for alerte in data.alertes %}
                <div class="p-3 rounded-lg text-sm {{ alerte.type == 'error' ? 'bg-red-50 border border-red-200 text-red-800' : alerte.type == 'warning' ? 'bg-yellow-50 border border-yellow-200 text-yellow-800' : 'bg-blue-50 border border-blue-200 text-blue-800' }}">
                    <p class="font-medium">{{ alerte.message }}</p>
                    {% if alerte.details is defined and alerte.details %}
                        <p class="mt-1 text-xs opacity-80">{{ alerte.details }}</p>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% else %}
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
        <p class="text-on-surface-variant">Chargement des données en cours...</p>
    </div>
{% endif %}
{% endblock %}
