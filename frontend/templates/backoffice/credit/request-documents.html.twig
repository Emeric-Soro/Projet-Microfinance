{% extends 'backoffice.html.twig' %}

{% block title %}Documents - Demande N°{{ demande.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Demandes', url: path('credit_requests') }, { label: 'N°' ~ demande.id ~ ' - Documents' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Documents - Demande N°{{ demande.id }}</h1>
    <span class="inline-block px-3 py-1 text-sm rounded-full {{ demande.statut == 'APPROUVEE' ? 'bg-green-100 text-green-800' : demande.statut == 'REJETEE' ? 'bg-red-100 text-red-800' : 'bg-blue-100 text-blue-800' }}">
        {{ demande.statut|default('BROUILLON')|replace({'_': ' '}) }}
    </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Documents fournis</h3>
            </div>
            <div class="p-4">
                {% if documents is not empty %}
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-on-surface-variant border-b border-gray-100">
                                <th class="pb-2">Type</th>
                                <th class="pb-2">Nom</th>
                                <th class="pb-2">Date d'ajout</th>
                                <th class="pb-2">Statut</th>
                                <th class="pb-2">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for doc in documents %}
                                <tr class="border-b border-gray-50">
                                    <td class="py-2">{{ doc.type|default('') }}</td>
                                    <td class="py-2">{{ doc.nom|default('') }}</td>
                                    <td class="py-2">{{ doc.dateAjout|default('')|date('d/m/Y') }}</td>
                                    <td class="py-2">
                                        <span class="inline-block px-2 py-0.5 text-xs rounded-full {{ doc.statut == 'VALIDE' ? 'bg-green-100 text-green-800' : doc.statut == 'REJETE' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' }}">
                                            {{ doc.statut|default('EN_ATTENTE')|replace({'_': ' '}) }}
                                        </span>
                                    </td>
                                    <td class="py-2">
                                        <a href="#" class="text-teal-600 hover:text-teal-800 text-xs">Télécharger</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-sm text-on-surface-variant text-center py-4">Aucun document fourni.</p>
                {% endif %}
            </div>
        </div>
    </div>

    <div>
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Ajouter un document</h3>
            </div>
            <div class="p-4">
                <form method="post" action="{{ path('credit_request_documents', { id: demande.id }) }}" enctype="multipart/form-data">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Type de document</label>
                            <select name="type" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                                <option value="PIECE_IDENTITE">Pièce d'identité</option>
                                <option value="JUSTIFICATIF_REVENU">Justificatif de revenu</option>
                                <option value="FACTURE">Facture</option>
                                <option value="CONTRAT">Contrat</option>
                                <option value="AUTRE">Autre</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Fichier</label>
                            <input type="file" name="fichier" class="w-full text-sm">
                        </div>
                        <button type="submit" class="w-full px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Ajouter</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
