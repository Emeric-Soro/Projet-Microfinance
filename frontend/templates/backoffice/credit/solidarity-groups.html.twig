{% extends 'backoffice.html.twig' %}

{% block title %}Groupes solidaires - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Groupes solidaires' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Groupes solidaires</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 text-left">
                        <th class="px-4 py-3 font-medium text-on-surface-variant">Nom</th>
                        <th class="px-4 py-3 font-medium text-on-surface-variant">Membres</th>
                        <th class="px-4 py-3 font-medium text-on-surface-variant">Encours total</th>
                        <th class="px-4 py-3 font-medium text-on-surface-variant">Statut</th>
                        <th class="px-4 py-3 font-medium text-on-surface-variant">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for g in groups %}
                        <tr class="border-t border-gray-100 hover:bg-gray-50">
                            <td class="px-4 py-3 font-medium">{{ g.nom|default('Groupe') }}</td>
                            <td class="px-4 py-3">{{ g.nombreMembres|default(0) }}</td>
                            <td class="px-4 py-3">{{ g.encoursTotal|default(0)|number_format(0, ',', ' ') }} FCFA</td>
                            <td class="px-4 py-3">
                                <span class="inline-block px-2 py-0.5 text-xs rounded-full {{ g.statut == 'ACTIF' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' }}">
                                    {{ g.statut|default('')|replace({'_': ' '}) }}
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                <a href="{{ path('credit_group_collection', { groupId: g.id }) }}" class="text-teal-600 hover:text-teal-800 text-xs">Collecte</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-4 py-8 text-center text-on-surface-variant">Aucun groupe solidaire trouvé.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div>
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Nouveau groupe</h3>
            </div>
            <div class="p-4">
                <form method="post" action="{{ path('credit_solidarity_groups') }}">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Nom du groupe</label>
                            <input type="text" name="nom" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Description</label>
                            <textarea name="description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
                        </div>
                        <button type="submit" class="w-full px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Créer le groupe</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
