{% extends 'backoffice.html.twig' %}

{% block title %}Demandes de crédit - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Demandes' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Demandes de crédit</h1>
    <a href="{{ path('credit_request_create') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors text-sm">Nouvelle demande</a>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-gray-50 text-left">
                <th class="px-4 py-3 font-medium text-on-surface-variant">N°</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Client</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Produit</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Montant</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Date</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Statut</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for demande in requests %}
                <tr class="border-t border-gray-100 hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium">{{ demande.id }}</td>
                    <td class="px-4 py-3">{{ demande.clientNom|default(demande.clientId|default('')) }}</td>
                    <td class="px-4 py-3">{{ demande.produitLibelle|default('') }}</td>
                    <td class="px-4 py-3">{{ demande.montant|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="px-4 py-3">{{ demande.dateCreation|default('')|date('d/m/Y') }}</td>
                    <td class="px-4 py-3">
                        <span class="inline-block px-2 py-0.5 text-xs rounded-full {{ demande.statut == 'APPROUVEE' ? 'bg-green-100 text-green-800' : demande.statut == 'REJETEE' ? 'bg-red-100 text-red-800' : demande.statut == 'EN_ANALYSE' ? 'bg-blue-100 text-blue-800' : 'bg-yellow-100 text-yellow-800' }}">
                            {{ demande.statut|default('BROUILLON')|replace({'_': ' '}) }}
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                            <a href="{{ path('credit_analysis', { id: demande.id }) }}" class="text-teal-600 hover:text-teal-800 text-xs">Analyse</a>
                            <a href="{{ path('credit_request_documents', { id: demande.id }) }}" class="text-teal-600 hover:text-teal-800 text-xs">Docs</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="px-4 py-8 text-center text-on-surface-variant">Aucune demande de crédit trouvée.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
