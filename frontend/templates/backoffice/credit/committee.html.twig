{% extends 'backoffice.html.twig' %}

{% block title %}Comité - Demande N°{{ demande.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Demandes', url: path('credit_requests') }, { label: 'N°' ~ demande.id ~ ' - Comité' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Comité de crédit - Demande N°{{ demande.id }}</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Membres du comité</h3>
            </div>
            <div class="p-4">
                {% if membres is not empty %}
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-on-surface-variant border-b border-gray-100">
                                <th class="pb-2">Membre</th>
                                <th class="pb-2">Rôle</th>
                                <th class="pb-2">Avis</th>
                                <th class="pb-2">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for m in membres %}
                                <tr class="border-b border-gray-50">
                                    <td class="py-2">{{ m.nom|default('') }}</td>
                                    <td class="py-2">{{ m.role|default('') }}</td>
                                    <td class="py-2">
                                        {% if m.avis == 'FAVORABLE' %}
                                            <span class="text-green-600 font-medium">Favorable</span>
                                        {% elseif m.avis == 'DEFAVORABLE' %}
                                            <span class="text-red-600 font-medium">Défavorable</span>
                                        {% else %}
                                            <span class="text-yellow-600">En attente</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-2">{{ m.dateVote|default('')|date('d/m/Y') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-sm text-on-surface-variant text-center py-4">Aucun membre désigné.</p>
                {% endif %}
            </div>
        </div>
    </div>

    <div>
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Enregistrer un avis</h3>
            </div>
            <div class="p-4">
                <form method="post" action="{{ path('credit_committee', { id: demande.id }) }}">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Votre avis</label>
                            <select name="avis" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                                <option value="FAVORABLE">Favorable</option>
                                <option value="DEFAVORABLE">Défavorable</option>
                                <option value="RESERVE">Réservé</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Commentaires</label>
                            <textarea name="commentaires" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
                        </div>
                        <button type="submit" class="w-full px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Soumettre</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
