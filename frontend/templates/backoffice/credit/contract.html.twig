{% extends 'backoffice.html.twig' %}

{% block title %}Contrat - Crédit N°{{ credit.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Crédits actifs', url: path('credit_active') }, { label: 'N°' ~ credit.id ~ ' - Contrat' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Contrat de crédit N°{{ credit.id }}</h1>
</div>

<div class="bg-white rounded-lg border border-gray-200">
    <div class="px-4 py-3 border-b border-gray-200">
        <h3 class="font-semibold text-on-surface">Génération du contrat</h3>
    </div>
    <div class="p-4">
        <form method="post" action="{{ path('credit_contract', { id: credit.id }) }}">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Numéro de contrat</label>
                    <input type="text" name="numeroContrat" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ contrat.numeroContrat|default('') }}">
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Date de signature</label>
                    <input type="date" name="dateSignature" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ contrat.dateSignature|default('')|date('Y-m-d') }}">
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Date d'effet</label>
                    <input type="date" name="dateEffet" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ contrat.dateEffet|default('')|date('Y-m-d') }}">
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Date d'échéance finale</label>
                    <input type="date" name="dateEcheanceFinale" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ contrat.dateEcheanceFinale|default('')|date('Y-m-d') }}">
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Montant en toutes lettres</label>
                    <input type="text" name="montantLettres" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ contrat.montantLettres|default('') }}">
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Taux nominal</label>
                    <input type="number" name="tauxNominal" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ contrat.tauxNominal|default(credit.taux|default(0)) }}" step="0.01">
                </div>
            </div>
            <div class="mt-4">
                <label class="block text-sm font-medium text-on-surface mb-1">Clauses particulières</label>
                <textarea name="clauses" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">{{ contrat.clauses|default('') }}</textarea>
            </div>
            <div class="flex items-center justify-end gap-3 mt-6">
                <a href="{{ path('credit_detail', { id: credit.id }) }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-sm">Annuler</a>
                <button type="submit" class="px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Générer le contrat</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
