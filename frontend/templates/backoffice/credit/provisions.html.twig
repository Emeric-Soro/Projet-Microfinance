{% extends 'backoffice.html.twig' %}

{% block title %}Provisions - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Provisions' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Provisions</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-sm text-on-surface-variant">Total provisions</p>
        <p class="text-xl font-bold text-on-surface mt-1">{{ provisions|reduce((carry, p) => carry + p.montant|default(0), 0)|number_format(0, ',', ' ') }} FCFA</p>
    </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-gray-50 text-left">
                <th class="px-4 py-3 font-medium text-on-surface-variant">N° crédit</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Client</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Encours</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Taux provision</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Montant provision</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Date calcul</th>
            </tr>
        </thead>
        <tbody>
            {% for p in provisions %}
                <tr class="border-t border-gray-100 hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium">{{ p.creditId|default('') }}</td>
                    <td class="px-4 py-3">{{ p.clientNom|default('') }}</td>
                    <td class="px-4 py-3">{{ p.encours|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="px-4 py-3">{{ p.tauxProvision|default(0) }}%</td>
                    <td class="px-4 py-3 font-semibold text-red-600">{{ p.montant|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="px-4 py-3">{{ p.dateCalcul|default('')|date('d/m/Y') }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="px-4 py-8 text-center text-on-surface-variant">Aucune provision trouvée.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="mt-6 bg-white rounded-lg border border-gray-200">
    <div class="px-4 py-3 border-b border-gray-200">
        <h3 class="font-semibold text-on-surface">Constituer une provision</h3>
    </div>
    <div class="p-4">
        <form method="post" action="{{ path('credit_provisions') }}">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Crédit</label>
                    <input type="number" name="credit_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="ID du crédit" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Taux de provision (%)</label>
                    <input type="number" name="tauxProvision" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" min="0" max="100" step="0.1" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Montant (FCFA)</label>
                    <input type="number" name="montant" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" min="0" step="1000" required>
                </div>
            </div>
            <div class="flex items-center justify-end mt-4">
                <button type="submit" class="px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Enregistrer la provision</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
