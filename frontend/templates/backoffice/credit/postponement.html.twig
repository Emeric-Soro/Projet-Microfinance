{% extends 'backoffice.html.twig' %}

{% block title %}Report d'échéance - Crédit N°{{ credit.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Crédits actifs', url: path('credit_active') }, { label: 'N°' ~ credit.id ~ ' - Report' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Report d'échéance - Crédit N°{{ credit.id }}</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Détails du crédit</h3>
            </div>
            <div class="p-4 space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Client</span>
                    <span class="font-medium">{{ credit.clientNom|default('') }}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Encours</span>
                    <span class="font-semibold">{{ credit.encours|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Mensualité</span>
                    <span class="font-medium">{{ credit.montantEcheance|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Échéances impayées</span>
                    <span class="font-medium text-red-600">{{ credit.echeancesImpayees|default(0) }}</span>
                </div>
            </div>
        </div>
    </div>

    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Paramètres du report</h3>
            </div>
            <div class="p-4">
                <form method="post" action="{{ path('credit_postponement', { id: credit.id }) }}">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Nombre d'échéances à reporter</label>
                            <input type="number" name="nombreEcheances" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" min="1" max="6" value="1">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Nouvelle durée (mois)</label>
                            <input type="number" name="nouvelleDuree" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ credit.duree|default(0) + 1 }}" min="{{ credit.duree|default(0) }}">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Date de début du report</label>
                            <input type="date" name="dateDebutReport" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Type de report</label>
                            <select name="typeReport" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                                <option value="PARTIEL">Partiel (intérêts seulement)</option>
                                <option value="TOTAL">Total (capital + intérêts)</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-4">
                        <label class="block text-sm font-medium text-on-surface mb-1">Motif du report</label>
                        <textarea name="motif" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" required></textarea>
                    </div>
                    <div class="flex items-center justify-end gap-3 mt-6">
                        <a href="{{ path('credit_detail', { id: credit.id }) }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-sm">Annuler</a>
                        <button type="submit" class="px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Enregistrer le report</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
