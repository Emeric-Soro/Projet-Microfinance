{% extends 'backoffice.html.twig' %}

{% block title %}Analyse - Demande N°{{ demande.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Demandes', url: path('credit_requests') }, { label: 'N°' ~ demande.id ~ ' - Analyse' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Analyse de la demande N°{{ demande.id }}</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Informations de la demande</h3>
            </div>
            <div class="p-4 space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Client</span>
                    <span class="font-medium">{{ demande.clientNom|default('') }}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Montant</span>
                    <span class="font-medium">{{ demande.montant|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Durée</span>
                    <span class="font-medium">{{ demande.duree|default(0) }} mois</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Produit</span>
                    <span class="font-medium">{{ demande.produitLibelle|default('') }}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Statut</span>
                    <span class="font-medium">{{ demande.statut|default('')|replace({'_': ' '}) }}</span>
                </div>
            </div>
        </div>
    </div>

    <div class="lg:col-span-2">
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Analyse financière</h3>
            </div>
            <div class="p-4">
                <form method="post" action="{{ path('credit_analysis', { id: demande.id }) }}">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Capacité de remboursement</label>
                            <input type="number" name="capaciteRemboursement" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ analyse.capaciteRemboursement|default('') }}" min="0" step="1000">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Ratio d'endettement (%)</label>
                            <input type="number" name="ratioEndettement" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ analyse.ratioEndettement|default('') }}" min="0" step="0.01">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Revenus mensuels</label>
                            <input type="number" name="revenusMensuels" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ analyse.revenusMensuels|default('') }}" min="0" step="1000">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-on-surface mb-1">Charges mensuelles</label>
                            <input type="number" name="chargesMensuelles" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" value="{{ analyse.chargesMensuelles|default('') }}" min="0" step="1000">
                        </div>
                    </div>
                    <div class="mt-4">
                        <label class="block text-sm font-medium text-on-surface mb-1">Avis de l'analyste</label>
                        <textarea name="avis" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">{{ analyse.avis|default('') }}</textarea>
                    </div>
                    <div class="mt-4">
                        <label class="block text-sm font-medium text-on-surface mb-1">Recommandation</label>
                        <select name="recommandation" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                            <option value="FAVORABLE" {{ analyse.recommandation|default('') == 'FAVORABLE' ? 'selected' : '' }}>Favorable</option>
                            <option value="RESERVE" {{ analyse.recommandation|default('') == 'RESERVE' ? 'selected' : '' }}>Réservé</option>
                            <option value="DEFAVORABLE" {{ analyse.recommandation|default('') == 'DEFAVORABLE' ? 'selected' : '' }}>Défavorable</option>
                        </select>
                    </div>
                    <div class="flex items-center justify-end gap-3 mt-6">
                        <a href="{{ path('credit_requests') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-sm">Retour</a>
                        <button type="submit" class="px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Enregistrer l'analyse</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
