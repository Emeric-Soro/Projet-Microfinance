{% extends 'backoffice.html.twig' %}

{% block title %}Simulation de crédit - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Simulation' }] %}

<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold">Simulation de crédit</h1>
    <p class="text-sm text-on-surface-variant mt-1">Calculez les échéances et le coût total d'un crédit</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-lg border border-gray-200">
        <div class="px-4 py-3 border-b border-gray-200">
            <h3 class="font-semibold text-on-surface">Paramètres de simulation</h3>
        </div>
        <div class="p-4">
            <form method="post" action="{{ path('credit_simulation') }}">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Produit de crédit</label>
                        <select name="produit_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                            <option value="">Sélectionner un produit</option>
                            {% for p in produits %}
                                <option value="{{ p.id }}">{{ p.libelle }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Montant souhaité (FCFA)</label>
                        <input type="number" name="montant" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" min="0" step="1000">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Durée (mois)</label>
                        <input type="number" name="duree" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" min="1" max="360">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Apport personnel (FCFA)</label>
                        <input type="number" name="apport" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" min="0" value="0">
                    </div>
                    <button type="submit" class="w-full px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors text-sm">Simuler</button>
                </div>
            </form>
        </div>
    </div>

    {% if result is not null %}
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-200">
                <h3 class="font-semibold text-on-surface">Résultat de la simulation</h3>
            </div>
            <div class="p-4 space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-sm text-on-surface">Montant financé</span>
                    <span class="text-sm font-semibold">{{ result.montantFinance|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-sm text-on-surface">Taux d'intérêt</span>
                    <span class="text-sm font-semibold">{{ result.taux|default(0) }}%</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-sm text-on-surface">Durée</span>
                    <span class="text-sm font-semibold">{{ result.duree|default(0) }} mois</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-sm text-on-surface">Mensualité</span>
                    <span class="text-sm font-semibold text-teal-600">{{ result.mensualite|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                    <span class="text-sm text-on-surface">Total des intérêts</span>
                    <span class="text-sm font-semibold text-orange-600">{{ result.totalInterets|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="flex justify-between items-center py-2">
                    <span class="text-sm font-semibold text-on-surface">Coût total du crédit</span>
                    <span class="text-sm font-bold text-on-surface">{{ result.coutTotal|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
                <div class="mt-4 pt-3 border-t border-gray-200">
                    <a href="{{ path('credit_request_create') }}" class="w-full inline-block text-center px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Faire une demande</a>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
