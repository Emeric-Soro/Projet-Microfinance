{% extends 'backoffice.html.twig' %}

{% block title %}Produits de crédit - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Produits' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Produits de crédit</h1>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {% for product in products %}
        <div class="bg-white rounded-lg border border-gray-200 p-4 hover:shadow-md transition-shadow">
            <h3 class="font-semibold text-on-surface">{{ product.libelle|default('Produit') }}</h3>
            <p class="text-sm text-on-surface-variant mt-1">{{ product.description|default('') }}</p>
            <div class="mt-3 space-y-1 text-sm">
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Taux</span>
                    <span class="font-medium">{{ product.taux|default(0) }}%</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Durée max</span>
                    <span class="font-medium">{{ product.dureeMax|default(0) }} mois</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-on-surface-variant">Montant max</span>
                    <span class="font-medium">{{ product.montantMax|default(0)|number_format(0, ',', ' ') }} FCFA</span>
                </div>
            </div>
            <div class="mt-3">
                <span class="inline-block px-2 py-0.5 text-xs rounded-full {{ product.statut == 'ACTIF' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' }}">
                    {{ product.statut|default('INACTIF') == 'ACTIF' ? 'Actif' : 'Inactif' }}
                </span>
            </div>
        </div>
    {% else %}
        <div class="col-span-full bg-white rounded-lg border border-gray-200 p-8 text-center">
            <p class="text-on-surface-variant">Aucun produit de crédit trouvé.</p>
        </div>
    {% endfor %}
</div>
{% endblock %}
