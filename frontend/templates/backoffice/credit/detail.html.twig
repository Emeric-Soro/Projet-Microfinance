{% extends 'backoffice.html.twig' %}

{% block title %}Crédit N°{{ credit.id }} - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Crédits actifs', url: path('credit_active') }, { label: 'N°' ~ credit.id }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Crédit N°{{ credit.id }}</h1>
    <div class="flex items-center gap-2">
        <a href="{{ path('credit_repayment', { id: credit.id }) }}" class="px-4 py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors text-sm">Remboursement</a>
        <a href="{{ path('credit_contract', { id: credit.id }) }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-sm">Contrat</a>
        <a href="{{ path('credit_file', { id: credit.id }) }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-sm">Dossier complet</a>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-sm text-on-surface-variant">Montant accordé</p>
        <p class="text-xl font-bold text-on-surface mt-1">{{ credit.montantAccorde|default(0)|number_format(0, ',', ' ') }} FCFA</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-sm text-on-surface-variant">Encours</p>
        <p class="text-xl font-bold text-teal-600 mt-1">{{ credit.encours|default(0)|number_format(0, ',', ' ') }} FCFA</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-sm text-on-surface-variant">Échéances payées</p>
        <p class="text-xl font-bold text-on-surface mt-1">{{ credit.echeancesPayees|default(0) }}/{{ credit.echeancesTotal|default(0) }}</p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
        <p class="text-sm text-on-surface-variant">Statut</p>
        <p class="text-xl font-bold mt-1 {{ credit.statut == 'ACTIF' ? 'text-green-600' : 'text-red-600' }}">{{ credit.statut|default('')|replace({'_': ' '}) }}</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-lg border border-gray-200">
        <div class="px-4 py-3 border-b border-gray-200">
            <h3 class="font-semibold text-on-surface">Informations générales</h3>
        </div>
        <div class="p-4 space-y-2 text-sm">
            <div class="flex justify-between py-1 border-b border-gray-50">
                <span class="text-on-surface-variant">Client</span>
                <span class="font-medium">{{ credit.clientNom|default('') }}</span>
            </div>
            <div class="flex justify-between py-1 border-b border-gray-50">
                <span class="text-on-surface-variant">Produit</span>
                <span class="font-medium">{{ credit.produitLibelle|default('') }}</span>
            </div>
            <div class="flex justify-between py-1 border-b border-gray-50">
                <span class="text-on-surface-variant">Taux d'intérêt</span>
                <span class="font-medium">{{ credit.taux|default(0) }}%</span>
            </div>
            <div class="flex justify-between py-1 border-b border-gray-50">
                <span class="text-on-surface-variant">Durée</span>
                <span class="font-medium">{{ credit.duree|default(0) }} mois</span>
            </div>
            <div class="flex justify-between py-1 border-b border-gray-50">
                <span class="text-on-surface-variant">Date de décaissement</span>
                <span class="font-medium">{{ credit.dateDecaissement|default('')|date('d/m/Y') }}</span>
            </div>
            <div class="flex justify-between py-1">
                <span class="text-on-surface-variant">Date d'échéance finale</span>
                <span class="font-medium">{{ credit.dateEcheanceFinale|default('')|date('d/m/Y') }}</span>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg border border-gray-200">
        <div class="px-4 py-3 border-b border-gray-200">
            <h3 class="font-semibold text-on-surface">Prochaines échéances</h3>
        </div>
        <div class="p-4">
            {% if echeances is not empty %}
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-left text-on-surface-variant border-b border-gray-100">
                            <th class="pb-2">N°</th>
                            <th class="pb-2">Date</th>
                            <th class="pb-2">Montant</th>
                            <th class="pb-2">Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for e in echeances|slice(0, 5) %}
                            <tr class="border-b border-gray-50">
                                <td class="py-2">{{ e.numero|default('') }}</td>
                                <td class="py-2">{{ e.dateEcheance|default('')|date('d/m/Y') }}</td>
                                <td class="py-2">{{ e.montant|default(0)|number_format(0, ',', ' ') }}</td>
                                <td class="py-2">
                                    <span class="inline-block px-2 py-0.5 text-xs rounded-full {{ e.statut == 'PAYEE' ? 'bg-green-100 text-green-800' : e.statut == 'IMPAYEE' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' }}">
                                        {{ e.statut|default('EN_ATTENTE')|replace({'_': ' '}) }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="mt-3 text-center">
                    <a href="{{ path('credit_schedule', { id: credit.id }) }}" class="text-sm text-teal-600 hover:text-teal-800">Voir tout l'échéancier</a>
                </div>
            {% else %}
                <p class="text-sm text-on-surface-variant text-center py-4">Aucune échéance trouvée.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
