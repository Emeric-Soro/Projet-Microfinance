{% extends 'backoffice.html.twig' %}

{% block title %}Impayés - MicroFin{% endblock %}

{% block backoffice_content %}
{% set breadcrumbs = [{ label: 'Crédit', url: path('credit_dashboard') }, { label: 'Impayés' }] %}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-heading font-bold">Impayés</h1>
    <a href="{{ path('credit_provisions') }}" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors text-sm">Provisions</a>
</div>

<div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-gray-50 text-left">
                <th class="px-4 py-3 font-medium text-on-surface-variant">N° crédit</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Client</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Encours</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Arriéré</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Jours d'impayé</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Tranche</th>
                <th class="px-4 py-3 font-medium text-on-surface-variant">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for imp in impayes %}
                <tr class="border-t border-gray-100 hover:bg-gray-50 {{ imp.joursImpaye|default(0) > 90 ? 'bg-red-50' : imp.joursImpaye|default(0) > 30 ? 'bg-yellow-50' : '' }}">
                    <td class="px-4 py-3 font-medium">{{ imp.id }}</td>
                    <td class="px-4 py-3">{{ imp.clientNom|default('') }}</td>
                    <td class="px-4 py-3">{{ imp.encours|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="px-4 py-3 font-semibold text-red-600">{{ imp.arriere|default(0)|number_format(0, ',', ' ') }}</td>
                    <td class="px-4 py-3">{{ imp.joursImpaye|default(0) }} jours</td>
                    <td class="px-4 py-3">
                        <span class="inline-block px-2 py-0.5 text-xs rounded-full {{ imp.tranche == '1-30' ? 'bg-yellow-100 text-yellow-800' : imp.tranche == '31-90' ? 'bg-orange-100 text-orange-800' : 'bg-red-100 text-red-800' }}">
                            {{ imp.tranche|default('') }}
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                            <a href="{{ path('credit_recovery', { id: imp.id }) }}" class="text-teal-600 hover:text-teal-800 text-xs">Recouvrement</a>
                            <a href="{{ path('credit_litigation', { id: imp.id }) }}" class="text-teal-600 hover:text-teal-800 text-xs">Contentieux</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="px-4 py-8 text-center text-on-surface-variant">Aucun impayé trouvé.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
