{% extends 'backoffice.html.twig' %}

{% block title %}Relevé guichetier - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Relevé de guichetier</h1>
    <p class="text-sm text-on-surface-variant mt-1">Guichet: {{ guichet.libelle }}</p>
</div>

<div class="bg-white rounded-lg shadow-card border border-teal-100 p-4 mb-6">
    <form method="get" class="flex items-end gap-4">
        {% include component('MfDatePicker') with { name: 'date_debut', label: 'Date début' } %}
        {% include component('MfDatePicker') with { name: 'date_fin', label: 'Date fin' } %}
        <button type="submit" class="mf-btn-primary">Filtrer</button>
    </form>
</div>

{% embed component('MfCard') with { title: 'Récapitulatif' } %}
    {% block card_content %}
        {% embed component('MfStatsGrid') with { cols: 3, stats: [
            { label: 'Total dépôts', value: statement.totalDepots|default(0)|montant, icon: 'M12 4v16m8-8H4', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
            { label: 'Total retraits', value: statement.totalRetraits|default(0)|montant, icon: 'M20 12H4', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
            { label: 'Solde net', value: (statement.totalDepots|default(0) - statement.totalRetraits|default(0))|montant, icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3', icon_bg: 'bg-teal-50', icon_color: 'text-teal-600' },
        ]} %}
            {% block card_content %}
                {{ parent() }}
            {% endblock %}
        {% endembed %}
    {% endblock %}
{% endembed %}

{% embed component('MfDataTable') with { headers: [
    { key: 'date', label: 'Date', sortable: true },
    { key: 'reference', label: 'Référence' },
    { key: 'type', label: 'Type' },
    { key: 'montant', label: 'Montant', sortable: true },
    { key: 'soldeApres', label: 'Solde après' },
], rows: statement.operations|default([]), class: 'mt-6', empty_title: 'Aucune opération', empty_message: 'Aucune opération pour cette période.' } %}
    {% block card_content %}
        {{ parent() }}
    {% endblock %}
{% endembed %}
{% endblock %}
