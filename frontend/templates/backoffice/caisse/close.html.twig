{% extends 'backoffice.html.twig' %}

{% block title %}Fermeture caisse - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Fermeture de session</h1>
    <p class="text-sm text-on-surface-variant mt-1">Guichet: {{ session.guichet }}</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        {% embed component('MfCard') with { title: 'Détails de la session' } %}
            {% block card_content %}
                <dl class="divide-y divide-gray-100">
                    {% include component('MfDetailRow') with { label: 'Guichet', value: session.guichet } %}
                    {% include component('MfDetailRow') with { label: 'Date ouverture', value: session.dateOuverture|date_fr } %}
                    {% include component('MfDetailRow') with { label: 'Solde initial', value: session.soldeInitial|montant } %}
                    {% include component('MfDetailRow') with { label: 'Solde actuel', value: session.soldeActuel|montant } %}
                </dl>
            {% endblock %}
        {% endembed %}

        {% embed component('MfFormCard') with { title: 'Fermeture', description: 'Saisissez le solde de clôture', class: 'mt-6' } %}
            {% block form_fields %}
                <div class="space-y-4">
                    {% include component('MfMoneyInput') with { name: 'solde_final', label: 'Solde final', required: true, value: session.soldeActuel } %}
                    {% include component('MfInput') with { name: 'observations', label: 'Observations' } %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>

    <div class="lg:col-span-1">
        {% embed component('MfCard') with { title: 'Vérifications' } %}
            {% block card_content %}
                <div class="text-sm text-on-surface-variant space-y-3">
                    <p>Assurez-vous d'avoir effectué le billetage avant la fermeture.</p>
                    <p>Vérifiez qu'il n'y a pas d'opérations en attente.</p>
                    {% include component('MfAlertBanner') with { type: 'warning', message: 'Une fois fermée, la session ne peut plus être modifiée.' } %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>
</div>
{% endblock %}
