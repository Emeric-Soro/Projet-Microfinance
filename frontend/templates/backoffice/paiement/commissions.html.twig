{% extends 'backoffice.html.twig' %}

{% block title %}Commissions{% endblock %}
{% block current_menu %}paiements_commissions{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <div class="lg:col-span-1">
        {% embed 'components/MfCard.html.twig' with {title: 'Calculer les commissions'} %}
            {% block card_content %}
                <form method="post" action="{{ path('paiements_commissions_calculer') }}" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Période</label>
                        <select name="periode" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="JOURNALIER">Journalier</option>
                            <option value="HEBDOMADAIRE">Hebdomadaire</option>
                            <option value="MENSUEL">Mensuel</option>
                            <option value="TRIMESTRIEL">Trimestriel</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Date début</label>
                        <input type="date" name="dateDebut" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Date fin</label>
                        <input type="date" name="dateFin" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Type commission</label>
                        <select name="type" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="TOUTES">Toutes</option>
                            <option value="VIREMENT">Virement</option>
                            <option value="CARTE">Carte</option>
                            <option value="CHEQUE">Chèque</option>
                            <option value="MOBILE_MONEY">Mobile Money</option>
                            <option value="DAB">DAB</option>
                        </select>
                    </div>
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <button type="submit" class="mf-btn-primary">Calculer</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}

        {% if calculation_result is defined %}
            {% embed 'components/MfSummaryCard.html.twig' with {title: 'Résultat du calcul', items: [
                {label: 'Total commissions', value: calculation_result.total|default(0)|number_format(0, ',', ' ') ~ ' FCFA'},
                {label: 'Nombre transactions', value: calculation_result.nbTransactions|default(0)},
                {label: 'Commission moyenne', value: calculation_result.moyenne|default(0)|number_format(0, ',', ' ') ~ ' FCFA'},
                {label: 'Période', value: calculation_result.periode|default('-')},
            ]} %}{% endembed %}
        {% endif %}
    </div>

    <div class="lg:col-span-3">
        {% embed 'components/MfCard.html.twig' with {title: 'Commissions'} %}
            {% block card_content %}
                {% include 'partials/_table_toolbar.html.twig' with {
                    search_placeholder: 'Rechercher...',
                    filters: [
                        {label: 'Type', options: [
                            {value: 'VIREMENT', label: 'Virement'},
                            {value: 'CARTE', label: 'Carte'},
                            {value: 'CHEQUE', label: 'Chèque'},
                            {value: 'MOBILE_MONEY', label: 'Mobile Money'},
                        ]}
                    ]
                } %}
                {% embed 'components/MfDataTable.html.twig' with {
                    headers: [
                        {key: 'id', label: 'N°'},
                        {key: 'type', label: 'Type'},
                        {key: 'transaction', label: 'Transaction'},
                        {key: 'montantTransaction', label: 'Mt transaction'},
                        {key: 'montantCommission', label: 'Commission'},
                        {key: 'taux', label: 'Taux'},
                        {key: 'dateCalcul', label: 'Date calcul'},
                        {key: 'statut', label: 'Statut'},
                    ],
                    rows: commissions
                } %}
                    {% block card_content %}
                        {% for commission in commissions %}
                            <tr>
                                <td>{{ commission.id }}</td>
                                <td>{{ commission.type }}</td>
                                <td>#{{ commission.transaction }}</td>
                                <td>{{ commission.montantTransaction|number_format(0, ',', ' ') }} FCFA</td>
                                <td class="font-medium text-primary">{{ commission.montantCommission|number_format(0, ',', ' ') }} FCFA</td>
                                <td>{{ commission.taux }}%</td>
                                <td>{{ commission.dateCalcul|date('d/m/Y') }}</td>
                                <td>{% include 'components/MfStatusBadge.html.twig' with {status: commission.statut} %}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center py-8">
                                    {% include 'partials/_empty_state.html.twig' with {title: 'Aucune commission', message: 'Aucune commission trouvée.'} %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>
</div>
{% endblock %}
