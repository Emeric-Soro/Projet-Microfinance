{% extends 'backoffice.html.twig' %}

{% block title %}Plafonds{% endblock %}
{% block current_menu %}paiements_plafonds{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 {% if edit_mode is defined and edit_mode %}lg:grid-cols-3{% endif %} gap-6">
    <div class="{% if edit_mode is defined and edit_mode %}lg:col-span-2{% else %}lg:col-span-3{% endif %}">
        {% embed 'components/MfCard.html.twig' with {title: 'Plafonds de paiement'} %}
            {% block card_content %}
                {% include 'partials/_table_toolbar.html.twig' with {
                    search_placeholder: 'Rechercher un plafond...',
                    filters: [
                        {label: 'Type', options: [
                            {value: 'VIREMENT', label: 'Virement'},
                            {value: 'CARTE', label: 'Carte'},
                            {value: 'CHEQUE', label: 'Chèque'},
                            {value: 'DAB', label: 'DAB'},
                            {value: 'MOBILE_MONEY', label: 'Mobile Money'},
                        ]}
                    ]
                } %}
                {% embed 'components/MfDataTable.html.twig' with {
                    headers: [
                        {key: 'id', label: 'N°'},
                        {key: 'type', label: 'Type'},
                        {key: 'profil', label: 'Profil'},
                        {key: 'plafondJournalier', label: 'Journalier'},
                        {key: 'plafondHebdomadaire', label: 'Hebdomadaire'},
                        {key: 'plafondMensuel', label: 'Mensuel'},
                        {key: 'plafondTransaction', label: 'Par transaction'},
                        {key: 'actions', label: 'Actions'},
                    ],
                    rows: plafonds
                } %}
                    {% block card_content %}
                        {% for plafond in plafonds %}
                            <tr>
                                <td>{{ plafond.id }}</td>
                                <td>{{ plafond.type }}</td>
                                <td class="font-medium">{{ plafond.profil }}</td>
                                <td>{{ plafond.plafondJournalier|number_format(0, ',', ' ') }} FCFA</td>
                                <td>{{ plafond.plafondHebdomadaire|number_format(0, ',', ' ') }} FCFA</td>
                                <td>{{ plafond.plafondMensuel|number_format(0, ',', ' ') }} FCFA</td>
                                <td>{{ plafond.plafondTransaction|number_format(0, ',', ' ') }} FCFA</td>
                                <td class="text-right">
                                    <a href="{{ path('paiements_plafonds_edit', {id: plafond.id}) }}" class="text-sm text-primary hover:text-primary-600">Modifier</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center py-8">
                                    {% include 'partials/_empty_state.html.twig' with {title: 'Aucun plafond', message: 'Aucun plafond configuré.'} %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>

    {% if edit_mode is defined and edit_mode and plafond is defined %}
    <div>
        {% embed 'components/MfCard.html.twig' with {title: 'Modifier le plafond'} %}
            {% block card_content %}
                <div class="space-y-4 mb-4">
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Type', value: plafond.type} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Profil', value: plafond.profil} %}{% endembed %}
                </div>
                <form method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Plafond journalier (FCFA)</label>
                        <input type="number" name="plafondJournalier" value="{{ plafond.plafondJournalier }}" step="0.01" min="0" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Plafond hebdomadaire (FCFA)</label>
                        <input type="number" name="plafondHebdomadaire" value="{{ plafond.plafondHebdomadaire }}" step="0.01" min="0" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Plafond mensuel (FCFA)</label>
                        <input type="number" name="plafondMensuel" value="{{ plafond.plafondMensuel }}" step="0.01" min="0" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Plafond par transaction (FCFA)</label>
                        <input type="number" name="plafondTransaction" value="{{ plafond.plafondTransaction }}" step="0.01" min="0" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <a href="{{ path('paiements_plafonds') }}" class="mf-btn-secondary">Annuler</a>
                        <button type="submit" class="mf-btn-primary">Mettre à jour</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}
    </div>
    {% endif %}
</div>
{% endblock %}
