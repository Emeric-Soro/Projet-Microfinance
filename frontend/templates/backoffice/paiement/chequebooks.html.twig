{% extends 'backoffice.html.twig' %}

{% block title %}Carnets de chèques{% endblock %}
{% block current_menu %}paiements_cheques{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

{% embed 'components/MfCard.html.twig' with {title: 'Carnets de chèques', action: {url: path('paiements_cheques_carnets_create'), label: 'Nouveau carnet'}} %}
    {% block card_content %}
        {% include 'partials/_table_toolbar.html.twig' with {
            search_placeholder: 'Rechercher un carnet...',
            action_button: {url: path('paiements_cheques_carnets_create'), label: 'Nouveau carnet'}
        } %}

        {% embed 'components/MfDataTable.html.twig' with {
            headers: [
                {key: 'id', label: 'N°', sortable: true},
                {key: 'numeroCarnet', label: 'Numéro carnet'},
                {key: 'compte', label: 'Compte'},
                {key: 'nbCheques', label: 'Nb chèques'},
                {key: 'chequesRestants', label: 'Restants'},
                {key: 'statut', label: 'Statut'},
                {key: 'dateCreation', label: 'Date création'},
            ],
            rows: carnets,
            actions: [
                {label: 'Détails', url: function(row) { return '#'; }, icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'},
            ]
        } %}
            {% block card_content %}
                {% for carnet in carnets %}
                    <tr>
                        <td>{{ carnet.id }}</td>
                        <td class="font-medium">{{ carnet.numeroCarnet }}</td>
                        <td>{{ carnet.compte }}</td>
                        <td>{{ carnet.nbCheques }}</td>
                        <td>{{ carnet.chequesRestants }}</td>
                        <td>{% include 'components/MfStatusBadge.html.twig' with {status: carnet.statut} %}</td>
                        <td>{{ carnet.dateCreation|date('d/m/Y') }}</td>
                        <td class="text-right">
                            <a href="#" class="text-sm text-primary hover:text-primary-600" title="Voir">
                                <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-8">
                            {% include 'partials/_empty_state.html.twig' with {title: 'Aucun carnet', message: 'Aucun carnet de chèques trouvé.'} %}
                        </td>
                    </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}
    {% endblock %}
{% endembed %}
{% endblock %}
