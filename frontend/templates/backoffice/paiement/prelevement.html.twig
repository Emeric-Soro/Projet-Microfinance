{% extends 'backoffice.html.twig' %}

{% block title %}Prélèvements{% endblock %}
{% block current_menu %}paiements_prelevements{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 {% if manage_mode is defined and manage_mode %}lg:grid-cols-3{% endif %} gap-6">
    <div class="{% if manage_mode is defined and manage_mode %}lg:col-span-2{% else %}lg:col-span-3{% endif %}">
        {% embed 'components/MfCard.html.twig' with {title: 'Prélèvements'} %}
            {% block card_content %}
                {% include 'partials/_table_toolbar.html.twig' with {
                    search_placeholder: 'Rechercher un prélèvement...',
                    filters: [
                        {label: 'Statut', options: [
                            {value: 'ACTIF', label: 'Actif'},
                            {value: 'SUSPENDU', label: 'Suspendu'},
                            {value: 'RESILIE', label: 'Résilié'},
                            {value: 'EN_ATTENTE', label: 'En attente'},
                        ]}
                    ]
                } %}
                {% embed 'components/MfDataTable.html.twig' with {
                    headers: [
                        {key: 'id', label: 'N°'},
                        {key: 'client', label: 'Client'},
                        {key: 'compteDebiteur', label: 'Compte'},
                        {key: 'montant', label: 'Montant'},
                        {key: 'frequence', label: 'Fréquence'},
                        {key: 'dateDebut', label: 'Début'},
                        {key: 'prochaineDate', label: 'Prochaine'},
                        {key: 'statut', label: 'Statut'},
                        {key: 'actions', label: 'Actions'},
                    ],
                    rows: prelevements
                } %}
                    {% block card_content %}
                        {% for prelevement in prelevements %}
                            <tr>
                                <td>{{ prelevement.id }}</td>
                                <td class="font-medium">{{ prelevement.client }}</td>
                                <td>{{ prelevement.compteDebiteur }}</td>
                                <td>{{ prelevement.montant|number_format(0, ',', ' ') }} FCFA</td>
                                <td>{{ prelevement.frequence }}</td>
                                <td>{{ prelevement.dateDebut|date('d/m/Y') }}</td>
                                <td>{{ prelevement.prochaineDate|date('d/m/Y') }}</td>
                                <td>{% include 'components/MfStatusBadge.html.twig' with {status: prelevement.statut} %}</td>
                                <td class="text-right">
                                    <a href="{{ path('paiements_prelevements_manage', {id: prelevement.id}) }}" class="text-sm text-primary hover:text-primary-600">Gérer</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center py-8">
                                    {% include 'partials/_empty_state.html.twig' with {title: 'Aucun prélèvement', message: 'Aucun prélèvement trouvé.'} %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>

    {% if manage_mode is defined and manage_mode and prelevement is defined %}
    <div>
        {% embed 'components/MfCard.html.twig' with {title: 'Gérer le prélèvement'} %}
            {% block card_content %}
                <div class="space-y-4 mb-4">
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Client', value: prelevement.client} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Montant', value: prelevement.montant|number_format(0, ',', ' ') ~ ' FCFA'} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Fréquence', value: prelevement.frequence} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Statut', value: ''} %}
                        {% block card_content %}
                            <dd class="w-2/3">{% include 'components/MfStatusBadge.html.twig' with {status: prelevement.statut} %}</dd>
                        {% endblock %}
                    {% endembed %}
                </div>
                <form method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Montant</label>
                        <input type="number" name="montant" value="{{ prelevement.montant }}" step="0.01" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Fréquence</label>
                        <select name="frequence" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="MENSUEL" {{ prelevement.frequence == 'MENSUEL' ? 'selected' : '' }}>Mensuel</option>
                            <option value="HEBDOMADAIRE" {{ prelevement.frequence == 'HEBDOMADAIRE' ? 'selected' : '' }}>Hebdomadaire</option>
                            <option value="TRIMESTRIEL" {{ prelevement.frequence == 'TRIMESTRIEL' ? 'selected' : '' }}>Trimestriel</option>
                            <option value="ANNUEL" {{ prelevement.frequence == 'ANNUEL' ? 'selected' : '' }}>Annuel</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Statut</label>
                        <select name="statut" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="ACTIF" {{ prelevement.statut == 'ACTIF' ? 'selected' : '' }}>Actif</option>
                            <option value="SUSPENDU" {{ prelevement.statut == 'SUSPENDU' ? 'selected' : '' }}>Suspendu</option>
                            <option value="RESILIE" {{ prelevement.statut == 'RESILIE' ? 'selected' : '' }}>Résilié</option>
                        </select>
                    </div>
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <a href="{{ path('paiements_prelevements') }}" class="mf-btn-secondary">Annuler</a>
                        <button type="submit" class="mf-btn-primary">Mettre à jour</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}
    </div>
    {% endif %}
</div>
{% endblock %}
