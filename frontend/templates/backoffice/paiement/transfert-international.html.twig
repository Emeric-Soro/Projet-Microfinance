{% extends 'backoffice.html.twig' %}

{% block title %}Transferts internationaux{% endblock %}
{% block current_menu %}paiements_transferts_internationaux{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

{% embed 'components/MfStatsGrid.html.twig' with {stats: [
    {label: 'En attente', value: stats.enAttente|default(0), icon: 'M12 9v2m0 4h.01', icon_bg: 'bg-yellow-50', icon_color: 'text-yellow-600'},
    {label: 'Traités', value: stats.traites|default(0), icon: 'M9 12l2 2 4-4', icon_bg: 'bg-green-50', icon_color: 'text-green-600'},
    {label: 'Volume total', value: (stats.volumeTotal|default(0))|number_format(0, ',', ' ') ~ ' FCFA', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1', icon_bg: 'bg-blue-50', icon_color: 'text-blue-600'},
    {label: 'Devises', value: stats.devises|default(0), icon: 'M9 8h6m-6 4h6m-6 4h6', icon_bg: 'bg-primary-50', icon_color: 'text-primary'},
]} %}{% endembed %}

{% if create_mode is defined and create_mode %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
    <div class="lg:col-span-1">
        {% embed 'components/MfCard.html.twig' with {title: 'Nouveau transfert international'} %}
            {% block card_content %}
                <form method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Compte à débiter</label>
                        <select name="compteDebiteurId" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="">Sélectionner un compte</option>
                            {% if comptes is defined %}
                                {% for compte in comptes %}
                                    <option value="{{ compte.id }}">{{ compte.numeroCompte }}</option>
                                {% endfor %}
                            {% endif %}
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Pays destinataire</label>
                        <input type="text" name="paysDestinataire" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Banque destinataire</label>
                        <input type="text" name="banqueDestinataire" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Code SWIFT/BIC</label>
                        <input type="text" name="codeSwift" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200 font-mono uppercase">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Compte destinataire</label>
                        <input type="text" name="compteDestinataire" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Montant</label>
                        <input type="number" name="montant" required step="0.01" min="0" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Devise</label>
                        <select name="devise" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="">Sélectionner une devise</option>
                            {% if devises is defined %}
                                {% for devise in devises %}
                                    <option value="{{ devise.code }}">{{ devise.code }} - {{ devise.libelle }}</option>
                                {% endfor %}
                            {% endif %}
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Motif du transfert</label>
                        <textarea name="motif" rows="2" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200"></textarea>
                    </div>
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <a href="{{ path('paiements_transferts_internationaux') }}" class="mf-btn-secondary">Annuler</a>
                        <button type="submit" class="mf-btn-primary">Envoyer le transfert</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}
    </div>
    <div class="lg:col-span-2">
{% else %}
<div class="mt-6">
{% endif %}

    {% embed 'components/MfCard.html.twig' with {title: 'Transferts internationaux', action: {url: path('paiements_transferts_internationaux_create'), label: 'Nouveau transfert'}} %}
        {% block card_content %}
            {% include 'partials/_table_toolbar.html.twig' with {
                search_placeholder: 'Rechercher un transfert...',
                filters: [
                    {label: 'Statut', options: [
                        {value: 'EN_ATTENTE', label: 'En attente'},
                        {value: 'TRAITE', label: 'Traité'},
                        {value: 'REJETE', label: 'Rejeté'},
                    ]}
                ]
            } %}
            {% embed 'components/MfDataTable.html.twig' with {
                headers: [
                    {key: 'id', label: 'N°'},
                    {key: 'date', label: 'Date'},
                    {key: 'compteDebiteur', label: 'Compte débiteur'},
                    {key: 'paysDestinataire', label: 'Pays'},
                    {key: 'montant', label: 'Montant'},
                    {key: 'devise', label: 'Devise'},
                    {key: 'statut', label: 'Statut'},
                    {key: 'actions', label: 'Actions'},
                ],
                rows: transferts
            } %}
                {% block card_content %}
                    {% for transfert in transferts %}
                        <tr>
                            <td>{{ transfert.id }}</td>
                            <td>{{ transfert.date|date('d/m/Y') }}</td>
                            <td>{{ transfert.compteDebiteur }}</td>
                            <td>{{ transfert.paysDestinataire }}</td>
                            <td class="font-medium">{{ transfert.montant|number_format(0, ',', ' ') }}</td>
                            <td>{{ transfert.devise }}</td>
                            <td>{% include 'components/MfStatusBadge.html.twig' with {status: transfert.statut} %}</td>
                            <td class="text-right">
                                <a href="#" class="text-sm text-primary hover:text-primary-600">Détails</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="text-center py-8">
                                {% include 'partials/_empty_state.html.twig' with {title: 'Aucun transfert', message: 'Aucun transfert international trouvé.'} %}
                            </td>
                        </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}
        {% endblock %}
    {% endembed %}

{% if create_mode is defined and create_mode %}
    </div>
</div>
{% endif %}
{% endblock %}
