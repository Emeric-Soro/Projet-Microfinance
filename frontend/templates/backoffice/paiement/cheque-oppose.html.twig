{% extends 'backoffice.html.twig' %}

{% block title %}Opposition chèques{% endblock %}
{% block current_menu %}paiements_cheques{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
    <div class="lg:col-span-2">
        {% embed 'components/MfCard.html.twig' with {title: 'Nouvelle opposition'} %}
            {% block card_content %}
                <form method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Numéro de chèque</label>
                        <input type="text" name="numeroCheque" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Motif</label>
                        <select name="motif" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="VOL">Vol</option>
                            <option value="PERTE">Perte</option>
                            <option value="DESTRUCTION">Destruction</option>
                            <option value="FRAUDE">Fraude</option>
                            <option value="AUTRE">Autre</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Description</label>
                        <textarea name="description" rows="3" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200"></textarea>
                    </div>
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <button type="submit" class="mf-btn-primary">Enregistrer l'opposition</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}
    </div>

    <div class="lg:col-span-3">
        {% embed 'components/MfCard.html.twig' with {title: 'Oppositions enregistrées'} %}
            {% block card_content %}
                {% embed 'components/MfDataTable.html.twig' with {
                    headers: [
                        {key: 'id', label: 'N°'},
                        {key: 'numeroCheque', label: 'Chèque'},
                        {key: 'motif', label: 'Motif'},
                        {key: 'dateOpposition', label: 'Date'},
                        {key: 'statut', label: 'Statut'},
                    ],
                    rows: oppositions
                } %}
                    {% block card_content %}
                        {% for opposition in oppositions %}
                            <tr>
                                <td>{{ opposition.id }}</td>
                                <td class="font-medium">{{ opposition.numeroCheque }}</td>
                                <td>{{ opposition.motif }}</td>
                                <td>{{ opposition.dateOpposition|date('d/m/Y H:i') }}</td>
                                <td>{% include 'components/MfStatusBadge.html.twig' with {status: opposition.statut} %}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-8">
                                    {% include 'partials/_empty_state.html.twig' with {title: 'Aucune opposition', message: 'Aucune opposition enregistrée.'} %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>
</div>
{% endblock %}
