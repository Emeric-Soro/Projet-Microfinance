{% extends 'backoffice.html.twig' %}

{% block title %}Abonnements{% endblock %}
{% block current_menu %}paiements_abonnements{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 {% if manage_mode is defined and manage_mode %}lg:grid-cols-3{% endif %} gap-6">
    <div class="{% if manage_mode is defined and manage_mode %}lg:col-span-2{% else %}lg:col-span-3{% endif %}">
        {% embed 'components/MfCard.html.twig' with {title: 'Abonnements'} %}
            {% block card_content %}
                {% include 'partials/_table_toolbar.html.twig' with {
                    search_placeholder: 'Rechercher un abonnement...',
                    filters: [
                        {label: 'Statut', options: [
                            {value: 'ACTIF', label: 'Actif'},
                            {value: 'SUSPENDU', label: 'Suspendu'},
                            {value: 'RESILIE', label: 'Résilié'},
                        ]},
                        {label: 'Type', options: [
                            {value: 'EAU', label: 'Eau'},
                            {value: 'ELECTRICITE', label: 'Électricité'},
                            {value: 'INTERNET', label: 'Internet'},
                            {value: 'TELEPHONE', label: 'Téléphone'},
                            {value: 'AUTRE', label: 'Autre'},
                        ]}
                    ]
                } %}
                {% embed 'components/MfDataTable.html.twig' with {
                    headers: [
                        {key: 'id', label: 'N°'},
                        {key: 'client', label: 'Client'},
                        {key: 'type', label: 'Type'},
                        {key: 'reference', label: 'Référence'},
                        {key: 'montant', label: 'Montant'},
                        {key: 'dateRenouvellement', label: 'Renouvellement'},
                        {key: 'statut', label: 'Statut'},
                        {key: 'actions', label: 'Actions'},
                    ],
                    rows: abonnements
                } %}
                    {% block card_content %}
                        {% for abonnement in abonnements %}
                            <tr>
                                <td>{{ abonnement.id }}</td>
                                <td class="font-medium">{{ abonnement.client }}</td>
                                <td>{{ abonnement.type }}</td>
                                <td class="font-mono text-sm">{{ abonnement.reference }}</td>
                                <td>{{ abonnement.montant|number_format(0, ',', ' ') }} FCFA</td>
                                <td>{{ abonnement.dateRenouvellement|date('d/m/Y') }}</td>
                                <td>{% include 'components/MfStatusBadge.html.twig' with {status: abonnement.statut} %}</td>
                                <td class="text-right">
                                    <a href="{{ path('paiements_abonnements_manage', {id: abonnement.id}) }}" class="text-sm text-primary hover:text-primary-600">Gérer</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center py-8">
                                    {% include 'partials/_empty_state.html.twig' with {title: 'Aucun abonnement', message: 'Aucun abonnement trouvé.'} %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>

    {% if manage_mode is defined and manage_mode and abonnement is defined %}
    <div>
        {% embed 'components/MfCard.html.twig' with {title: 'Gérer l\'abonnement'} %}
            {% block card_content %}
                <div class="space-y-4 mb-4">
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Client', value: abonnement.client} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Type', value: abonnement.type} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Montant', value: abonnement.montant|number_format(0, ',', ' ') ~ ' FCFA'} %}{% endembed %}
                </div>
                <form method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Statut</label>
                        <select name="statut" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="ACTIF" {{ abonnement.statut == 'ACTIF' ? 'selected' : '' }}>Actif</option>
                            <option value="SUSPENDU" {{ abonnement.statut == 'SUSPENDU' ? 'selected' : '' }}>Suspendu</option>
                            <option value="RESILIE" {{ abonnement.statut == 'RESILIE' ? 'selected' : '' }}>Résilié</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Montant (FCFA)</label>
                        <input type="number" name="montant" value="{{ abonnement.montant }}" step="0.01" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <a href="{{ path('paiements_abonnements') }}" class="mf-btn-secondary">Annuler</a>
                        <button type="submit" class="mf-btn-primary">Mettre à jour</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}
    </div>
    {% endif %}
</div>
{% endblock %}
