{% extends 'backoffice.html.twig' %}

{% block title %}Partenaires{% endblock %}
{% block current_menu %}paiements_partenaires{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 {% if create_mode is defined or edit_mode is defined %}lg:grid-cols-3{% endif %} gap-6">
    <div class="{% if create_mode is defined or edit_mode is defined %}lg:col-span-2{% else %}lg:col-span-3{% endif %}">
        {% embed 'components/MfCard.html.twig' with {title: 'Partenaires', action: {url: path('paiements_partenaires_create'), label: 'Nouveau partenaire'}} %}
            {% block card_content %}
                {% include 'partials/_table_toolbar.html.twig' with {
                    search_placeholder: 'Rechercher un partenaire...',
                    filters: [
                        {label: 'Statut', options: [
                            {value: 'ACTIF', label: 'Actif'},
                            {value: 'INACTIF', label: 'Inactif'},
                            {value: 'SUSPENDU', label: 'Suspendu'},
                        ]},
                        {label: 'Type', options: [
                            {value: 'BANQUE', label: 'Banque'},
                            {value: 'FINTECH', label: 'Fintech'},
                            {value: 'TELECOM', label: 'Télécom'},
                            {value: 'AUTRE', label: 'Autre'},
                        ]}
                    ]
                } %}
                {% embed 'components/MfDataTable.html.twig' with {
                    headers: [
                        {key: 'id', label: 'N°'},
                        {key: 'nom', label: 'Nom'},
                        {key: 'type', label: 'Type'},
                        {key: 'contact', label: 'Contact'},
                        {key: 'email', label: 'Email'},
                        {key: 'statut', label: 'Statut'},
                        {key: 'actions', label: 'Actions'},
                    ],
                    rows: partenaires
                } %}
                    {% block card_content %}
                        {% for partenaire in partenaires %}
                            <tr>
                                <td>{{ partenaire.id }}</td>
                                <td class="font-medium">{{ partenaire.nom }}</td>
                                <td>
                                    <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                                        {{ partenaire.type }}
                                    </span>
                                </td>
                                <td>{{ partenaire.contact }}</td>
                                <td class="text-sm">{{ partenaire.email }}</td>
                                <td>{% include 'components/MfStatusBadge.html.twig' with {status: partenaire.statut} %}</td>
                                <td class="text-right">
                                    <a href="{{ path('paiements_partenaires_edit', {id: partenaire.id}) }}" class="text-sm text-primary hover:text-primary-600">Modifier</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-8">
                                    {% include 'partials/_empty_state.html.twig' with {title: 'Aucun partenaire', message: 'Aucun partenaire trouvé.', action_url: path('paiements_partenaires_create'), action_label: 'Ajouter un partenaire'} %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>

    {% if create_mode is defined or edit_mode is defined %}
    <div>
        {% embed 'components/MfCard.html.twig' with {title: edit_mode is defined ? 'Modifier le partenaire' : 'Nouveau partenaire'} %}
            {% block card_content %}
                <form method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Nom</label>
                        <input type="text" name="nom" value="{{ partenaire.nom|default('') }}" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Type</label>
                        <select name="type" required class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="BANQUE" {{ partenaire.type|default('') == 'BANQUE' ? 'selected' : '' }}>Banque</option>
                            <option value="FINTECH" {{ partenaire.type|default('') == 'FINTECH' ? 'selected' : '' }}>Fintech</option>
                            <option value="TELECOM" {{ partenaire.type|default('') == 'TELECOM' ? 'selected' : '' }}>Télécom</option>
                            <option value="AUTRE" {{ partenaire.type|default('') == 'AUTRE' ? 'selected' : '' }}>Autre</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Contact</label>
                        <input type="text" name="contact" value="{{ partenaire.contact|default('') }}" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Email</label>
                        <input type="email" name="email" value="{{ partenaire.email|default('') }}" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Adresse</label>
                        <textarea name="adresse" rows="2" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">{{ partenaire.adresse|default('') }}</textarea>
                    </div>
                    {% if edit_mode is defined %}
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Statut</label>
                        <select name="statut" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="ACTIF" {{ partenaire.statut|default('') == 'ACTIF' ? 'selected' : '' }}>Actif</option>
                            <option value="INACTIF" {{ partenaire.statut|default('') == 'INACTIF' ? 'selected' : '' }}>Inactif</option>
                            <option value="SUSPENDU" {{ partenaire.statut|default('') == 'SUSPENDU' ? 'selected' : '' }}>Suspendu</option>
                        </select>
                    </div>
                    {% endif %}
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <a href="{{ path('paiements_partenaires') }}" class="mf-btn-secondary">Annuler</a>
                        <button type="submit" class="mf-btn-primary">{{ edit_mode is defined ? 'Mettre à jour' : 'Créer' }}</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}
    </div>
    {% endif %}
</div>
{% endblock %}
