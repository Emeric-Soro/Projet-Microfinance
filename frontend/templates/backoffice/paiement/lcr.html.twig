{% extends 'backoffice.html.twig' %}

{% block title %}Lettres de Change Relevé (LCR){% endblock %}
{% block current_menu %}paiements_lcr{% endblock %}

{% block backoffice_content %}
{% include 'partials/_breadcrumb.html.twig' with {breadcrumbs: breadcrumbs} %}

<div class="grid grid-cols-1 {% if manage_mode is defined and manage_mode %}lg:grid-cols-3{% endif %} gap-6">
    <div class="{% if manage_mode is defined and manage_mode %}lg:col-span-2{% else %}lg:col-span-3{% endif %}">
        {% embed 'components/MfCard.html.twig' with {title: 'Lettres de Change Relevé'} %}
            {% block card_content %}
                {% include 'partials/_table_toolbar.html.twig' with {
                    search_placeholder: 'Rechercher une LCR...',
                    filters: [
                        {label: 'Statut', options: [
                            {value: 'EN_ATTENTE', label: 'En attente'},
                            {value: 'PAYEE', label: 'Payée'},
                            {value: 'IMPAYEE', label: 'Impayée'},
                            {value: 'REJETEE', label: 'Rejetée'},
                        ]}
                    ]
                } %}
                {% embed 'components/MfDataTable.html.twig' with {
                    headers: [
                        {key: 'id', label: 'N°'},
                        {key: 'reference', label: 'Référence'},
                        {key: 'tireur', label: 'Tireur'},
                        {key: 'tire', label: 'Tiré'},
                        {key: 'montant', label: 'Montant'},
                        {key: 'dateEcheance', label: 'Échéance'},
                        {key: 'statut', label: 'Statut'},
                        {key: 'actions', label: 'Actions'},
                    ],
                    rows: lcrs
                } %}
                    {% block card_content %}
                        {% for lcr in lcrs %}
                            <tr>
                                <td>{{ lcr.id }}</td>
                                <td class="font-mono text-sm">{{ lcr.reference }}</td>
                                <td>{{ lcr.tireur }}</td>
                                <td>{{ lcr.tire }}</td>
                                <td class="font-medium">{{ lcr.montant|number_format(0, ',', ' ') }} FCFA</td>
                                <td>{{ lcr.dateEcheance|date('d/m/Y') }}</td>
                                <td>{% include 'components/MfStatusBadge.html.twig' with {status: lcr.statut} %}</td>
                                <td class="text-right">
                                    <a href="{{ path('paiements_lcr_manage', {id: lcr.id}) }}" class="text-sm text-primary hover:text-primary-600">Gérer</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center py-8">
                                    {% include 'partials/_empty_state.html.twig' with {title: 'Aucune LCR', message: 'Aucune lettre de change relevé trouvée.'} %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}
            {% endblock %}
        {% endembed %}
    </div>

    {% if manage_mode is defined and manage_mode and lcr is defined %}
    <div>
        {% embed 'components/MfCard.html.twig' with {title: 'Gérer la LCR'} %}
            {% block card_content %}
                <div class="space-y-4 mb-4">
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Référence', value: lcr.reference} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Montant', value: lcr.montant|number_format(0, ',', ' ') ~ ' FCFA'} %}{% endembed %}
                    {% embed 'components/MfDetailRow.html.twig' with {label: 'Échéance', value: lcr.dateEcheance|date('d/m/Y')} %}{% endembed %}
                </div>
                <form method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Statut</label>
                        <select name="statut" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
                            <option value="EN_ATTENTE" {{ lcr.statut == 'EN_ATTENTE' ? 'selected' : '' }}>En attente</option>
                            <option value="PAYEE" {{ lcr.statut == 'PAYEE' ? 'selected' : '' }}>Payée</option>
                            <option value="IMPAYEE" {{ lcr.statut == 'IMPAYEE' ? 'selected' : '' }}>Impayée</option>
                            <option value="REJETEE" {{ lcr.statut == 'REJETEE' ? 'selected' : '' }}>Rejetée</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Commentaire</label>
                        <textarea name="commentaire" rows="3" class="w-full px-3 py-2 border border-gray-200 rounded text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">{{ lcr.commentaire|default('') }}</textarea>
                    </div>
                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                        <a href="{{ path('paiements_lcr') }}" class="mf-btn-secondary">Annuler</a>
                        <button type="submit" class="mf-btn-primary">Mettre à jour</button>
                    </div>
                </form>
            {% endblock %}
        {% endembed %}
    </div>
    {% endif %}
</div>
{% endblock %}
