{% extends 'backoffice.html.twig' %}

{% block backoffice_content %}
<div class="mf-card p-0 overflow-hidden">
    <div class="p-6 border-b border-teal-100">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
                <h2 class="text-xl font-heading font-semibold text-on-surface">Comptes — {{ agence.nom|default('Agence') }}</h2>
                <p class="text-sm text-on-surface-variant mt-1">{{ total_items }} compte(s) dans cette agence</p>
            </div>
            <div class="flex items-center gap-2">
                <a href="{{ path('account_list') }}" class="mf-btn-secondary flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                    Tous les comptes
                </a>
                <a href="{{ path('account_open') }}" class="mf-btn-primary flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Nouveau compte
                </a>
            </div>
        </div>
    </div>

    {% if agence is defined %}
    <div class="p-6 border-b border-teal-100 bg-surface">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-white rounded p-3 border border-teal-100">
                <p class="text-xs text-on-surface-variant uppercase tracking-wide">Code agence</p>
                <p class="text-sm font-medium text-on-surface mt-0.5">{{ agence.code|default('—') }}</p>
            </div>
            <div class="bg-white rounded p-3 border border-teal-100">
                <p class="text-xs text-on-surface-variant uppercase tracking-wide">Localisation</p>
                <p class="text-sm font-medium text-on-surface mt-0.5">{{ agence.ville|default('—') }}, {{ agence.pays|default('—') }}</p>
            </div>
            <div class="bg-white rounded p-3 border border-teal-100">
                <p class="text-xs text-on-surface-variant uppercase tracking-wide">Statut</p>
                <p class="text-sm font-medium text-on-surface mt-0.5">{{ agence.statut|default('ACTIF') }}</p>
            </div>
        </div>
    </div>
    {% endif %}

    {% include 'components/MfDataTable.html.twig' with {
        headers: [
            { key: 'numero', label: 'Numéro' },
            { key: 'client', label: 'Client' },
            { key: 'produit', label: 'Produit' },
            { key: 'solde', label: 'Solde' },
            { key: 'statut', label: 'Statut' },
        ],
        rows: comptes,
        actions: [
            { label: 'Détail', url: (row) => path('account_detail', { num: row.numero }), icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' },
        ],
        empty_title: 'Aucun compte',
        empty_message: 'Aucun compte trouvé pour cette agence.',
    } %}

    {% include 'partials/_pagination.html.twig' with {
        route: 'account_by_agency',
        params: { id: agence.id|default(app.request.get('id')) },
    } %}
</div>
{% endblock %}
