{% extends 'backoffice.html.twig' %}

{% block backoffice_content %}
<div class="space-y-6">
    <div>
        <h2 class="text-xl font-heading font-semibold text-on-surface">Relevé de compte</h2>
        <p class="text-sm text-on-surface-variant mt-1">Compte {{ compte.numero }} — {{ compte.client_nom|default('') }}</p>
    </div>

    <div class="bg-white rounded-lg shadow-card border border-teal-100 p-6">
        <form method="post" action="{{ path('account_statement', { num: compte.numero }) }}" class="flex flex-col sm:flex-row items-end gap-3">
            <div class="flex-1">
                <label class="block text-sm font-medium text-on-surface mb-1">Date début</label>
                <input type="date" name="date_debut" value="{{ date_debut }}" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
            </div>
            <div class="flex-1">
                <label class="block text-sm font-medium text-on-surface mb-1">Date fin</label>
                <input type="date" name="date_fin" value="{{ date_fin }}" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary-200">
            </div>
            <button type="submit" class="mf-btn-primary">Générer le relevé</button>
        </form>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-white rounded-lg shadow-card border border-teal-100 p-4 text-center">
            <p class="text-xs text-on-surface-variant uppercase tracking-wide">Solde début de période</p>
            <p class="text-lg font-heading font-semibold text-on-surface mt-1">{{ solde_debut|number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="bg-white rounded-lg shadow-card border border-teal-100 p-4 text-center">
            <p class="text-xs text-on-surface-variant uppercase tracking-wide">Solde fin de période</p>
            <p class="text-lg font-heading font-semibold text-primary mt-1">{{ solde_fin|number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="bg-white rounded-lg shadow-card border border-teal-100 p-4 text-center">
            <p class="text-xs text-on-surface-variant uppercase tracking-wide">Nombre d'opérations</p>
            <p class="text-lg font-heading font-semibold text-on-surface mt-1">{{ total_items }}</p>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-card border border-teal-100 p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-semibold text-on-surface">Détail des opérations</h3>
            <div class="flex items-center gap-2">
                <a href="#" class="mf-btn-secondary text-sm flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                    PDF
                </a>
                <a href="#" class="mf-btn-secondary text-sm flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    Excel
                </a>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="mf-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Référence</th>
                        <th>Libellé</th>
                        <th>Débit</th>
                        <th>Crédit</th>
                        <th>Solde</th>
                    </tr>
                </thead>
                <tbody>
                    {% for mvt in mouvements %}
                    <tr>
                        <td class="text-sm">{{ mvt.date|default('—')|date('d/m/Y') }}</td>
                        <td class="text-sm font-mono">{{ mvt.reference|default('—') }}</td>
                        <td class="text-sm">{{ mvt.libelle|default('—') }}</td>
                        <td class="text-sm text-red-600">{{ mvt.debit|default(0) > 0 ? (mvt.debit|number_format(0, ',', ' ')) ~ ' FCFA' : '—' }}</td>
                        <td class="text-sm text-green-600">{{ mvt.credit|default(0) > 0 ? (mvt.credit|number_format(0, ',', ' ')) ~ ' FCFA' : '—' }}</td>
                        <td class="text-sm font-medium">{{ mvt.solde|default(0)|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-8">
                            {% include 'partials/_empty_state.html.twig' with { title: 'Aucune opération', message: 'Aucune opération trouvée pour la période sélectionnée.' } %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% include 'partials/_pagination.html.twig' with {
            route: 'account_statement',
            params: { num: compte.numero },
            query: { date_debut: date_debut, date_fin: date_fin },
        } %}
    </div>
</div>
{% endblock %}
