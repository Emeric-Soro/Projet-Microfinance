{% extends 'backoffice.html.twig' %}

{% block backoffice_content %}
<div class="max-w-2xl mx-auto">
    <div>
        <h2 class="text-xl font-heading font-semibold text-on-surface">Débloquer le compte</h2>
        <p class="text-sm text-on-surface-variant mt-1">Compte {{ compte.numero }} — {{ compte.client_nom|default('') }}</p>
    </div>

    <div class="mt-6 bg-white rounded-lg shadow-card border border-teal-100 p-6">
        <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                    <p class="text-sm font-medium text-green-800">Déblocage du compte</p>
                    <p class="text-sm text-green-600 mt-1">Le compte pourra à nouveau effectuer des opérations après validation.</p>
                </div>
            </div>
        </div>

        <form method="post" action="{{ path('account_unblock', { num: compte.numero }) }}">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Motif du déblocage</label>
                    <textarea name="motif" rows="4" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary-200" placeholder="Expliquez la raison du déblocage..." required></textarea>
                </div>
                <div class="flex items-start gap-3 p-3 bg-yellow-50 border border-yellow-200 rounded">
                    <input type="checkbox" name="confirm" value="1" class="mt-1" required>
                    <label class="text-sm text-yellow-800">Je confirme vouloir débloquer ce compte.</label>
                </div>
            </div>
            <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-100 mt-6">
                <a href="{{ path('account_detail', { num: compte.numero }) }}" class="mf-btn-secondary">Annuler</a>
                <button type="submit" class="mf-btn-primary flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
                    Débloquer le compte
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
