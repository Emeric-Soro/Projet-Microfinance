{% extends 'backoffice.html.twig' %}

{% block backoffice_content %}
<div class="max-w-2xl mx-auto">
    <div>
        <h2 class="text-xl font-heading font-semibold text-on-surface">Clôture de compte</h2>
        <p class="text-sm text-on-surface-variant mt-1">Compte {{ compte.numero }} — {{ compte.client_nom|default('') }}</p>
    </div>

    <div class="mt-6 space-y-6">
        <div class="bg-white rounded-lg shadow-card border border-teal-100 p-6">
            <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                    <div>
                        <p class="text-sm font-medium text-red-800">Attention : Cette action est irréversible</p>
                        <p class="text-sm text-red-600 mt-1">Le compte sera définitivement fermé et ne pourra plus effectuer d'opérations. Le solde éventuel devra être préalablement transféré.</p>
                    </div>
                </div>
            </div>

            {% if compte.solde is defined and compte.solde > 0 %}
            <div class="mb-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                    <div>
                        <p class="text-sm font-medium text-yellow-800">Solde non nul</p>
                        <p class="text-sm text-yellow-600 mt-1">Le solde actuel est de <strong>{{ compte.solde|number_format(0, ',', ' ') }} FCFA</strong>. Veuillez transférer ou retirer ce solde avant de clôturer.</p>
                    </div>
                </div>
            </div>
            {% endif %}

            <form method="post" action="{{ path('account_closure', { num: compte.numero }) }}">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-2">Motif de clôture</label>
                        <div class="space-y-2">
                            {% for key, label in motifs %}
                            <label class="flex items-center gap-3 p-3 border border-gray-200 rounded cursor-pointer hover:border-primary transition-colors">
                                <input type="radio" name="motif" value="{{ key }}" class="mt-0.5" required>
                                <span class="text-sm text-on-surface">{{ label }}</span>
                            </label>
                            {% endfor %}
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Commentaire</label>
                        <textarea name="commentaire" rows="3" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary-200" placeholder="Informations complémentaires..."></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-on-surface mb-1">Compte de transfert du solde</label>
                        <input type="text" name="compte_transfert" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary-200" placeholder="Numéro de compte destinataire (si solde non nul)">
                    </div>
                    <div class="flex items-start gap-3 p-3 bg-yellow-50 border border-yellow-200 rounded">
                        <input type="checkbox" name="confirm" value="1" class="mt-1" required>
                        <label class="text-sm text-yellow-800">Je confirme vouloir clôturer définitivement ce compte et j'assume la responsabilité de cette action.</label>
                    </div>
                </div>
                <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-100 mt-6">
                    <a href="{{ path('account_detail', { num: compte.numero }) }}" class="mf-btn-secondary">Annuler</a>
                    <button type="submit" class="mf-btn-danger flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    Clôturer le compte
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
