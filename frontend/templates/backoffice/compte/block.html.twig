{% extends 'backoffice.html.twig' %}

{% block backoffice_content %}
<div class="max-w-2xl mx-auto">
    <div>
        <h2 class="text-xl font-heading font-semibold text-on-surface">Bloquer le compte</h2>
        <p class="text-sm text-on-surface-variant mt-1">Compte {{ compte.numero }} — {{ compte.client_nom|default('') }}</p>
    </div>

    <div class="mt-6 bg-white rounded-lg shadow-card border border-teal-100 p-6">
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                <div>
                    <p class="text-sm font-medium text-red-800">Attention : Cette action bloquera le compte</p>
                    <p class="text-sm text-red-600 mt-1">Toutes les opérations sur ce compte seront suspendues jusqu'à son déblocage.</p>
                </div>
            </div>
        </div>

        <form method="post" action="{{ path('account_block', { num: compte.numero }) }}">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Motif du blocage</label>
                    <textarea name="motif" rows="4" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary-200" placeholder="Expliquez la raison du blocage..." required></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-1">Référence (si applicable)</label>
                    <input type="text" name="reference" class="w-full border border-gray-200 rounded px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary-200" placeholder="N° de décision, réquisition, etc.">
                </div>
                <div class="flex items-start gap-3 p-3 bg-yellow-50 border border-yellow-200 rounded">
                    <input type="checkbox" name="confirm" value="1" class="mt-1" required>
                    <label class="text-sm text-yellow-800">Je confirme vouloir bloquer ce compte et j'assume la responsabilité de cette action.</label>
                </div>
            </div>
            <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-100 mt-6">
                <a href="{{ path('account_detail', { num: compte.numero }) }}" class="mf-btn-secondary">Annuler</a>
                <button type="submit" class="mf-btn-danger flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    Bloquer le compte
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
