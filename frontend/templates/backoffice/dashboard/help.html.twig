{% extends 'backoffice.html.twig' %}

{% block title %}Aide - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Aide & FAQ</h1>
    <p class="text-sm text-on-surface-variant mt-1">Questions fréquentes et documentation</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        {% if faq is defined and faq is not empty %}
            {% embed component('MfCard') with { title: 'Questions fréquentes' } %}
                {% block card_content %}
                    {% set sections = [] %}
                    {% for item in faq %}
                        {% set sections = sections|merge([{ title: item.question, content: '<p>' ~ item.reponse|nl2br ~ '</p>' }]) %}
                    {% endfor %}
                    {% include component('MfAccordion') with { sections: sections } %}
                {% endblock %}
            {% endembed %}
        {% else %}
            {% embed component('MfCard') with { title: 'Questions fréquentes' } %}
                {% block card_content %}
                    {% set sections = [
                        { title: 'Comment créer un nouveau client ?', content: '<p>Allez dans le menu Clients > Nouveau client. Remplissez les informations obligatoires (nom, prénom, pièce d\'identité) et validez.</p>' },
                        { title: 'Comment effectuer un dépôt ?', content: '<p>Depuis le tableau de bord, cliquez sur "Dépôt" dans les actions rapides ou allez dans Opérations > Dépôt. Saisissez le numéro de compte et le montant.</p>' },
                        { title: 'Comment valider une opération ?', content: '<p>Rendez-vous dans Validations > File d\'attente. Sélectionnez l\'opération à valider, vérifiez les détails et cliquez sur Approuver ou Rejeter.</p>' },
                        { title: 'Comment consulter l\'historique des transactions ?', content: '<p>Allez dans Opérations > Historique. Vous pouvez filtrer par date, type, statut ou compte.</p>' },
                        { title: 'Comment générer un rapport ?', content: '<p>Allez dans Reporting, choisissez le type de rapport (comptable, crédit, etc.), sélectionnez la période et cliquez sur Générer.</p>' },
                        { title: 'Comment gérer mon profil ?', content: '<p>Cliquez sur votre nom en haut à droite, puis sur "Mon profil". Vous pouvez y modifier vos informations personnelles.</p>' },
                    ] %}
                    {% include component('MfAccordion') with { sections: sections } %}
                {% endblock %}
            {% endembed %}
        {% endif %}
    </div>

    <div class="space-y-6">
        {% embed component('MfCard') with { title: 'Besoin d\'aide ?' } %}
            {% block card_content %}
                <div class="space-y-4 text-sm text-on-surface-variant">
                    <p>Contactez le support technique pour une assistance personnalisée.</p>
                    <div class="bg-gray-50 rounded-lg p-4 space-y-2">
                        <p class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            <span>support@microfin.com</span>
                        </p>
                        <p class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            <span>+225 01 02 03 04 05</span>
                        </p>
                    </div>
                </div>
            {% endblock %}
        {% endembed %}

        {% embed component('MfCard') with { title: 'Liens utiles' } %}
            {% block card_content %}
                <ul class="space-y-2 text-sm">
                    <li><a href="#" class="text-primary hover:text-primary-600">Guide de l'utilisateur</a></li>
                    <li><a href="#" class="text-primary hover:text-primary-600">Manuel de procédures</a></li>
                    <li><a href="#" class="text-primary hover:text-primary-600">Documentation technique</a></li>
                    <li><a href="#" class="text-primary hover:text-primary-600">Notes de version</a></li>
                </ul>
            {% endblock %}
        {% endembed %}
    </div>
</div>
{% endblock %}
