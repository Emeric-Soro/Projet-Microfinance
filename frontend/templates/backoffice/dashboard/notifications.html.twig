{% extends 'backoffice.html.twig' %}

{% block title %}Notifications - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Notifications</h1>
    <p class="text-sm text-on-surface-variant mt-1">Centre de notifications</p>
</div>

{% if notifications is defined and notifications is not empty %}
    <div class="space-y-3">
        {% for notification in notifications %}
            <div class="bg-white rounded-lg shadow-card border border-teal-100 p-4 hover:border-teal-300 transition-colors {{ notification.lue ? '' : 'border-l-4 border-l-primary' }}">
                <div class="flex items-start justify-between gap-4">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                            {% if notification.lue is not defined or not notification.lue %}
                                <span class="w-2 h-2 rounded-full bg-primary flex-shrink-0"></span>
                            {% endif %}
                            <h3 class="text-sm font-semibold text-on-surface truncate">{{ notification.titre }}</h3>
                            {% include component('MfStatusBadge') with { status: notification.type|default('INFO') } %}
                        </div>
                        <p class="text-sm text-on-surface-variant line-clamp-2">{{ notification.message }}</p>
                        <p class="text-xs text-on-surface-variant mt-2">{{ notification.date|date_fr }}</p>
                    </div>
                    <a href="{{ path('notification_detail', { id: notification.id }) }}" class="flex-shrink-0 text-sm font-medium text-primary hover:text-primary-600">
                        Détail
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    {% include 'partials/_empty_state.html.twig' with { title: 'Aucune notification', message: 'Vous n\'avez aucune notification pour le moment.' } %}
{% endif %}
{% endblock %}
