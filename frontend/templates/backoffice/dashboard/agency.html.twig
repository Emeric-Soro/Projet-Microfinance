{% extends 'backoffice.html.twig' %}

{% block title %}Agence - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Tableau de bord Agence</h1>
    <p class="text-sm text-on-surface-variant mt-1">Indicateurs de l'agence #{{ agence_id }}</p>
</div>

{% if data is defined and data is not empty %}
    {% embed component('MfStatsGrid') with { cols: 4, stats: [
        { label: 'Clients', value: data.totalClients|default(0)|number_format(0, ',', ' '), icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', icon_bg: 'bg-blue-50', icon_color: 'text-blue-600' },
        { label: 'Comptes', value: data.totalComptes|default(0)|number_format(0, ',', ' '), icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z', icon_bg: 'bg-teal-50', icon_color: 'text-teal-600' },
        { label: 'Encours crédit', value: data.encoursCredit|default(0)|montant, icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
        { label: 'Épargne', value: data.epargne|default(0)|montant, icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', icon_bg: 'bg-purple-50', icon_color: 'text-purple-600' },
    ]} %}
        {% block card_content %}{{ parent() }}{% endblock %}
    {% endembed %}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
        {% embed component('MfCard') with { title: 'Dernières opérations', action: { url: path('operation_history'), label: 'Voir tout' } } %}
            {% block card_content %}
                {% set headers = [
                    { label: 'Réf', key: 'reference' },
                    { label: 'Type', key: 'type' },
                    { label: 'Montant', key: 'montant' },
                    { label: 'Date', key: 'date' },
                ] %}
                {% set rows = data.dernieresOperations|default([]) %}
                {% include component('MfDataTable') with { headers: headers, rows: rows } %}
            {% endblock %}
        {% endembed %}

        {% embed component('MfCard') with { title: 'Résumé du personnel' } %}
            {% block card_content %}
                {% set items = [
                    { label: 'Effectif total', value: data.effectifTotal|default(0) },
                    { label: 'Caissiers', value: data.caissiers|default(0) },
                    { label: 'Agents de crédit', value: data.agentsCredit|default(0) },
                    { label: 'Guichets ouverts', value: data.guichetsOuverts|default(0) },
                ] %}
                {% include component('MfSummaryCard') with { items: items } %}
            {% endblock %}
        {% endembed %}
    </div>
{% else %}
    {% include 'partials/_empty_state.html.twig' with { title: 'Chargement...', message: 'Données de l\'agence en cours de chargement.' } %}
{% endif %}
{% endblock %}
