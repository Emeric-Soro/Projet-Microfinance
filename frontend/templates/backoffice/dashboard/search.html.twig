{% extends 'backoffice.html.twig' %}

{% block title %}Recherche - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Recherche globale</h1>
    <p class="text-sm text-on-surface-variant mt-1">Recherchez dans l'ensemble de l'application</p>
</div>

<div class="bg-white rounded-lg shadow-card border border-teal-100 p-6 mb-6">
    <form method="get" action="{{ path('global_search') }}" class="flex gap-3">
        <div class="flex-1">
            <input type="text" name="q" value="{{ query }}" placeholder="Rechercher un client, un compte, une opération..."
                   class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary">
        </div>
        <button type="submit" class="mf-btn-primary px-6">
            <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            Rechercher
        </button>
    </form>
</div>

{% if query is not empty %}
    <p class="text-sm text-on-surface-variant mb-4">
        Résultats pour <strong>"{{ query }}"</strong>
        {% if results.total is defined %}
            — {{ results.total }} résultat(s)
        {% endif %}
    </p>

    {% if results is defined and results is not empty %}
        {% if results.clients is defined and results.clients is not empty %}
            {% embed component('MfCard') with { title: 'Clients' } %}
                {% block card_content %}
                    {% set headers = [
                        { label: 'N° Client', key: 'numero' },
                        { label: 'Nom', key: 'nom' },
                        { label: 'Prénom', key: 'prenom' },
                        { label: 'Téléphone', key: 'telephone' },
                    ] %}
                    {% set rows = results.clients %}
                    {% include component('MfDataTable') with { headers: headers, rows: rows } %}
                {% endblock %}
            {% endembed %}
        {% endif %}

        {% if results.comptes is defined and results.comptes is not empty %}
            {% embed component('MfCard') with { title: 'Comptes' } %}
                {% block card_content %}
                    {% set headers = [
                        { label: 'N° Compte', key: 'numero' },
                        { label: 'Client', key: 'client' },
                        { label: 'Solde', key: 'solde' },
                        { label: 'Statut', key: 'statut' },
                    ] %}
                    {% set rows = results.comptes %}
                    {% include component('MfDataTable') with { headers: headers, rows: rows } %}
                {% endblock %}
            {% endembed %}
        {% endif %}

        {% if results.operations is defined and results.operations is not empty %}
            {% embed component('MfCard') with { title: 'Opérations' } %}
                {% block card_content %}
                    {% set headers = [
                        { label: 'Réf', key: 'reference' },
                        { label: 'Type', key: 'type' },
                        { label: 'Montant', key: 'montant' },
                        { label: 'Date', key: 'date' },
                        { label: 'Statut', key: 'statut' },
                    ] %}
                    {% set rows = results.operations %}
                    {% include component('MfDataTable') with { headers: headers, rows: rows } %}
                {% endblock %}
            {% endembed %}
        {% endif %}

        {% if results.credits is defined and results.credits is not empty %}
            {% embed component('MfCard') with { title: 'Crédits' } %}
                {% block card_content %}
                    {% set headers = [
                        { label: 'N° Crédit', key: 'numero' },
                        { label: 'Client', key: 'client' },
                        { label: 'Montant', key: 'montant' },
                        { label: 'Statut', key: 'statut' },
                    ] %}
                    {% set rows = results.credits %}
                    {% include component('MfDataTable') with { headers: headers, rows: rows } %}
                {% endblock %}
            {% endembed %}
        {% endif %}

        {% if results is empty or (results.clients is not defined and results.comptes is not defined and results.operations is not defined and results.credits is not defined) %}
            {% include 'partials/_empty_state.html.twig' with { title: 'Aucun résultat', message: 'Aucun résultat trouvé pour votre recherche.' } %}
        {% endif %}
    {% else %}
        {% include 'partials/_empty_state.html.twig' with { title: 'Aucun résultat', message: 'Aucun résultat trouvé pour votre recherche.' } %}
    {% endif %}
{% endif %}
{% endblock %}
