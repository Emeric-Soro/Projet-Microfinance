{% extends 'backoffice.html.twig' %}

{% block title %}Dépôt - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Dépôt</h1>
    <p class="text-sm text-on-surface-variant mt-1">Effectuer un dépôt sur un compte</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
        {% embed component('MfFormCard') with { title: 'Formulaire de dépôt', description: 'Saisissez les informations du dépôt' } %}
            {% block form_fields %}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {% include component('MfSelect') with { name: 'compte', label: 'Compte bénéficiaire', required: true, options: accounts|map(a => { value: a.numero, label: a.numero ~ ' - ' ~ a.client_nom }) } %}
                    {% include component('MfMoneyInput') with { name: 'montant', label: 'Montant', required: true } %}
                    {% include component('MfSelect') with { name: 'type_operation', label: 'Mode de dépôt', value: 'ESPECES', options: [
                        { value: 'ESPECES', label: 'Espèces' },
                        { value: 'CHEQUE', label: 'Chèque' },
                        { value: 'VIREMENT', label: 'Virement' },
                        { value: 'MOBILE_MONEY', label: 'Mobile Money' },
                    ]} %}
                    {% include component('MfDatePicker') with { name: 'date_operation', label: 'Date opération', value: 'now'|date('Y-m-d') } %}
                    {% include component('MfInput') with { name: 'guichet', label: 'Guichet' } %}
                    {% include component('MfInput') with { name: 'description', label: 'Description' } %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>

    <div class="lg:col-span-1">
        {% embed component('MfCard') with { title: 'Instructions' } %}
            {% block card_content %}
                <div class="text-sm text-on-surface-variant space-y-3">
                    <p>Vérifiez l'identité du client avant d'effectuer le dépôt.</p>
                    <p>Le montant minimum pour un dépôt est de 1 000 FCFA.</p>
                    <p>Pour les dépôts par chèque, assurez-vous que le chèque est endossé.</p>
                    {% include component('MfAlertBanner') with { type: 'info', message: 'Les dépôts en espèces supérieurs à 1 000 000 FCFA nécessitent une déclaration.' } %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>
</div>
{% endblock %}
