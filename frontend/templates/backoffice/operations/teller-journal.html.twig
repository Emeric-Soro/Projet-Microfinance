{% extends 'backoffice.html.twig' %}

{% block title %}Journal de guichet - MicroFin{% endblock %}

{% block backoffice_content %}
<div class="mb-6">
    <h1 class="text-2xl font-heading font-bold text-on-surface">Journal de guichet</h1>
    <p class="text-sm text-on-surface-variant mt-1">Consultez les opérations par date et guichet</p>
</div>

<div class="bg-white rounded-lg shadow-card border border-teal-100 p-4 mb-6">
    <form method="get" class="flex items-end gap-4">
        {% include component('MfDatePicker') with { name: 'date', label: 'Date', value: selected_date } %}
        {% include component('MfInput') with { name: 'guichet', label: 'Guichet', placeholder: 'Tous' } %}
        <button type="submit" class="mf-btn-primary">Filtrer</button>
    </form>
</div>

{% if summary is defined and summary is not empty %}
    {% embed component('MfStatsGrid') with { cols: 4, stats: [
        { label: 'Total dépôts', value: summary.totalDepots|default(0)|montant, icon: 'M12 4v16m8-8H4', icon_bg: 'bg-green-50', icon_color: 'text-green-600' },
        { label: 'Total retraits', value: summary.totalRetraits|default(0)|montant, icon: 'M20 12H4', icon_bg: 'bg-red-50', icon_color: 'text-red-600' },
        { label: 'Nombre opérations', value: summary.nombreOperations|default(0), icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', icon_bg: 'bg-blue-50', icon_color: 'text-blue-600' },
        { label: 'Solde net', value: (summary.totalDepots|default(0) - summary.totalRetraits|default(0))|montant, icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3', icon_bg: 'bg-teal-50', icon_color: 'text-teal-600' },
    ]} %}
        {% block card_content %}
            {{ parent() }}
        {% endblock %}
    {% endembed %}
{% endif %}

{% embed component('MfCard') with { title: 'Opérations du ' ~ selected_date|date_fr, class: 'mt-6' } %}
    {% block card_content %}
        {% embed component('MfDataTable') with {
            headers: [
                { key: 'heure', label: 'Heure', sortable: true },
                { key: 'reference', label: 'Réf', sortable: true },
                { key: 'type', label: 'Type', sortable: true },
                { key: 'compte', label: 'Compte' },
                { key: 'client', label: 'Client' },
                { key: 'montant', label: 'Montant', sortable: true },
                { key: 'statut', label: 'Statut' },
            ],
            rows: transactions,
            actions: [
                { label: 'Détail', url: (row) => path('operation_detail', { ref: row.reference }), icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' },
            ],
            empty_title: 'Aucune opération',
            empty_message: 'Aucune opération enregistrée pour cette date.',
        } %}
            {% block card_content %}
                {{ parent() }}
            {% endblock %}
        {% endembed %}
    {% endblock %}
{% endembed %}
{% endblock %}
