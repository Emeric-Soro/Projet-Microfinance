{% if pending_validation is defined and pending_validation %}
<div class="mb-4 p-4 bg-orange-50 border border-orange-200 rounded-lg">
    <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <div class="flex-1">
            <p class="text-sm font-medium text-orange-800">
                Cette action est en attente de validation
            </p>
            <p class="text-xs text-orange-600 mt-1">
                Soumise par {{ pending_validation.maker|default('') }} le {{ pending_validation.date|default('')|date_fr }}
            </p>
        </div>
        <a href="{{ path('validation_detail', {id: pending_validation.id}) }}" class="text-sm font-medium text-orange-700 hover:text-orange-800 underline">
            Voir
        </a>
    </div>
</div>
{% endif %}
