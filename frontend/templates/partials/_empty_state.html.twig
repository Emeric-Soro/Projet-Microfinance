<div class="mf-empty-state">
    <svg class="w-16 h-16 mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
    </svg>
    <h3 class="text-lg font-medium text-on-surface mb-1">{{ title|default('Aucune donnée') }}</h3>
    <p class="text-sm text-on-surface-variant mb-4">{{ message|default('Aucun élément trouvé pour le moment.') }}</p>
    {% if action_url is defined and action_label is defined %}
        <a href="{{ action_url }}" class="mf-btn-primary">{{ action_label }}</a>
    {% endif %}
</div>
