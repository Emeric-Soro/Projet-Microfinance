<div class="border border-gray-200 rounded-lg overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 bg-gray-50 border-b border-gray-200">
        <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-on-surface-variant" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            <span class="text-sm font-medium">{{ document_name|default('Document') }}</span>
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ download_url|default('#') }}" class="text-sm text-primary hover:text-primary-600 flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Télécharger
            </a>
            <span class="text-xs text-on-surface-variant">{{ file_size|default('') }}</span>
        </div>
    </div>
    <div class="bg-gray-100 aspect-video flex items-center justify-center">
        {% if preview_url is defined %}
            <iframe src="{{ preview_url }}" class="w-full h-full" frameborder="0"></iframe>
        {% else %}
            <div class="text-center text-on-surface-variant">
                <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                <p class="text-sm">Aperçu non disponible</p>
            </div>
        {% endif %}
    </div>
</div>
