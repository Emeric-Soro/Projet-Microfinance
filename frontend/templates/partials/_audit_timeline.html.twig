{% if entries is defined and entries is not empty %}
<div class="flow-root">
    <ul class="-mb-8">
        {% for entry in entries %}
        <li>
            <div class="relative pb-8">
                {% if not loop.last %}
                <span class="absolute left-4 top-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                {% endif %}
                <div class="relative flex space-x-3">
                    <div>
                        <span class="h-8 w-8 rounded-full flex items-center justify-center ring-8 ring-white {{ entry.type|default('info') == 'create' ? 'bg-green-500' : entry.type == 'update' ? 'bg-blue-500' : entry.type == 'delete' ? 'bg-red-500' : 'bg-gray-400' }}">
                            <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                {% if entry.type == 'create' %}
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                {% elseif entry.type == 'update' %}
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                                {% elseif entry.type == 'delete' %}
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                {% else %}
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                {% endif %}
                            </svg>
                        </span>
                    </div>
                    <div class="min-w-0 flex-1 pt-1.5">
                        <p class="text-sm text-on-surface">
                            {{ entry.action|default('') }}
                            {% if entry.user is defined %}
                            <span class="font-medium">{{ entry.user }}</span>
                            {% endif %}
                        </p>
                        {% if entry.details is defined %}
                        <p class="text-xs text-on-surface-variant mt-1">{{ entry.details }}</p>
                        {% endif %}
                        <p class="text-xs text-on-surface-variant mt-1">
                            {{ entry.date|default('')|date_fr }}
                            {% if entry.time is defined %}
                            à {{ entry.time }}
                            {% endif %}
                        </p>
                    </div>
                </div>
            </div>
        </li>
        {% endfor %}
    </ul>
</div>
{% else %}
    <p class="text-sm text-on-surface-variant text-center py-8">Aucun historique disponible</p>
{% endif %}
