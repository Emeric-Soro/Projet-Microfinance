{% if total_pages is defined and total_pages > 1 %}
<div class="flex items-center justify-between mt-4">
    <p class="text-sm text-on-surface-variant">
        Affichage de <span class="font-medium">{{ current_page * page_size + 1 }}</span> à 
        <span class="font-medium">{{ min((current_page + 1) * page_size, total_items) }}</span> 
        sur <span class="font-medium">{{ total_items }}</span> résultats
    </p>
    <div class="flex items-center gap-1">
        <a href="{{ path(route, query|merge({page: current_page - 1})) }}" 
           class="px-3 py-2 text-sm border border-gray-200 rounded hover:bg-primary-50 hover:border-primary transition-colors {{ current_page <= 0 ? 'pointer-events-none opacity-50' : '' }}"
           {% if current_page <= 0 %}disabled{% endif %}>
            Précédent
        </a>
        {% for i in range(0, total_pages - 1) %}
            {% if i == current_page %}
                <span class="px-3 py-2 text-sm bg-primary text-white rounded">{{ i + 1 }}</span>
            {% elseif i == 0 or i == total_pages - 1 or (i >= current_page - 2 and i <= current_page + 2) %}
                <a href="{{ path(route, query|merge({page: i})) }}" class="px-3 py-2 text-sm border border-gray-200 rounded hover:bg-primary-50 hover:border-primary transition-colors">{{ i + 1 }}</a>
            {% elseif i == current_page - 3 or i == current_page + 3 %}
                <span class="px-2 text-on-surface-variant">...</span>
            {% endif %}
        {% endfor %}
        <a href="{{ path(route, query|merge({page: current_page + 1})) }}" 
           class="px-3 py-2 text-sm border border-gray-200 rounded hover:bg-primary-50 hover:border-primary transition-colors {{ current_page >= total_pages - 1 ? 'pointer-events-none opacity-50' : '' }}"
           {% if current_page >= total_pages - 1 %}disabled{% endif %}>
            Suivant
        </a>
    </div>
</div>
{% endif %}
