{% extends 'auth.html.twig' %}

{% block title %}Mot de passe oublié - MicroFin{% endblock %}

{% block auth_content %}
<h2 class="font-heading text-xl font-semibold text-primary mb-2">Mot de passe oublié</h2>
<p class="text-sm text-on-surface-variant mb-6">Saisissez votre adresse email pour recevoir un lien de réinitialisation.</p>

<form method="post" action="{{ path('forgot_password') }}" class="space-y-5">
    <div>
        <label for="email" class="block text-sm font-medium text-on-surface mb-1.5">Adresse email</label>
        <input type="email" id="email" name="email" required autocomplete="email" autofocus
               class="w-full px-4 py-2.5 border border-teal-200 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary bg-white placeholder-gray-400"
               placeholder="vous@exemple.com">
    </div>

    <button type="submit"
            class="w-full bg-primary text-white font-medium py-2.5 px-4 rounded-lg hover:bg-primary-600 focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors text-sm">
        Envoyer le lien
    </button>

    <div class="text-center">
        <a href="{{ path('login') }}" class="text-sm text-primary hover:text-primary-600 underline">
            Retour à la connexion
        </a>
    </div>
</form>
{% endblock %}
