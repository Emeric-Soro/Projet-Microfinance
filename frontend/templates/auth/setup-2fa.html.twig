{% extends 'auth.html.twig' %}

{% block title %}Configuration 2FA - MicroFin{% endblock %}

{% block auth_content %}
<h2 class="font-heading text-xl font-semibold text-primary mb-2">Authentification à deux facteurs</h2>
<p class="text-sm text-on-surface-variant mb-6">Scannez le code QR avec votre application d'authentification (Google Authenticator, Authy, etc.).</p>

{% if qr_code %}
<div class="flex justify-center mb-6">
    <div class="bg-white p-4 rounded-lg border border-teal-100">
        <img src="{{ qr_code }}" alt="QR Code 2FA" class="w-48 h-48">
    </div>
</div>
{% endif %}

{% if secret %}
<div class="mb-6 p-4 bg-teal-50 rounded-lg border border-teal-100">
    <p class="text-xs font-medium text-primary mb-1">Ou saisissez cette clé manuellement :</p>
    <p class="text-sm font-mono text-primary-700 break-all select-all">{{ secret }}</p>
</div>
{% endif %}

{% if manual_key %}
<div class="mb-6 p-4 bg-teal-50 rounded-lg border border-teal-100">
    <p class="text-xs font-medium text-primary mb-1">Clé manuelle :</p>
    <p class="text-sm font-mono text-primary-700 break-all select-all">{{ manual_key }}</p>
</div>
{% endif %}

<form method="post" action="{{ path('setup_2fa') }}" class="space-y-5">
    <div>
        <label for="verification_code" class="block text-sm font-medium text-on-surface mb-1.5">Code de vérification</label>
        <input type="text" id="verification_code" name="verification_code" required inputmode="numeric"
               maxlength="6" autofocus
               class="w-full px-4 py-2.5 border border-teal-200 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary bg-white placeholder-gray-400 text-center text-lg tracking-widest"
               placeholder="••••••">
    </div>

    <button type="submit"
            class="w-full bg-primary text-white font-medium py-2.5 px-4 rounded-lg hover:bg-primary-600 focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors text-sm">
        Activer la 2FA
    </button>

    <div class="text-center">
        <a href="{{ path('dashboard_general') }}" class="text-sm text-primary hover:text-primary-600 underline">
            Passer cette étape
        </a>
    </div>
</form>
{% endblock %}
