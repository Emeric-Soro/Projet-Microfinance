{% extends 'auth.html.twig' %}

{% block title %}Vérification OTP - MicroFin{% endblock %}

{% block auth_content %}
<h2 class="font-heading text-xl font-semibold text-primary mb-2">Vérification OTP</h2>
<p class="text-sm text-on-surface-variant mb-6">Un code de vérification a été envoyé à votre adresse email ou téléphone.</p>

<form method="post" action="{{ path('login_otp') }}" class="space-y-5">
    <div>
        <label for="otp" class="block text-sm font-medium text-on-surface mb-1.5">Code de vérification</label>
        <input type="text" id="otp" name="otp" required autocomplete="one-time-code" inputmode="numeric"
               maxlength="6" autofocus
               class="w-full px-4 py-2.5 border border-teal-200 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary bg-white placeholder-gray-400 text-center text-lg tracking-widest"
               placeholder="••••••">
    </div>

    <button type="submit"
            class="w-full bg-primary text-white font-medium py-2.5 px-4 rounded-lg hover:bg-primary-600 focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors text-sm">
        Vérifier
    </button>

    <div class="text-center">
        <a href="{{ path('login') }}" class="text-sm text-primary hover:text-primary-600 underline">
            Retour à la connexion
        </a>
    </div>
</form>
{% endblock %}
