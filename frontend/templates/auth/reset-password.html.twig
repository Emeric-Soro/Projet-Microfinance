{% extends 'auth.html.twig' %}

{% block title %}Réinitialiser le mot de passe - MicroFin{% endblock %}

{% block auth_content %}
<h2 class="font-heading text-xl font-semibold text-primary mb-2">Réinitialiser le mot de passe</h2>
<p class="text-sm text-on-surface-variant mb-6">Choisissez un nouveau mot de passe sécurisé.</p>

<form method="post" action="{{ path('reset_password', { token: token }) }}" class="space-y-5">
    <div>
        <label for="new_password" class="block text-sm font-medium text-on-surface mb-1.5">Nouveau mot de passe</label>
        <input type="password" id="new_password" name="new_password" required autocomplete="new-password" autofocus
               minlength="8"
               class="w-full px-4 py-2.5 border border-teal-200 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary bg-white placeholder-gray-400"
               placeholder="Au moins 8 caractères">
    </div>

    <div>
        <label for="confirm_password" class="block text-sm font-medium text-on-surface mb-1.5">Confirmer le mot de passe</label>
        <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password"
               minlength="8"
               class="w-full px-4 py-2.5 border border-teal-200 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary bg-white placeholder-gray-400"
               placeholder="Répétez le mot de passe">
    </div>

    <button type="submit"
            class="w-full bg-primary text-white font-medium py-2.5 px-4 rounded-lg hover:bg-primary-600 focus:ring-2 focus:ring-primary focus:ring-offset-2 transition-colors text-sm">
        Réinitialiser le mot de passe
    </button>

    <div class="text-center">
        <a href="{{ path('login') }}" class="text-sm text-primary hover:text-primary-600 underline">
            Retour à la connexion
        </a>
    </div>
</form>
{% endblock %}
