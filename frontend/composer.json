{
    "name": "microfin/frontend",
    "type": "project",
    "description": "MicroFin M01 Web Operateur - Backoffice Symfony",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/security-bundle": "7.2.*",
        "symfony/http-client": "7.2.*",
        "symfony/translation": "7.2.*",
        "symfony/validator": "7.2.*",
        "symfony/form": "7.2.*",
        "symfony/asset": "7.2.*",
        "symfony/messenger": "7.2.*",
        "symfony/lock": "7.2.*",
        "symfony/rate-limiter": "7.2.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/webpack-encore-bundle": "^2.2",
        "symfony/ux-turbo": "^2.20",
        "symfony/ux-chartjs": "^2.20",
        "symfony/ux-autocomplete": "^2.20",
        "symfony/ux-dropzone": "^2.20",
        "symfony/ux-live-component": "^2.20",
        "doctrine/orm": "^3.3",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "lexik/jwt-authentication-bundle": "^3.1",
        "scheb/2fa-bundle": "^7.2",
        "scheb/2fa-totp": "^7.2",
        "scheb/2fa-backup-code": "^7.2",
        "nelmio/api-doc-bundle": "^4.18",
        "knplabs/knp-snappy-bundle": "^1.10",
        "phpoffice/phpspreadsheet": "^2.2",
        "ext-json": "*",
        "symfony/runtime": "*",
        "symfony/dotenv": "^7.2"
    },
    "require-dev": {
        "symfony/debug-bundle": "7.2.*",
        "symfony/web-profiler-bundle": "7.2.*",
        "symfony/var-dumper": "7.2.*",
        "symfony/maker-bundle": "^1.60"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "lexik/jwt-authentication-bundle": true
        }
    }
}
